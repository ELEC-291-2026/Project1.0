090E            203   ; The 8-bit hex number passed in the accumulator is converted to
090E            204   ; BCD and stored in [R1, R0]
090E            205   Hex_to_bcd_8bit:
090E 75F064     206            mov b, #100
0911 84         207            div ab
0912 F9         208            mov R1, a   ; After dividing, a has the 100s
0913 E5F0       209            mov a, b    ; Remainder is in register b
0915 75F00A     210            mov b, #10
0918 84         211            div ab ; The tens are stored in a, the units are stored in b 
0919 C4         212            swap a
091A 54F0       213            anl a, #0xf0
091C 45F0       214            orl a, b
091E F8         215            mov R0, a
091F 22         216            ret
