0000              1   ; main project file
                  3   $LIST
0000              5   
0000              6   
0000              7   CLK              EQU 33333333 ; Microcontroller system crystal frequency in Hz
0000              8   TIMER0_RATE      EQU 1000     ; 1000Hz, for a timer tick of 1ms
0000              9   TIMER0_RELOAD    EQU ((65536-(CLK/(12*TIMER0_RATE))))
0000             10   FREQ                     EQU 33333333
0000             11   BAUD                     EQU 115200
0000             12   T1LOAD                   EQU 256-(FREQ/(32*12*BAUD))
0000             13   
0000             14   ;PIN Assignemet
0000             15   ;Need to figure out wich ADC pins the LM335 and OP07 are on 
0000             16   LM335_ADC equ 0
0000             17   OP07_ADC equ 1
0000             18   
0000             19   
0000             20   ; Reset vector
0000             21   org 0x0000
0000 020B58      22       ljmp main
0003             23       
0003             24   ; Timer/Counter 0 overflow interrupt vector
000B             25   org 0x000B
000B 0208A2      26            ljmp Timer0_ISR
000E             27   
0030             28   dseg at 0x30
0030             29   ; For math 
