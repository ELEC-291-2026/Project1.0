                614   $LIST
                 -1   $include(LCD_4bit_DE10Lite_no_RW.inc) ; A library of LCD related functions and utility macros
0300              1   ;  LCD routines adapted for the DE10-Lite configured as a CV_8052 processor
0300              2   cseg
0300              3   
0300              4   ; When using a 33.333333MHz crystal clock
0300              5   ; one cycle takes 1.0/33.333333MHz = 30 ns
0300              6   
0300              7   ;---------------------------------;
0300              8   ; Wait 40 microseconds            ;
0300              9   ;---------------------------------;
0300             10   Wait40uSec:
0300 C000        11            push AR0
0302 78BE        12            mov R0, #190
0304             13   L0: 
0304 00          14            nop
0305 00          15            nop
0306 00          16            nop
0307 00          17            nop
0308 D8FA        18            djnz R0, L0 ; 1+1+1+1+3 cycles->7*30ns*190=40us
030A D000        19            pop AR0
030C 22          20       ret
030D             21   
030D             22   ;---------------------------------;
030D             23   ; Wait 'R2' milliseconds          ;
030D             24   ;---------------------------------;
                 25   Wait_Milli_Seconds mac
                 26   	push AR2
                 27   	mov R2, %0
                 28   	lcall ?Wait_Milli_Seconds
                 29   	pop AR2
                 30   endmac
030D             31   
030D             32   ?Wait_Milli_Seconds:
030D C000        33            push AR0
030F C001        34            push AR1
0311 7932        35   L3: mov R1, #50
0313 78DF        36   L2: mov R0, #223
0315 D8FE        37   L1: djnz R0, L1 ; 3 cycles->3*30ns*250=20.07us
0317 D9FA        38       djnz R1, L2 ; 20.07us*50=1.004ms
0319 DAF6        39       djnz R2, L3 ; number of millisecons to wait passed in R2
031B D001        40       pop AR1
031D D000        41       pop AR0
031F 22          42       ret
0320             43            
0320             44   ;---------------------------------;
0320             45   ; Toggles the 'E' pin in the LCD  ;
0320             46   ;---------------------------------;
0320             47   ELCD_pulse:
0320 D291        48            setb ELCD_E
0322 120300      49            lcall Wait40uSec
0325 C291        50            clr ELCD_E
0327 120300      51       lcall Wait40uSec ; This line is needed in the DE1SoC running an 8051 because it is much faster than the AT89LP51RC2
032A 22          52       ret
032B             53   
032B             54   ;---------------------------------;
032B             55   ; Writes acc to LCD in 4-bit mode ;
032B             56   ;---------------------------------;
032B             57   ELCD_byte:
032B             58            ; Write high 4 bits first
032B A2E7        59            mov c, ACC.7
032D 9281        60            mov ELCD_D7, c
032F A2E6        61            mov c, ACC.6
0331 9283        62            mov ELCD_D6, c
0333 A2E5        63            mov c, ACC.5
0335 9285        64            mov ELCD_D5, c
0337 A2E4        65            mov c, ACC.4
0339 9287        66            mov ELCD_D4, c
033B 120320      67       lcall ELCD_pulse
033E             68            ; Write low 4 bits next
033E A2E3        69            mov c, ACC.3
0340 9281        70            mov ELCD_D7, c
0342 A2E2        71            mov c, ACC.2
0344 9283        72            mov ELCD_D6, c
0346 A2E1        73            mov c, ACC.1
0348 9285        74            mov ELCD_D5, c
034A A2E0        75            mov c, ACC.0
034C 9287        76            mov ELCD_D4, c
034E 120320      77       lcall ELCD_pulse
0351 22          78            ret
0352             79   
0352             80   ;---------------------------------;
0352             81   ; Write data to LCD               ;
0352             82   ;---------------------------------;
                 83   WriteData mac
                 84   	mov a, %0
                 85   	lcall ?WriteData
                 86   endmac
0352             87            
0352             88   ?WriteData:
0352 D297        89            setb ELCD_RS
0354 02032B      90            ljmp ELCD_byte
0357             91   
0357             92   ;---------------------------------;
0357             93   ; Write command to LCD            ;
0357             94   ;---------------------------------;
                 95   WriteCommand mac
                 96   	mov a, %0
                 97   	lcall ?WriteCommand
                 98   endmac
0357             99   
0357            100   ?WriteCommand:
0357 C297       101            clr ELCD_RS
0359 02032B     102            ljmp ELCD_byte
035C            103   
035C            104   ;---------------------------------;
035C            105   ; Configure LCD in 4-bit mode     ;
035C            106   ;---------------------------------;
035C            107   ELCD_4BIT:
035C C291       108            clr ELCD_E   ; Resting state of LCD's enable pin is zero
035E            109            ;clr ELCD_RW  ; RW forced to zero
035E            110            
035E            111            ; After power on, let the LCD start up before initializing
035E C002       112            push AR2
0360 7A28       112            mov R2, #40
0362 12030D     112            lcall ?Wait_Milli_Seconds
0365 D002       112            pop AR2
0367            113            
0367            114            ; First make sure the LCD is in 8-bit mode and then change to 4-bit mode
0367 7433       115            mov a, #0x33
0369 120357     115            lcall ?WriteCommand
036C 7433       116            mov a, #0x33
036E 120357     116            lcall ?WriteCommand
0371 7432       117            mov a, #0x32
0373 120357     117            lcall ?WriteCommand ; change to 4-bit mode
0376            118   
0376            119            ; Configure the LCD
0376 7428       120            mov a, #0x28
0378 120357     120            lcall ?WriteCommand
037B 740C       121            mov a, #0x0c
037D 120357     121            lcall ?WriteCommand
0380 7401       122            mov a, #0x01
0382 120357     122            lcall ?WriteCommand ;  Clear screen command (takes some time)
0385            123   
0385            124       ;Wait for the clear screen command to finish.
0385 C002       125            push AR2
0387 7A02       125            mov R2, #2
0389 12030D     125            lcall ?Wait_Milli_Seconds
038C D002       125            pop AR2
038E 22         126       ret
038F            127   
038F            128   ;---------------------------------;
038F            129   ; Send a constant string to LCD   ;
038F            130   ;---------------------------------;
                131   Send_Constant_String mac
                132   	push dph
                133   	push dpl
                134   	push acc
                135   	mov dptr, %0
                136   	lcall ?Send_Constant_String
                137   	pop acc
                138   	pop dpl
                139   	pop dph
                140   endmac
038F            141   
038F            142   ?Send_Constant_String:
038F E4         143       clr a
0390 93         144       movc a, @a+dptr
0391 6006       145       jz ?Send_Constant_String_Done
0393 120352     146       lcall ?WriteData
0396 A3         147       inc dptr
0397 80F6       148       sjmp ?Send_Constant_String
0399            149   ?Send_Constant_String_Done:
0399 22         150       ret  
039A            151   
039A            152   ;---------------------------------;
039A            153   ; Set LCD cursor at row, column   ;
039A            154   ;---------------------------------;
                155   Set_Cursor mac
                156   	push acc
                157   	mov a, #%1
                158   	dec a
                159   	lcall ?Set_Cursor_%0 ; Select column and row
                160   	pop acc
                161   endmac
039A            162   
039A            163   ?Set_Cursor_2:
039A 4440       164            orl a, #01000000B
039C            165   ?Set_Cursor_1:
039C 4480       166            orl a, #10000000B
039E 020357     167            ljmp ?WriteCommand ; Select column and row
03A1            168   
03A1            169   ;---------------------------------;
03A1            170   ; Display a BCD number in the LCD ;
03A1            171   ;---------------------------------;
                172   Display_BCD mac
                173   	push ar0
                174   	mov r0, %0
                175   	lcall ?Display_BCD
                176   	pop ar0
                177   endmac
03A1            178   
03A1            179   ?Display_BCD:
03A1 C0E0       180            push acc
03A3            181            ; Write most significant digit
03A3 E8         182            mov a, r0
03A4 C4         183            swap a
03A5 540F       184            anl a, #0fh
03A7 4430       185            orl a, #30h
03A9 120352     186            lcall ?WriteData
03AC            187            ; write least significant digit
03AC E8         188            mov a, r0
03AD 540F       189            anl a, #0fh
03AF 4430       190            orl a, #30h
03B1 120352     191            lcall ?WriteData
03B4 D0E0       192            pop acc
03B6 22         193            ret
03B7            194   
03B7            195   ;------------------------------------;
03B7            196   ; Display a char in the LCD          ;
03B7            197   ;------------------------------------;
                198   Display_char mac
                199   	push acc
                200   	mov a, %0
                201   	lcall ?WriteData
                202   	pop acc
                203   endmac
03B7            204   
                 -1   	$include(keypad_lib_3.asm)
03B7              1   
03B7              2   CSEG
03B7              3   
03B7              4   ;--------------------------------------------------
03B7              5   ; Lookup table for 7-segment display patterns (common anode)
03B7              6   ; Index 0-F = segment pattern
03B7              7   ;--------------------------------------------------
03B7              8   
03B7              9   myLUT:
03B7 C0F9A4B0    10       DB 0C0h, 0F9h, 0A4h, 0B0h, 099h        ; digits 0-4
     99
03BC 9282F880    11       DB 092h, 082h, 0F8h, 080h, 090h        ; digits 5-9
     90
03C1 8883C6A1    12       DB 088h, 083h, 0C6h, 0A1h, 086h, 08Eh  ; A-F
     868E
03C7             13   
03C7             14   ;--------------------------------------------------
03C7             15   ; Macro: showBCD
03C7             16   ; Input : one byte containing two BCD digits
03C7             17   ; Output: two 7-seg displays
03C7             18   ;   %0 = bcd byte
03C7             19   ;   %1 = HEX low
03C7             20   ;   %2 = HEX high
03C7             21   ;--------------------------------------------------
03C7             22   
                 23   showBCD MAC
                 24       ; ---- Display lower nibble (LSD) ----
                 25       mov  A, %0           ; Load BCD byte
                 26       anl  A, #0Fh         ; Keep lower 4 bits
                 27       movc A, @A+dptr      ; Convert using LUT
                 28       mov  %1, A           ; Output to first HEX display
                 29   
                 30       ; ---- Display upper nibble (MSD) ----
                 31       mov  A, %0
                 32       swap A               ; Swap nibbles
                 33       anl  A, #0Fh
                 34       movc A, @A+dptr
                 35       mov  %2, A           ; Output to second HEX display
                 36   ENDMAC
03C7             37   
03C7             38   
03C7             39   ;--------------------------------------------------
03C7             40   ; Display routine - show BCD number on HEX displays
03C7             41   ; KEY3: 0 = show high digits, 1 = show low digits
03C7             42   ; LEDRA.7: overflow indicator if bcd+3 or bcd+4 != 0
03C7             43   ;--------------------------------------------------
03C7             44   
03C7             45   Display:
03C7 9003B7      46       mov dptr, #myLUT     ; Point to lookup table
03CA             47   
03CA             48       ; If digits 10-7 (bcd+3 and bcd+4) are NOT zero
03CA             49       ; turn ON LEDRA.7 as overflow indicator
03CA             50   
03CA E53B        51       mov A, bcd+3
03CC 453C        52       orl A, bcd+4
03CE 6004        53       jz  Display_L1
03D0 D2EF        54       setb LEDRA.7         ; Alert LED on
03D2 8002        55       sjmp Display_L2
03D4             56   Display_L1:
03D4 C2EF        57       clr LEDRA.7          ; Alert LED off
03D6             58   Display_L2:
03D6             59   
03D6             60       ; If KEY3 pressed (assuming active low) show HIGH digits
03D6             61       ; Otherwise show LOW digits
03D6             62   
03D6 30FB2F      63       jnb KEY.3, Display_high_digits
03D9             64   
03D9             65       ; Show lower 6 digits
03D9             66       ; ---- Display lower nibble (LSD) ----
03D9 E538        66       mov  A, bcd+0           ; Load BCD byte
03DB 540F        66       anl  A, #0Fh         ; Keep lower 4 bits
03DD 93          66       movc A, @A+dptr      ; Convert using LUT
03DE F591        66       mov  HEX0, A           ; Output to first HEX display
03E0             66   
03E0             66       ; ---- Display upper nibble (MSD) ----
03E0 E538        66       mov  A, bcd+0
03E2 C4          66       swap A               ; Swap nibbles
03E3 540F        66       anl  A, #0Fh
03E5 93          66       movc A, @A+dptr
03E6 F592        66       mov  HEX1, A           ; Output to second HEX display
03E8             67       ; ---- Display lower nibble (LSD) ----
03E8 E539        67       mov  A, bcd+1           ; Load BCD byte
03EA 540F        67       anl  A, #0Fh         ; Keep lower 4 bits
03EC 93          67       movc A, @A+dptr      ; Convert using LUT
03ED F593        67       mov  HEX2, A           ; Output to first HEX display
03EF             67   
03EF             67       ; ---- Display upper nibble (MSD) ----
03EF E539        67       mov  A, bcd+1
03F1 C4          67       swap A               ; Swap nibbles
03F2 540F        67       anl  A, #0Fh
03F4 93          67       movc A, @A+dptr
03F5 F594        67       mov  HEX3, A           ; Output to second HEX display
03F7             68       ; ---- Display lower nibble (LSD) ----
03F7 E53A        68       mov  A, bcd+2           ; Load BCD byte
03F9 540F        68       anl  A, #0Fh         ; Keep lower 4 bits
03FB 93          68       movc A, @A+dptr      ; Convert using LUT
03FC F58E        68       mov  HEX4, A           ; Output to first HEX display
03FE             68   
03FE             68       ; ---- Display upper nibble (MSD) ----
03FE E53A        68       mov  A, bcd+2
0400 C4          68       swap A               ; Swap nibbles
0401 540F        68       anl  A, #0Fh
0403 93          68       movc A, @A+dptr
0404 F58F        68       mov  HEX5, A           ; Output to second HEX display
0406 8024        69       sjmp Display_end
0408             70   
0408             71   Display_high_digits:
0408             72       ; Show upper 4 digits
0408             73       ; ---- Display lower nibble (LSD) ----
0408 E53B        73       mov  A, bcd+3           ; Load BCD byte
040A 540F        73       anl  A, #0Fh         ; Keep lower 4 bits
040C 93          73       movc A, @A+dptr      ; Convert using LUT
040D F591        73       mov  HEX0, A           ; Output to first HEX display
040F             73   
040F             73       ; ---- Display upper nibble (MSD) ----
040F E53B        73       mov  A, bcd+3
0411 C4          73       swap A               ; Swap nibbles
0412 540F        73       anl  A, #0Fh
0414 93          73       movc A, @A+dptr
0415 F592        73       mov  HEX1, A           ; Output to second HEX display
0417             74       ; ---- Display lower nibble (LSD) ----
0417 E53C        74       mov  A, bcd+4           ; Load BCD byte
0419 540F        74       anl  A, #0Fh         ; Keep lower 4 bits
041B 93          74       movc A, @A+dptr      ; Convert using LUT
041C F593        74       mov  HEX2, A           ; Output to first HEX display
041E             74   
041E             74       ; ---- Display upper nibble (MSD) ----
041E E53C        74       mov  A, bcd+4
0420 C4          74       swap A               ; Swap nibbles
0421 540F        74       anl  A, #0Fh
0423 93          74       movc A, @A+dptr
0424 F594        74       mov  HEX3, A           ; Output to second HEX display
0426             75   
0426             76       ; Blank remaining displays
0426 758EFF      77       mov HEX4, #0FFh
0429 758FFF      78       mov HEX5, #0FFh
042C             79   
042C             80   Display_end:
042C 22          81       ret
042D             82   
042D             83   ;--------------------------------------------------
042D             84   ; Macro: Rotate Left through Carry
042D             85   ;--------------------------------------------------
042D             86   
                 87   MYRLC MAC
                 88       mov A, %0
                 89       rlc A
                 90       mov %0, A
                 91   ENDMAC
042D             92   
042D             93   ;--------------------------------------------------
042D             94   ; Shift all BCD digits LEFT by 4 bits
042D             95   ; Makes room for new digit in LSD (R7)
042D             96   ;--------------------------------------------------
042D             97   
042D             98   Shift_Digits_Left:
042D 7804        99       mov R0, #4           ; 4 bit shifts (one nibble)
042F            100   
042F            101   Shift_Digits_Left_L0:
042F C3         102       clr C                ; Clear carry before shift
0430 E538       103       mov A, bcd+0
0432 33         103       rlc A
0433 F538       103       mov bcd+0, A
0435 E539       104       mov A, bcd+1
0437 33         104       rlc A
0438 F539       104       mov bcd+1, A
043A E53A       105       mov A, bcd+2
043C 33         105       rlc A
043D F53A       105       mov bcd+2, A
043F E53B       106       mov A, bcd+3
0441 33         106       rlc A
0442 F53B       106       mov bcd+3, A
0444 E53C       107       mov A, bcd+4
0446 33         107       rlc A
0447 F53C       107       mov bcd+4, A
0449 D8E4       108       djnz R0, Shift_Digits_Left_L0
044B            109   
044B            110       ; Insert new digit from R7 into lowest nibble safely
044B            111       ; Keep upper nibble of bcd+0 unchanged
044B 5338F0     112       anl  bcd+0, #0F0h    ; clear lower nibble
044E EF         113       mov  A, R7
044F 540F       114       anl  A, #0Fh         ; ensure only 0-F
0451 4238       115       orl  bcd+0, A
0453 22         116       ret
0454            117   
0454            118   ;--------------------------------------------------
0454            119   ; Macro: Rotate Right through Carry
0454            120   ;--------------------------------------------------
0454            121   
                122   MYRRC MAC
                123       mov A, %0
                124       rrc A
                125       mov %0, A
                126   ENDMAC
0454            127   
0454            128   ;--------------------------------------------------
0454            129   ; Shift digits RIGHT by 4 bits
0454            130   ; Used for BACKSPACE (delete last digit)
0454            131   ;--------------------------------------------------
0454            132   
0454            133   Shift_Digits_Right:
0454 7804       134       mov R0, #4
0456            135   
0456            136   Shift_Digits_Right_L0:
0456 C3         137       clr C
0457 E53C       138       mov A, bcd+4
0459 13         138       rrc A
045A F53C       138       mov bcd+4, A
045C E53B       139       mov A, bcd+3
045E 13         139       rrc A
045F F53B       139       mov bcd+3, A
0461 E53A       140       mov A, bcd+2
0463 13         140       rrc A
0464 F53A       140       mov bcd+2, A
0466 E539       141       mov A, bcd+1
0468 13         141       rrc A
0469 F539       141       mov bcd+1, A
046B E538       142       mov A, bcd+0
046D 13         142       rrc A
046E F538       142       mov bcd+0, A
0470 D8E4       143       djnz R0, Shift_Digits_Right_L0
0472 22         144       ret
0473            145   
0473            146   
0473            147   ;--------------------------------------------------
0473            148   ; 25 ms delay (software debounce)
0473            149   ;--------------------------------------------------
0473            150   
0473            151   Wait25ms:
0473 780F       152       mov R0, #15
0475 794A       153   L6: mov R1, #74
0477 7AFA       154   L5: mov R2, #250
0479 DAFE       155   L4: djnz R2, L4
047B D9FA       156       djnz R1, L5
047D D8F6       157       djnz R0, L6
047F 22         158       ret
0480            159   
0480            160   
0480            161   ;--------------------------------------------------
0480            162   ; Helper routines for parameter storage
0480            163   ; Each parameter value lives in bcd+0..bcd+1
0480            164   ; active_param: 0=A, 1=B, 2=C, 3=D
0480            165   ;--------------------------------------------------
0480            166   
0480            167   ; Save current BCD (bcd+0..bcd+1) into active parameter
0480            168   Save_Current_BCD_Into_Param:
0480 E564       169       mov A, active_param
0482 B40007     170       cjne A, #0, Save_NotA
0485            171       ; A: soak_temp
0485 853858     172       mov soak_temp+0, bcd+0
0488 853959     173       mov soak_temp+1, bcd+1
048B 22         174       ret
048C            175   Save_NotA:
048C B40107     176       cjne A, #1, Save_NotB
048F            177       ; B: soak_time
048F 85385A     178       mov soak_time+0, bcd+0
0492 85395B     179       mov soak_time+1, bcd+1
0495 22         180       ret
0496            181   Save_NotB:
0496 B40207     182       cjne A, #2, Save_NotC
0499            183       ; C: reflow_temp
0499 85385E     184       mov reflow_temp+0, bcd+0
049C 85395F     185       mov reflow_temp+1, bcd+1
049F 22         186       ret
04A0            187   Save_NotC:
04A0            188       ; D: reflow_time (default case)
04A0 853860     189       mov reflow_time+0, bcd+0
04A3 853961     190       mov reflow_time+1, bcd+1
04A6 22         191       ret
04A7            192   
04A7            193   
04A7            194   ; Load active parameter into BCD (bcd+0..bcd+1)
04A7            195   ; Clear the higher digits.
04A7            196   Load_Param_Into_BCD:
04A7 753A00     197       mov bcd+2, #00h
04AA 753B00     198       mov bcd+3, #00h
04AD 753C00     199       mov bcd+4, #00h
04B0            200   
04B0 E564       201       mov A, active_param
04B2 B40007     202       cjne A, #0, Load_NotA
04B5            203       ; A: soak_temp
04B5 855838     204       mov bcd+0, soak_temp
04B8 855939     205       mov bcd+1, soak_temp+1
04BB 22         206       ret
04BC            207   Load_NotA:
04BC B40107     208       cjne A, #1, Load_NotB
04BF            209       ; B: soak_time
04BF 855A38     210       mov bcd+0, soak_time
04C2 855B39     211       mov bcd+1, soak_time+1
04C5 22         212       ret
04C6            213   Load_NotB:
04C6 B40207     214       cjne A, #2, Load_NotC
04C9            215       ; C: reflow_temp
04C9 855E38     216       mov bcd+0, reflow_temp
04CC 855F39     217       mov bcd+1, reflow_temp+1
04CF 22         218       ret
04D0            219   Load_NotC:
04D0            220       ; D: reflow_time (default)
04D0 856038     221       mov bcd+0, reflow_time
04D3 856139     222       mov bcd+1, reflow_time+1
04D6 22         223       ret
04D7            224   
04D7            225   
04D7            226   ;--------------------------------------------------
04D7            227   ; Macro: Check one keypad column
04D7            228   ; If pressed -> R7 = key value, C=1, jump to Key_Found
04D7            229   ; %0 = column bit, %1 = key code (immediate)
04D7            230   ;--------------------------------------------------
04D7            231   
                232   CHECK_COLUMN MAC
                233       jb  %0, CHECK_COL_%M     ; if column=1 -> no key here -> skip
                234       mov R7, %1               ; store key code
                235       jnb %0, $                ; wait until key is released
                236       setb C                   ; mark "key found"
                237       ljmp Key_Found           ; use long jump instead of short
                238   CHECK_COL_%M:
                239   ENDMAC
04D7            240   
04D7            241   
04D7            242   ;--------------------------------------------------
04D7            243   ; Configure GPIO directions for keypad
04D7            244   ;--------------------------------------------------
04D7            245   
04D7            246   Configure_Keypad_Pins:
04D7 439B54     247       orl P1MOD, #01010100b    ; Rows as output on P1
04DA 439C01     248       orl P2MOD, #00000001b
04DD 539CAB     249       anl P2MOD, #10101011b    ; Columns as input on P2
04E0 539DFE     250       anl P3MOD, #11111110b    ; Column on P3.0 input
04E3 22         251       ret
04E4            252   
04E4            253   ; Pin definitions for keypad
04E4            254   ROW1 EQU P1.2
04E4            255   ROW2 EQU P1.4
04E4            256   ROW3 EQU P1.6
04E4            257   ROW4 EQU P2.0
04E4            258   
04E4            259   COL1 EQU P2.2
04E4            260   COL2 EQU P2.4
04E4            261   COL3 EQU P2.6
04E4            262   COL4 EQU P3.0
04E4            263   
04E4            264   ;--------------------------------------------------
04E4            265   ; Keypad scanning routine
04E4            266   ; Output:
04E4            267   ;   C = 1 -> numeric key pressed, code in R7 (0-9, maybe E/F)
04E4            268   ;   C = 0 -> no digit (no key, mode key, or backspace)
04E4            269   ;--------------------------------------------------
04E4            270   
04E4            271   Keypad:
04E4            272   
04E4            273       ; KEY1 acts as BACKSPACE / ERASE
04E4            274   
04E4 20F90E     275       jb  KEY.1, keypad_L0     ; if KEY1=1 (not pressed) -> skip
04E7 120473     276       lcall Wait25ms
04EA 20F908     277       jb  KEY.1, keypad_L0     ; if bounced back high, skip
04ED 30F9FD     278       jnb KEY.1, $             ; wait for release (KEY1 low while pressed)
04F0 120454     279       lcall Shift_Digits_Right ; delete LSD for active parameter
04F3 C3         280       clr C                    ; no digit returned
04F4 22         281       ret
04F5            282   
04F5            283   keypad_L0:
04F5            284   
04F5            285       ; Drive all rows LOW - check if any column LOW
04F5            286   
04F5 C292       287       clr ROW1
04F7 C294       288       clr ROW2
04F9 C296       289       clr ROW3
04FB C2A0       290       clr ROW4
04FD            291   
04FD A2A2       292       mov C, COL1
04FF 82A4       293       anl C, COL2
0501 82A6       294       anl C, COL3
0503 82B0       295       anl C, COL4
0505 5002       296       jnc Keypad_Debounce      ; if any column low -> possible key
0507 C3         297       clr C
0508 22         298       ret
0509            299   
0509            300   Keypad_Debounce:
0509            301       ; Wait and check again to avoid bouncing
0509 120473     302       lcall Wait25ms
050C            303   
050C A2A2       304       mov C, COL1
050E 82A4       305       anl C, COL2
0510 82A6       306       anl C, COL3
0512 82B0       307       anl C, COL4
0514 5002       308       jnc Keypad_Key_Code
0516 C3         309       clr C
0517 22         310       ret
0518            311   
0518            312   Keypad_Key_Code:
0518            313       ; Prepare to scan each row individually
0518 D292       314       setb ROW1
051A D294       315       setb ROW2
051C D296       316       setb ROW3
051E D2A0       317       setb ROW4
0520            318   
0520            319       ; SW0 selects layout orientation
0520 30E803     320       jnb SWA.0, keypad_default
0523 0205F8     321       ljmp keypad_90deg
0526            322   
