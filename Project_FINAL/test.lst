06CA            405   
06CA            406   
06CA            407   ;--------------------------------------------------
06CA            408   ; Key_Found:
06CA            409   ;   R7 = key code (0-F), C = 1 when we get here.
06CA            410   ;   A/B/C/D (0Ah-0Dh) -> mode select
06CA            411   ;   * (0Eh)           -> delete / backspace one digit
06CA            412   ;   # (0Fh)           -> clear all digits
06CA            413   ;   others (0-9, maybe E/F) -> digit
06CA            414   ;--------------------------------------------------
06CA            415   
06CA            416   Key_Found:
06CA EF         417       mov A, R7
06CB            418   
06CB            419       ; --- Mode A (soak temperature) ---
06CB B40A0B     420       cjne A, #0Ah, KF_CheckB
06CE 120480     421       lcall Save_Current_BCD_Into_Param
06D1 756400     422       mov   active_param, #0       ; A: soak_temp
06D4 1204A7     423       lcall Load_Param_Into_BCD
06D7 C3         424       clr C                        ; do not treat as digit
06D8 22         425       ret
06D9            426   
06D9            427   KF_CheckB:
06D9            428       ; --- Mode B (soak time) ---
06D9 B40B0B     429       cjne A, #0Bh, KF_CheckC
06DC 120480     430       lcall Save_Current_BCD_Into_Param
06DF 756401     431       mov   active_param, #1       ; B: soak_time
06E2 1204A7     432       lcall Load_Param_Into_BCD
06E5 C3         433       clr C
06E6 22         434       ret
06E7            435   
06E7            436   KF_CheckC:
06E7            437       ; --- Mode C (reflow temperature) ---
06E7 B40C0B     438       cjne A, #0Ch, KF_CheckD
06EA 120480     439       lcall Save_Current_BCD_Into_Param
06ED 756402     440       mov   active_param, #2       ; C: reflow_temp
06F0 1204A7     441       lcall Load_Param_Into_BCD
06F3 C3         442       clr C
06F4 22         443       ret
06F5            444   
06F5            445   KF_CheckD:
06F5            446       ; --- Mode D (reflow time) ---
06F5 B40D0B     447       cjne A, #0Dh, KF_CheckStar
06F8 120480     448       lcall Save_Current_BCD_Into_Param
06FB 756403     449       mov   active_param, #3       ; D: reflow_time
06FE 1204A7     450       lcall Load_Param_Into_BCD
0701 C3         451       clr C
0702 22         452       ret
0703            453   
0703            454   KF_CheckStar:
0703            455       ; --- '*' key (code 0Eh) -> delete / backspace ---
0703 B40E05     456       cjne A, #0Eh, KF_CheckHash
0706            457       ; Backspace = shift digits right by 1 digit
0706 120454     458       lcall Shift_Digits_Right
0709 C3         459       clr C                        ; no new digit for main loop
070A 22         460       ret
070B            461   
070B            462   KF_CheckHash:
070B            463       ; --- '#' key (code 0Fh) -> clear ---
070B B40F0D     464       cjne A, #0Fh, KF_Digit
070E            465       ; Clear all BCD digits for current parameter
070E E4         466       clr A
070F F538       467       mov bcd+0, A
0711 F539       468       mov bcd+1, A
0713 F53A       469       mov bcd+2, A
0715 F53B       470       mov bcd+3, A
0717 F53C       471       mov bcd+4, A
0719 C3         472       clr C                        ; no digit to insert
071A 22         473       ret
071B            474   
071B            475   KF_Digit:
071B            476       ; Not A/B/C/D/*/# -> treat as numeric digit key
071B            477       ; R7 holds the digit, Carry = 1 -> main loop will append it
071B 22         478       ret
071C            479   
071C            480   
071C            481   END
                 -1   $include(temperature_lib.asm)
