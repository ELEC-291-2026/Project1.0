0000              1   ; Simple_Rhythm_DE10Lite.asm:
0000              2   ; Plays C D E F G A B C once (no loop)
0000              3   ; Press KEY.1 to play again
0000              4   ;
                  6   $LIST
0000              8   
0000              9   CLK           EQU 33333333 ; Microcontroller system crystal frequency in Hz
0000             10   TIMER2_RATE   EQU 1000     ; 1000Hz, for a timer tick of 1ms
0000             11   TIMER2_RELOAD EQU ((65536-(CLK/(12*TIMER2_RATE))))
0000             12   
0000             13   SOUND_OUT     equ P0.4
0000             14   
0000             15   ; Reset vector
0000             16   org 0x0000
0000 020140      17       ljmp main
0003             18   
0003             19   ; External interrupt 0 vector (not used in this code)
0003             20   org 0x0003
0003 32          21            reti
0004             22   
0004             23   ; Timer/Counter 0 overflow interrupt vector
000B             24   org 0x000B
000B 0200E7      25            ljmp Timer0_ISR
000E             26   
000E             27   ; External interrupt 1 vector (not used in this code)
0013             28   org 0x0013
0013 32          29            reti
0014             30   
0014             31   ; Timer/Counter 1 overflow interrupt vector (not used in this code)
001B             32   org 0x001B
001B 32          33            reti
001C             34   
001C             35   ; Serial port receive/transmit interrupt vector (not used in this code)
0023             36   org 0x0023 
0023 32          37            reti
0024             38            
0024             39   ; Timer/Counter 2 overflow interrupt vector
002B             40   org 0x002B
002B 020109      41            ljmp Timer2_ISR
002E             42   
002E             43   ; Variables
0030             44   dseg at 0x30
0030             45   Count1ms:     ds 2   ; 1ms counter for Timer2
0032             46   song_idx:     ds 1   ; which note we're on (0-7)
0033             47   note_ms:      ds 2   ; how long current note has played (ms)
0035             48   tone_rh:      ds 1   ; Timer0 reload high byte for current note
0036             49   tone_rl:      ds 1   ; Timer0 reload low byte for current note
0037             50   note_dur_l:   ds 1   ; Current note duration low byte
0038             51   note_dur_h:   ds 1   ; Current note duration high byte
0039             52   
0000             53   bseg
0000             54   song_playing: dbit 1 ; Flag: is song currently playing?
0001             55   
002E             56   cseg
002E             57   
002E             58   ; -------- Note reload values (CLK = 33,333,333 Hz, prescaler = 12) --------
002E             59   ; Timer0 overflow rate = 2*freq (because we toggle pin each overflow)
002E             60   
002E             61   R_C5  EQU 0F5A2h   ; 523.25 Hz (Do)
002E             62   R_Cs5 EQU 0F63Fh   ; 622.25 Hz (Do Sharp)
002E             63   R_D5  EQU 0F6C3h   ; 587.33 Hz (Re)
002E             64   R_Ds5 EQU 0F74Dh   ; 739.99 Hz (Dsharp)
002E             65   R_E5  EQU 0F7C5h   ; 659.26 Hz (Mi)
002E             66   R_F5  EQU 0F83Bh   ; 698.46 Hz (Fa)
002E             67   R_Fs5 EQU 0F8ACh   ; 739.99 Hz (Fa Sharp)
002E             68   R_G5  EQU 0F914h   ; 783.99 Hz (Sol)
002E             69   R_Gs5 EQU 0F97Bh   ; 830.61 Hz (Sol Sharp)
002E             70   R_A5  EQU 0F9D6h   ; 880.00 Hz (La)
002E             71   R_As5 EQU 0FA31h   ; 932.33 Hz (La Sharp)
002E             72   R_B5  EQU 0FA82h   ; 987.77 Hz (Si)
002E             73   R_C6  EQU 0FAD0h   ; 1046.50 Hz (Do - higher octave)
002E             74   R_Cs6 EQU 0FB1Fh   ; 1108.73 Hz
002E             75   R_D6  EQU 0FB61h   ; 1174.66 Hz
002E             76   R_Ds6 EQU 0FBA7h   ; 1244.51 Hz
002E             77   R_E6  EQU 0FBE3h   ; 1318.51 Hz
002E             78   R_F6  EQU 0FC1Dh   ; 1396.91 Hz
002E             79   R_Fs6 EQU 0FC56h   ; 1479.98 Hz
002E             80   R_G6  EQU 0FC8Ah   ; 1567.98 Hz
002E             81   R_Gs6 EQU 0FCBDh   ; 1661.22 Hz
002E             82   R_A6  EQU 0FCEBh   ; 1760.00 Hz
002E             83   R_As6 EQU 0FD19h   ; 1864.66 Hz
002E             84   R_B6  EQU 0FD41h   ; 1975.53 Hz
002E             85   R_C7  EQU 0FD68h   ; 2093.00 Hz
002E             86   No_Note  EQU 0000h   ; 000 Hz
002E             87   
002E             88   
002E             89   SIMPLE_RHYTHM:
002E             90   
002E F5A200FA    91       DW R_C5, 250    
0032 F63F00FA    92       DW R_Cs5, 250   
0036 F6C300FA    93       DW R_D5, 250   
003A F74D00FA    94       DW R_Ds5, 250  
003E F7C500FA    95       DW R_E5, 250  
0042 F83B00FA    96       DW R_F5, 250    
0046 F8AC00FA    97       DW R_Fs5, 250  
004A F91400FA    98       DW R_G5, 250     
004E F97B00FA    99       DW R_Gs5,  250   
0052 F9D600FA   100       DW R_A5, 250    
0056 FA3100FA   101       DW R_As5, 250 
005A FA8200FA   102       DW R_B5, 250 
005E 000000FA   103       DW No_Note, 250
0062 000000FA   104       DW No_Note, 250
0066 FAD000FA   105       DW R_C6, 250  
006A FB1F00FA   106       DW R_Cs6, 250  
006E FB6100FA   107       DW R_D6, 250    
0072 FBA700FA   108       DW R_Ds6, 250     
0076 FBE300FA   109       DW R_E6, 250   
007A FC1D00FA   110       DW R_F6, 250    
007E FC5600FA   111       DW R_Fs6, 250 
0082 FC8A00FA   112       DW R_G6, 250    
0086 FCBD00FA   113       DW R_Gs6,250  
008A FCEB00FA   114       DW R_A6, 250    
008E FD1900FA   115       DW R_As6, 250 
0092 FD4100FA   116       DW R_B6, 250 
0096            117       
0096            118   
0096            119   SONG_LEN EQU 24    ; number of notes
0096            120   
0096            121   ;---------------------------------;
0096            122   ; Load current note from song     ;
0096            123   ; Input: song_idx (0-7)          ;
0096            124   ;---------------------------------;
0096            125   Load_Song_Note:
0096 C0E0       126       push acc
0098 C083       127       push dph
009A C082       128       push dpl
009C            129       
009C            130       ; Each note is 4 bytes: 2 for reload, 2 for duration
009C            131       ; Offset = song_idx * 4
009C E532       132       mov a, song_idx
009E 23         133       rl a              ; *2
009F 23         134       rl a              ; *4
00A0 54FC       135       anl a, #0FCh      ; Ensure it's a multiple of 4
00A2            136       
00A2 90002E     137       mov dptr, #SIMPLE_RHYTHM
00A5            138       
00A5            139       ; Get reload high byte
00A5 93         140       movc a, @a+dptr
00A6 F535       141       mov tone_rh, a
00A8            142       
00A8            143       ; Get reload low byte
00A8 E532       144       mov a, song_idx
00AA 23         145       rl a
00AB 23         146       rl a
00AC 54FC       147       anl a, #0FCh
00AE 04         148       inc a
00AF 93         149       movc a, @a+dptr
00B0 F536       150       mov tone_rl, a
00B2            151       
00B2            152       ; Get duration low byte
00B2 E532       153       mov a, song_idx
00B4 23         154       rl a
00B5 23         155       rl a
00B6 54FC       156       anl a, #0FCh
00B8 2402       157       add a, #2
00BA 93         158       movc a, @a+dptr
00BB F538       159       mov note_dur_h, a
00BD            160       
00BD            161       ; Get duration high byte
00BD E532       162       mov a, song_idx
00BF 23         163       rl a
00C0 23         164       rl a
00C1 54FC       165       anl a, #0FCh
00C3 2403       166       add a, #3
00C5 93         167       movc a, @a+dptr
00C6 F537       168       mov note_dur_l, a
00C8            169       
00C8            170       ; Reset note timing counter
00C8 E4         171       clr a
00C9 F533       172       mov note_ms+0, a
00CB F534       173       mov note_ms+1, a
00CD            174       
00CD            175       ; Load timer and start
00CD 85358C     176       mov TH0, tone_rh
00D0 85368A     177       mov TL0, tone_rl
00D3 D28C       178       setb TR0              ; Start Timer0
00D5            179       
00D5 D082       180       pop dpl
00D7 D083       181       pop dph
00D9 D0E0       182       pop acc
00DB 22         183       ret
00DC            184   
00DC            185   ;---------------------------------;
00DC            186   ; Routine to initialize the ISR   ;
00DC            187   ; for timer 0                     ;
00DC            188   ;---------------------------------;
00DC            189   Timer0_Init:
00DC E589       190            mov a, TMOD
00DE 54F0       191            anl a, #0xf0 ; Clear the bits for timer 0
00E0 4401       192            orl a, #0x01 ; Configure timer 0 as 16-timer
00E2 F589       193            mov TMOD, a
00E4            194            
00E4            195            ; Don't start timer yet - Load_Song_Note will do it
00E4 D2A9       196       setb ET0  ; Enable timer 0 interrupt
00E6 22         197            ret
00E7            198   
00E7            199   ;---------------------------------;
00E7            200   ; ISR for timer 0.                ;
00E7            201   ; Generates square wave for tone  ;
00E7            202   ;---------------------------------;
00E7            203   Timer0_ISR:
00E7            204            ; Reload timer with current note's value
00E7 85358C     205            mov TH0, tone_rh
00EA 85368A     206            mov TL0, tone_rl
00ED B284       207            cpl SOUND_OUT ; Toggle speaker
00EF 32         208            reti
00F0            209   
00F0            210   ;---------------------------------;
00F0            211   ; Routine to initialize the ISR   ;
00F0            212   ; for timer 2                     ;
00F0            213   ;---------------------------------;
00F0            214   Timer2_Init:
00F0 75C800     215            mov T2CON, #0 ; Stop timer/counter.  Autoreload mode.
00F3 75CDF5     216            mov TH2, #high(TIMER2_RELOAD)
00F6 75CC27     217            mov TL2, #low(TIMER2_RELOAD)
00F9            218            ; Set the reload value
00F9 75CBF5     219            mov RCAP2H, #high(TIMER2_RELOAD)
00FC 75CA27     220            mov RCAP2L, #low(TIMER2_RELOAD)
00FF            221            ; Init One millisecond interrupt counter
00FF E4         222            clr a
0100 F530       223            mov Count1ms+0, a
0102 F531       224            mov Count1ms+1, a
0104            225            ; Enable the timer and interrupts
0104 D2AD       226       setb ET2  ; Enable timer 2 interrupt
0106 D2CA       227       setb TR2  ; Enable timer 2
0108 22         228            ret
0109            229   
0109            230   ;---------------------------------;
0109            231   ; ISR for timer 2 (1ms tick)      ;
0109            232   ; Handles note timing             ;
0109            233   ;---------------------------------;
0109            234   Timer2_ISR:
0109 C2CF       235            clr TF2  ; Timer 2 doesn't clear TF2 automatically
010B B291       236            cpl P1.1 ; Debug: Check interrupt rate with oscilloscope
010D            237            
010D C0E0       238            push acc
010F C0D0       239            push psw
0111            240            
0111            241            ; Only process if song is playing
0111 300027     242            jnb song_playing, Timer2_ISR_done
0114            243            
0114            244            ; Increment note duration counter
0114 0533       245            inc note_ms+0
0116 E533       246            mov a, note_ms+0
0118 7002       247            jnz Check_Note_Duration
011A 0534       248            inc note_ms+1
011C            249            
011C            250   Check_Note_Duration:
011C            251            ; Check if note duration has elapsed
011C E533       252            mov a, note_ms+0
011E B5371A     253            cjne a, note_dur_l, Timer2_ISR_done
0121 E534       254            mov a, note_ms+1
0123 B53815     255            cjne a, note_dur_h, Timer2_ISR_done
0126            256            
0126            257            ; Note duration elapsed - advance to next note
0126 E532       258            mov a, song_idx
0128 04         259            inc a
0129            260            
0129            261            ; Check if song is finished
0129 B4180A     262            cjne a, #SONG_LEN, Next_Note_OK
012C            263            
012C            264            ; *** SONG FINISHED - STOP PLAYING ***
012C C200       265            clr song_playing
012E C28C       266            clr TR0               ; Stop Timer0
0130 C284       267            clr SOUND_OUT         ; Turn off speaker
0132 D2E8       268            setb LEDRA.0          ; Turn on LED to show song finished
0134 8005       269            sjmp Timer2_ISR_done
0136            270            
0136            271   Next_Note_OK:
0136 F532       272            mov song_idx, a
0138 120096     273            lcall Load_Song_Note
013B            274            
013B            275   Timer2_ISR_done:
013B D0D0       276            pop psw
013D D0E0       277            pop acc
013F 32         278            reti
0140            279   
0140            280   ;---------------------------------;
0140            281   ; Main program. Includes hardware ;
0140            282   ; initialization and 'forever'    ;
0140            283   ; loop.                           ;
0140            284   ;---------------------------------;
0140            285   main:
0140            286            ; Initialization
0140 75817F     287       mov SP, #0x7F
0143            288       
0143            289       ; Configure I/O pins
0143 759A10     290       mov P0MOD, #00010000b ; P0.4 (SOUND_OUT) is output
0146 759B02     291       mov P1MOD, #00000010b ; P1.1 is output (debug)
0149            292       
0149            293       ; Turn off all the LEDs
0149 75E800     294       mov LEDRA, #0
014C 759500     295       mov LEDRB, #0
014F            296       
014F            297       ; Initialize timers
014F 1200DC     298       lcall Timer0_Init
0152 1200F0     299       lcall Timer2_Init
0155            300       
0155            301       ; Initialize song (but don't play yet)
0155 753200     302       mov song_idx, #0
0158 C200       303       clr song_playing      ; Wait for button press
015A            304       
015A D2AF       305       setb EA   ; Enable Global interrupts
015C            306            
015C            307            ; Main loop - wait for button to play
015C            308   loop:
015C            309            ; Press KEY.1 to play the rhythm
015C 20F9FD     310            jb KEY.1, loop
015F 30F9FD     311            jnb KEY.1, $          ; Wait for release
0162            312            
0162            313            ; Only play if not already playing
0162 2000F7     314            jb song_playing, loop
0165            315            
0165            316            ; Start playing from beginning
0165 C2E8       317            clr LEDRA.0           ; Turn off LED
0167 753200     318            mov song_idx, #0
016A 120096     319            lcall Load_Song_Note
016D D200       320            setb song_playing
016F            321            
016F 80EB       322            sjmp loop
0171            323   
0171            324   EN
