0000              1   ; Simple_Rhythm_DE10Lite.asm:
0000              2   ; Plays C D E F G A B C once (no loop)
0000              3   ; Press KEY.1 to play again
0000              4   ;
                  6   $LIST
0000              8   
0000              9   CLK           EQU 33333333 ; Microcontroller system crystal frequency in Hz
0000             10   TIMER2_RATE   EQU 1000     ; 1000Hz, for a timer tick of 1ms
0000             11   TIMER2_RELOAD EQU ((65536-(CLK/(12*TIMER2_RATE))))
0000             12   
0000             13   SOUND_OUT     equ P0.4
0000             14   
0000             15   ; Reset vector
0000             16   org 0x0000
0000 0200F8      17       ljmp main
0003             18   
0003             19   ; External interrupt 0 vector (not used in this code)
0003             20   org 0x0003
0003 32          21            reti
0004             22   
0004             23   ; Timer/Counter 0 overflow interrupt vector
000B             24   org 0x000B
000B 02009F      25            ljmp Timer0_ISR
000E             26   
000E             27   ; External interrupt 1 vector (not used in this code)
0013             28   org 0x0013
0013 32          29            reti
0014             30   
0014             31   ; Timer/Counter 1 overflow interrupt vector (not used in this code)
001B             32   org 0x001B
001B 32          33            reti
001C             34   
001C             35   ; Serial port receive/transmit interrupt vector (not used in this code)
0023             36   org 0x0023 
0023 32          37            reti
0024             38            
0024             39   ; Timer/Counter 2 overflow interrupt vector
002B             40   org 0x002B
002B 0200C1      41            ljmp Timer2_ISR
002E             42   
002E             43   ; Variables
0030             44   dseg at 0x30
0030             45   Count1ms:     ds 2   ; 1ms counter for Timer2
0032             46   song_idx:     ds 1   ; which note we're on (0-7)
0033             47   note_ms:      ds 2   ; how long current note has played (ms)
0035             48   tone_rh:      ds 1   ; Timer0 reload high byte for current note
0036             49   tone_rl:      ds 1   ; Timer0 reload low byte for current note
0037             50   note_dur_l:   ds 1   ; Current note duration low byte
0038             51   note_dur_h:   ds 1   ; Current note duration high byte
0039             52   
0000             53   bseg
0000             54   song_playing: dbit 1 ; Flag: is song currently playing?
0001             55   
002E             56   cseg
002E             57   
002E             58   ; -------- Note reload values (CLK = 33,333,333 Hz, prescaler = 12) --------
002E             59   ; Timer0 overflow rate = 2*freq (because we toggle pin each overflow)
002E             60   
002E             61   R_C5  EQU 0F5A2h   ; 523.25 Hz (Do)
002E             62   R_D5  EQU 0F6C3h   ; 587.33 Hz (Re)
002E             63   R_E5  EQU 0F7C5h   ; 659.26 Hz (Mi)
002E             64   R_F5  EQU 0F83Bh   ; 698.46 Hz (Fa)
002E             65   R_G5  EQU 0F914h   ; 783.99 Hz (Sol)
002E             66   R_A5  EQU 0F9D6h
002E             67   R_B5  EQU 0FA82h
002E             68   R_C6  EQU 0FAD0h   ; 1046.50 Hz (Do - higher octave)
002E             69   
002E             70   ; Simple rhythm: C D E F G A B C
002E             71   ; Each note plays for 400ms
002E             72   SIMPLE_RHYTHM:
002E F5A20190    73       DW R_C5, 400    ; Do
0032 F6C30190    74       DW R_D5, 400    ; Re
0036 F7C50190    75       DW R_E5, 400    ; Mi
003A F83B0190    76       DW R_F5, 400    ; Fa
003E F9140190    77       DW R_G5, 400    ; Sol
0042 F9D60190    78       DW R_A5, 400    ; La
0046 FA820190    79       DW R_B5, 400    ; Si
004A FAD00258    80       DW R_C6, 600    ; Do (longer final note)
004E             81   
004E             82   SONG_LEN EQU 8    ; number of notes
004E             83   
004E             84   ;---------------------------------;
004E             85   ; Load current note from song     ;
004E             86   ; Input: song_idx (0-7)          ;
004E             87   ;---------------------------------;
004E             88   Load_Song_Note:
004E C0E0        89       push acc
0050 C083        90       push dph
0052 C082        91       push dpl
0054             92       
0054             93       ; Each note is 4 bytes: 2 for reload, 2 for duration
0054             94       ; Offset = song_idx * 4
0054 E532        95       mov a, song_idx
0056 23          96       rl a              ; *2
0057 23          97       rl a              ; *4
0058 54FC        98       anl a, #0FCh      ; Ensure it's a multiple of 4
005A             99       
005A 90002E     100       mov dptr, #SIMPLE_RHYTHM
005D            101       
005D            102       ; Get reload high byte
005D 93         103       movc a, @a+dptr
005E F535       104       mov tone_rh, a
0060            105       
0060            106       ; Get reload low byte
0060 E532       107       mov a, song_idx
0062 23         108       rl a
0063 23         109       rl a
0064 54FC       110       anl a, #0FCh
0066 04         111       inc a
0067 93         112       movc a, @a+dptr
0068 F536       113       mov tone_rl, a
006A            114       
006A            115       ; Get duration low byte
006A E532       116       mov a, song_idx
006C 23         117       rl a
006D 23         118       rl a
006E 54FC       119       anl a, #0FCh
0070 2402       120       add a, #2
0072 93         121       movc a, @a+dptr
0073 F538       122       mov note_dur_h, a
0075            123       
0075            124       ; Get duration high byte
0075 E532       125       mov a, song_idx
0077 23         126       rl a
0078 23         127       rl a
0079 54FC       128       anl a, #0FCh
007B 2403       129       add a, #3
007D 93         130       movc a, @a+dptr
007E F537       131       mov note_dur_l, a
0080            132       
0080            133       ; Reset note timing counter
0080 E4         134       clr a
0081 F533       135       mov note_ms+0, a
0083 F534       136       mov note_ms+1, a
0085            137       
0085            138       ; Load timer and start
0085 85358C     139       mov TH0, tone_rh
0088 85368A     140       mov TL0, tone_rl
008B D28C       141       setb TR0              ; Start Timer0
008D            142       
008D D082       143       pop dpl
008F D083       144       pop dph
0091 D0E0       145       pop acc
0093 22         146       ret
0094            147   
0094            148   ;---------------------------------;
0094            149   ; Routine to initialize the ISR   ;
0094            150   ; for timer 0                     ;
0094            151   ;---------------------------------;
0094            152   Timer0_Init:
0094 E589       153            mov a, TMOD
0096 54F0       154            anl a, #0xf0 ; Clear the bits for timer 0
0098 4401       155            orl a, #0x01 ; Configure timer 0 as 16-timer
009A F589       156            mov TMOD, a
009C            157            
009C            158            ; Don't start timer yet - Load_Song_Note will do it
009C D2A9       159       setb ET0  ; Enable timer 0 interrupt
009E 22         160            ret
009F            161   
009F            162   ;---------------------------------;
009F            163   ; ISR for timer 0.                ;
009F            164   ; Generates square wave for tone  ;
009F            165   ;---------------------------------;
009F            166   Timer0_ISR:
009F            167            ; Reload timer with current note's value
009F 85358C     168            mov TH0, tone_rh
00A2 85368A     169            mov TL0, tone_rl
00A5 B284       170            cpl SOUND_OUT ; Toggle speaker
00A7 32         171            reti
00A8            172   
00A8            173   ;---------------------------------;
00A8            174   ; Routine to initialize the ISR   ;
00A8            175   ; for timer 2                     ;
00A8            176   ;---------------------------------;
00A8            177   Timer2_Init:
00A8 75C800     178            mov T2CON, #0 ; Stop timer/counter.  Autoreload mode.
00AB 75CDF5     179            mov TH2, #high(TIMER2_RELOAD)
00AE 75CC27     180            mov TL2, #low(TIMER2_RELOAD)
00B1            181            ; Set the reload value
00B1 75CBF5     182            mov RCAP2H, #high(TIMER2_RELOAD)
00B4 75CA27     183            mov RCAP2L, #low(TIMER2_RELOAD)
00B7            184            ; Init One millisecond interrupt counter
00B7 E4         185            clr a
00B8 F530       186            mov Count1ms+0, a
00BA F531       187            mov Count1ms+1, a
00BC            188            ; Enable the timer and interrupts
00BC D2AD       189       setb ET2  ; Enable timer 2 interrupt
00BE D2CA       190       setb TR2  ; Enable timer 2
00C0 22         191            ret
00C1            192   
00C1            193   ;---------------------------------;
00C1            194   ; ISR for timer 2 (1ms tick)      ;
00C1            195   ; Handles note timing             ;
00C1            196   ;---------------------------------;
00C1            197   Timer2_ISR:
00C1 C2CF       198            clr TF2  ; Timer 2 doesn't clear TF2 automatically
00C3 B291       199            cpl P1.1 ; Debug: Check interrupt rate with oscilloscope
00C5            200            
00C5 C0E0       201            push acc
00C7 C0D0       202            push psw
00C9            203            
00C9            204            ; Only process if song is playing
00C9 300027     205            jnb song_playing, Timer2_ISR_done
00CC            206            
00CC            207            ; Increment note duration counter
00CC 0533       208            inc note_ms+0
00CE E533       209            mov a, note_ms+0
00D0 7002       210            jnz Check_Note_Duration
00D2 0534       211            inc note_ms+1
00D4            212            
00D4            213   Check_Note_Duration:
00D4            214            ; Check if note duration has elapsed
00D4 E533       215            mov a, note_ms+0
00D6 B5371A     216            cjne a, note_dur_l, Timer2_ISR_done
00D9 E534       217            mov a, note_ms+1
00DB B53815     218            cjne a, note_dur_h, Timer2_ISR_done
00DE            219            
00DE            220            ; Note duration elapsed - advance to next note
00DE E532       221            mov a, song_idx
00E0 04         222            inc a
00E1            223            
00E1            224            ; Check if song is finished
00E1 B4080A     225            cjne a, #SONG_LEN, Next_Note_OK
00E4            226            
00E4            227            ; *** SONG FINISHED - STOP PLAYING ***
00E4 C200       228            clr song_playing
00E6 C28C       229            clr TR0               ; Stop Timer0
00E8 C284       230            clr SOUND_OUT         ; Turn off speaker
00EA D2E8       231            setb LEDRA.0          ; Turn on LED to show song finished
00EC 8005       232            sjmp Timer2_ISR_done
00EE            233            
00EE            234   Next_Note_OK:
00EE F532       235            mov song_idx, a
00F0 12004E     236            lcall Load_Song_Note
00F3            237            
00F3            238   Timer2_ISR_done:
00F3 D0D0       239            pop psw
00F5 D0E0       240            pop acc
00F7 32         241            reti
00F8            242   
00F8            243   ;---------------------------------;
00F8            244   ; Main program. Includes hardware ;
00F8            245   ; initialization and 'forever'    ;
00F8            246   ; loop.                           ;
00F8            247   ;---------------------------------;
00F8            248   main:
00F8            249            ; Initialization
00F8 75817F     250       mov SP, #0x7F
00FB            251       
00FB            252       ; Configure I/O pins
00FB 759A10     253       mov P0MOD, #00010000b ; P0.4 (SOUND_OUT) is output
00FE 759B02     254       mov P1MOD, #00000010b ; P1.1 is output (debug)
0101            255       
0101            256       ; Turn off all the LEDs
0101 75E800     257       mov LEDRA, #0
0104 759500     258       mov LEDRB, #0
0107            259       
0107            260       ; Initialize timers
0107 120094     261       lcall Timer0_Init
010A 1200A8     262       lcall Timer2_Init
010D            263       
010D            264       ; Initialize song (but don't play yet)
010D 753200     265       mov song_idx, #0
0110 C200       266       clr song_playing      ; Wait for button press
0112            267       
0112 D2AF       268       setb EA   ; Enable Global interrupts
0114            269            
0114            270            ; Main loop - wait for button to play
0114            271   loop:
0114            272            ; Press KEY.1 to play the rhythm
0114 20F9FD     273            jb KEY.1, loop
0117 30F9FD     274            jnb KEY.1, $          ; Wait for release
011A            275            
011A            276            ; Only play if not already playing
011A 2000F7     277            jb song_playing, loop
011D            278            
011D            279            ; Start playing from beginning
011D C2E8       280            clr LEDRA.0           ; Turn off LED
011F 753200     281            mov song_idx, #0
0122 12004E     282            lcall Load_Song_Note
0125 D200       283            setb song_playing
0127            284            
0127 80EB       285            sjmp loop
0129            286   
0129            287   EN
