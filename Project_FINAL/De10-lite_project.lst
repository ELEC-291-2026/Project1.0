0505            253   ; Pin definitions for keypad
0505            254   ROW1 EQU P1.2
0505            255   ROW2 EQU P1.4
0505            256   ROW3 EQU P1.6
0505            257   ROW4 EQU P2.0
0505            258   
0505            259   COL1 EQU P2.2
0505            260   COL2 EQU P2.4
0505            261   COL3 EQU P2.6
0505            262   COL4 EQU P3.0
