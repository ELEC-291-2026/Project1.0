05D7 7F0C       354       mov R7, #0Ch               ; store key code
05D9 30B0FD     354       jnb COL4, $                ; wait until key is released
05DC D3         354       setb C                   ; mark "key found"
05DD 0206EA     354       ljmp Key_Found           ; use long jump instead of short
05E0            354   CHECK_COL_35:
