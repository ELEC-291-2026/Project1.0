05BC            351   CHECK_COL_32:
05BC 20A409     352       jb  COL2, CHECK_COL_33     ; if column=1 -> no key here -> skip
05BF 7F08       352       mov R7, #08h               ; store key code
05C1 30A4FD     352       jnb COL2, $                ; wait until key is released
05C4 D3         352       setb C                   ; mark "key found"
