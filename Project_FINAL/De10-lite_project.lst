0B1A            109   ;Example macro to help with process %0,1,etc represents the input number, this is all pass by reference(i.e it can actually affect the variable)
                110   Load_X_Var32 MAC
                111   mov x+0, %0+0
                112   mov x+1, %0+1
                113   mov x+2, %0+2
                114   mov x+3, %0+3
                115   ENDMAC
0B1A            116   
                117   Load_Y_Var32 MAC
                118   mov y+0, %0+0
                119   mov y+1, %0+1
                120   mov y+2, %0+2
                121   mov y+3, %0+3
                122   ENDMAC
0B1A            123   
                124   Load_X_Var16 MAC
                125   mov x+0, %0+0
                126   mov x+1, %0+1
                127   mov x+2, #0
                128   mov x+3, #0
                129   ENDMAC
0B1A            130   
                131   Load_Y_Var16 MAC
                132   mov y+0, %0+0
                133   mov y+1, %0+1
                134   mov y+2, #0
                135   mov y+3, #0
                136   ENDMAC
0B1A            137   
                138   Load_X_Var8 MAC
                139       
                140   mov x+0, %0+0
                141   mov x+1, #0
                142   mov x+2, #0
                143   mov x+3, #0
                144   ENDMAC
0B1A            145   
                146   Load_Y_Var8 MAC
                147       
                148   mov y+0, %0+0
                149   mov y+1, #0
                150   mov y+2, #0
                151   mov y+3, #0
                152   ENDMAC
0B1A            153   
                154   powerPercent MAC
                155   	;Convert percentage of time into a time it needs to be on %0 is percentage(i.e 20 is 20%) on, %1 is total time, %2 is the time on
                156   	;load_x(%0)
                157   	mov x+0, %0
                158   	mov x+1, #0
                159   	mov x+2, #0
                160   	mov x+3, #0
                161   	;converts x to a percentage through fractions
                162   	Load_Y_Var16(%1)
                163   	lcall mul32
                164   	
                165   	load_y(100)
                166   	lcall div32
                167   	
                168   	mov %2+0, x+0
                169   	mov %2+1, x+1
                170   ENDMAC
