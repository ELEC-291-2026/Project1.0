044D             83   ;--------------------------------------------------
044D             84   ; Macro: Rotate Left through Carry
044D             85   ;--------------------------------------------------
044D             86   
                 87   MYRLC MAC
                 88       mov A, %0
                 89       rlc A
                 90       mov %0, A
                 91   ENDMAC
044D             92   
044D             93   ;--------------------------------------------------
044D             94   ; Shift all BCD digits LEFT by 4 bits
044D             95   ; Makes room for new digit in LSD (R7)
044D             96   ;--------------------------------------------------
044D             97   
044D             98   Shift_Digits_Left:
044D 7804        99       mov R0, #4           ; 4 bit shifts (one nibble)
044F            100   
044F            101   Shift_Digits_Left_L0:
044F C3         102       clr C                ; Clear carry before shift
0450 E538       103       mov A, bcd+0
0452 33         103       rlc A
0453 F538       103       mov bcd+0, A
0455 E539       104       mov A, bcd+1
0457 33         104       rlc A
0458 F539       104       mov bcd+1, A
045A E53A       105       mov A, bcd+2
045C 33         105       rlc A
045D F53A       105       mov bcd+2, A
045F E53B       106       mov A, bcd+3
0461 33         106       rlc A
0462 F53B       106       mov bcd+3, A
0464 E53C       107       mov A, bcd+4
0466 33         107       rlc A
0467 F53C       107       mov bcd+4, A
0469 D8E4       108       djnz R0, Shift_Digits_Left_L0
046B            109   
046B            110       ; Insert new digit from R7 into lowest nibble safely
046B            111       ; Keep upper nibble of bcd+0 unchanged
046B 5338F0     112       anl  bcd+0, #0F0h    ; clear lower nibble
046E EF         113       mov  A, R7
046F 540F       114       anl  A, #0Fh         ; ensure only 0-F
0471 4238       115       orl  bcd+0, A
0473 22         116       ret
0474            117   
0474            118   ;--------------------------------------------------
0474            119   ; Macro: Rotate Right through Carry
0474            120   ;--------------------------------------------------
0474            121   
                122   MYRRC MAC
                123       mov A, %0
                124       rrc A
                125       mov %0, A
                126   ENDMAC
0474            127   
0474            128   ;--------------------------------------------------
0474            129   ; Shift digits RIGHT by 4 bits
0474            130   ; Used for BACKSPACE (delete last digit)
0474            131   ;--------------------------------------------------
0474            132   
0474            133   Shift_Digits_Right:
0474 7804       134       mov R0, #4
0476            135   
0476            136   Shift_Digits_Right_L0:
0476 C3         137       clr C
0477 E53C       138       mov A, bcd+4
0479 13         138       rrc A
047A F53C       138       mov bcd+4, A
047C E53B       139       mov A, bcd+3
047E 13         139       rrc A
047F F53B       139       mov bcd+3, A
0481 E53A       140       mov A, bcd+2
0483 13         140       rrc A
0484 F53A       140       mov bcd+2, A
0486 E539       141       mov A, bcd+1
0488 13         141       rrc A
0489 F539       141       mov bcd+1, A
048B E538       142       mov A, bcd+0
048D 13         142       rrc A
048E F538       142       mov bcd+0, A
0490 D8E4       143       djnz R0, Shift_Digits_Right_L0
0492 22         144       ret
0493            145   
0493            146   
0493            147   ;--------------------------------------------------
0493            148   ; 25 ms delay (software debounce)
0493            149   ;--------------------------------------------------
0493            150   
0493            151   Wait25ms:
0493 780F       152       mov R0, #15
0495 794A       153   L6: mov R1, #74
0497 7AFA       154   L5: mov R2, #250
0499 DAFE       155   L4: djnz R2, L4
049B D9FA       156       djnz R1, L5
049D D8F6       157       djnz R0, L6
049F 22         158       ret
04A0            159   
