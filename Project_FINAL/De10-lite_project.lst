099B            107   ;---------------------------------;
099B            108   ; Routine to initialize the ISR   ;
099B            109   ; for timer 0                     ;
099B            110   ;---------------------------------;
099B            111   Timer0_Init:
099B E589       112            mov a, TMOD
099D 54F0       113            anl a, #0xf0 ; 11110000 Clear the bits for timer 0
099F 4401       114            orl a, #0x01 ; 00000001 Configure timer 0 as 16-timer
09A1 F589       115            mov TMOD, a
09A3            116            
09A3 758CF5     117            mov TH0, #high(TIMER0_RELOAD)
09A6 758A68     118            mov TL0, #low(TIMER0_RELOAD)
09A9            119            
09A9            120            ; Enable the timer and interrupts
09A9 D2A9       121       setb ET0  ; Enable timer 0 interrupt
09AB D28C       122       setb TR0  ; Start timer 0
09AD 22         123            ret
