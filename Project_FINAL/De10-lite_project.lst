                 -1   $include(lcd_lib.asm)
093A              1   ;===========================================================
093A              2   ; lcd_lib.asm - High-level LCD helper routines
093A              3   ;===========================================================
093A              4   ; Provides:
093A              5   ;   LCD_ShowParameter    - Show current active parameter on row 1
093A              6   ;   LCD_ShowTotalTime    - Show "Tot MM:SS" on row 2
093A              7   ;   LCD_ShowStateTime    - Show "St  MM:SS" on row 2 (simple)
093A              8   ;   LCD_ShowStateRunInfo - Show "Sx MM:SS ########" on row 2
093A              9   ;===========================================================
093A             10   
093A             11   CSEG
093A             12   
093A             13   
093A             14   ;-----------------------------------------------------------
093A             15   ; Write_3digits(var)
093A             16   ; var is a 2-byte packed BCD value:
093A             17   ;   var+0 : low byte  (tens, ones)
093A             18   ;   var+1 : high byte (thousands, hundreds)
093A             19   ; We print exactly 3 digits: H T O
093A             20   ;   H = hundreds  (low nibble of var+1)
093A             21   ;   T = tens      (high nibble of var+0)
093A             22   ;   O = ones      (low nibble of var+0)
093A             23   ;-----------------------------------------------------------
                 24   Write_3digits MAC
                 25       ; --- Hundreds digit (from low nibble of var+1) ---
                 26       mov  a, %0+1        ; load high BCD byte
                 27       anl  a, #0FH        ; keep low nibble = hundreds
                 28       orl  a, #'0'        ; convert 0–9 -> ASCII
                 29       lcall ?WriteData
                 30   
                 31       ; --- Tens digit (from high nibble of var+0) ---
                 32       mov  a, %0+0        ; load low BCD byte
                 33       swap a              ; high nibble -> low nibble
                 34       anl  a, #0FH        ; keep that nibble
                 35       orl  a, #'0'        ; 0–9 -> ASCII
                 36       lcall ?WriteData
                 37   
                 38       ; --- Ones digit (from low nibble of var+0) ---
                 39       mov  a, %0+0        ; load low BCD byte again
                 40       anl  a, #0FH        ; low nibble = ones
                 41       orl  a, #'0'        ; 0–9 -> ASCII
                 42       lcall ?WriteData
                 43   ENDMAC
093A             44   
093A             45   ;-----------------------------------------------------------
093A             46   ; LCD_ShowParamsLine1
093A             47   ;   Writes: ST=xxx  t=yyy
093A             48   ;   Uses: soak_temp (3-digit BCD), soak_time (seconds, 3-digit BCD)
093A             49   ;   Cursor must already be positioned by caller (e.g. Set_Cursor(1,1))
093A             50   ;-----------------------------------------------------------
093A             51   LCD_ShowParamsLine1:
093A C0E0        52       push acc
093C             53   
093C             54       ; "ST="
093C 7453        55       mov  a, #'S'
093E 12035D      56       lcall ?WriteData
0941 7454        57       mov  a, #'T'
0943 12035D      58       lcall ?WriteData
0946 743D        59       mov  a, #'='
0948 12035D      60       lcall ?WriteData
094B             61   
094B             62       ; ST=xxx   (soak_temp)
094B             63       ; --- Hundreds digit (from low nibble of var+1) ---
094B E559        63       mov  a, soak_temp+1        ; load high BCD byte
094D 540F        63       anl  a, #0FH        ; keep low nibble = hundreds
094F 4430        63       orl  a, #'0'        ; convert 0–9 -> ASCII
0951 12035D      63       lcall ?WriteData
0954             63   
0954             63       ; --- Tens digit (from high nibble of var+0) ---
0954 E558        63       mov  a, soak_temp+0        ; load low BCD byte
0956 C4          63       swap a              ; high nibble -> low nibble
0957 540F        63       anl  a, #0FH        ; keep that nibble
0959 4430        63       orl  a, #'0'        ; 0–9 -> ASCII
095B 12035D      63       lcall ?WriteData
095E             63   
095E             63       ; --- Ones digit (from low nibble of var+0) ---
095E E558        63       mov  a, soak_temp+0        ; load low BCD byte again
0960 540F        63       anl  a, #0FH        ; low nibble = ones
0962 4430        63       orl  a, #'0'        ; 0–9 -> ASCII
0964 12035D      63       lcall ?WriteData
0967             64   
0967             65       ; "  " (two spaces)
0967 7420        66       mov  a, #' '
0969 12035D      67       lcall ?WriteData
096C 7420        68       mov  a, #' '
096E 12035D      69       lcall ?WriteData
0971             70   
0971             71       ; "t="
0971 7474        72       mov  a, #'t'
0973 12035D      73       lcall ?WriteData
0976 743D        74       mov  a, #'='
0978 12035D      75       lcall ?WriteData
097B             76   
097B             77       ; t=yyy   (soak_time in seconds)
097B             78       ; --- Hundreds digit (from low nibble of var+1) ---
097B E55B        78       mov  a, soak_time+1        ; load high BCD byte
097D 540F        78       anl  a, #0FH        ; keep low nibble = hundreds
097F 4430        78       orl  a, #'0'        ; convert 0–9 -> ASCII
0981 12035D      78       lcall ?WriteData
0984             78   
0984             78       ; --- Tens digit (from high nibble of var+0) ---
0984 E55A        78       mov  a, soak_time+0        ; load low BCD byte
0986 C4          78       swap a              ; high nibble -> low nibble
0987 540F        78       anl  a, #0FH        ; keep that nibble
0989 4430        78       orl  a, #'0'        ; 0–9 -> ASCII
098B 12035D      78       lcall ?WriteData
098E             78   
098E             78       ; --- Ones digit (from low nibble of var+0) ---
098E E55A        78       mov  a, soak_time+0        ; load low BCD byte again
0990 540F        78       anl  a, #0FH        ; low nibble = ones
0992 4430        78       orl  a, #'0'        ; 0–9 -> ASCII
0994 12035D      78       lcall ?WriteData    
0997             79   
0997 D0E0        80       pop  acc
0999 22          81       ret
099A             82   
