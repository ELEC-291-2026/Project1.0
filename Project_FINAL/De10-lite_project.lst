0A5E            243   ; The 8-bit hex number passed in the accumulator is converted to
0A5E            244   ; BCD and stored in [R1, R0]
0A5E            245   Hex_to_bcd_8bit:
0A5E 75F064     246            mov b, #100
0A61 84         247            div ab
0A62 F9         248            mov R1, a   ; After dividing, a has the 100s
0A63 E5F0       249            mov a, b    ; Remainder is in register b
0A65 75F00A     250            mov b, #10
0A68 84         251            div ab ; The tens are stored in a, the units are stored in b 
0A69 C4         252            swap a
0A6A 54F0       253            anl a, #0xf0
0A6C 45F0       254            orl a, b
0A6E F8         255            mov R0, a
0A6F 22         256            ret
