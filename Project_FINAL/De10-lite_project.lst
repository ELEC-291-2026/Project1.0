05E2            356   
05E2 C2A0       357       clr ROW4
05E4 20A209     358       jb  COL1, CHECK_COL_36     ; if column=1 -> no key here -> skip
05E7 7F0E       358       mov R7, #0Eh               ; store key code
05E9 30A2FD     358       jnb COL1, $                ; wait until key is released
05EC D3         358       setb C                   ; mark "key found"
05ED 0206EA     358       ljmp Key_Found           ; use long jump instead of short
05F0            358   CHECK_COL_36: ; '*' delete
05F0 20A409     359       jb  COL2, CHECK_COL_37     ; if column=1 -> no key here -> skip
05F3 7F00       359       mov R7, #00h               ; store key code
05F5 30A4FD     359       jnb COL2, $                ; wait until key is released
05F8 D3         359       setb C                   ; mark "key found"
05F9 0206EA     359       ljmp Key_Found           ; use long jump instead of short
05FC            359   CHECK_COL_37: ; '0'
05FC 20A609     360       jb  COL3, CHECK_COL_38     ; if column=1 -> no key here -> skip
05FF 7F0F       360       mov R7, #0Fh               ; store key code
0601 30A6FD     360       jnb COL3, $                ; wait until key is released
0604 D3         360       setb C                   ; mark "key found"
0605 0206EA     360       ljmp Key_Found           ; use long jump instead of short
0608            360   CHECK_COL_38: ; '#' clear
0608 20B009     361       jb  COL4, CHECK_COL_39     ; if column=1 -> no key here -> skip
060B 7F0D       361       mov R7, #0Dh               ; store key code
060D 30B0FD     361       jnb COL4, $                ; wait until key is released
0610 D3         361       setb C                   ; mark "key found"
0611 0206EA     361       ljmp Key_Found           ; use long jump instead of short
0614            361   CHECK_COL_39: ; 'D'
0614 D2A0       362       setb ROW4
0616            363   
0616            364       ; If we reached here, no key found
0616 C3         365       clr C
0617 22         366       ret
0618            367   
0618            368   
