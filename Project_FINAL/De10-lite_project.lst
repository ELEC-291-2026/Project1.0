0409 C4          68       swap A               ; Swap nibbles
040A 540F        68       anl  A, #0Fh
040C 93          68       movc A, @A+dptr
040D F58F        68       mov  HEX5, A           ; Output to second HEX display
040F 8024        69       sjmp Display_end
0411             70   
