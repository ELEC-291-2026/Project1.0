095F 753A00     341            mov bcd+2, #0
0962 753B00     341            mov bcd+3, #0
0965 12007B     342                    lcall bcd2hex
0968 753482     343            mov y+0, #low (130 % 0x10000) 
096B 753500     343            mov y+1, #high(130 % 0x10000) 
096E 753600     343            mov y+2, #low (130 / 0x10000) 
0971 753700     343            mov y+3, #high(130 / 0x10000)  ; Our min temp
0974 12011A     344                    lcall x_lt_y ;mf 1 if true
0977 30001B     345                    jnb mf, underflow_soaktemp_check
097A 753082     346            mov x+0, #low (130 % 0x10000) 
097D 753100     346            mov x+1, #high(130 % 0x10000) 
0980 753200     346            mov x+2, #low (130 / 0x10000) 
0983 753300     346            mov x+3, #high(130 / 0x10000) 
0986 12002E     347                lcall hex2bcd
0989            348   ;bcd is A, soak_temp is B
