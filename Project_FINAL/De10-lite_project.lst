03C0              3   
03C0              4   ;--------------------------------------------------
03C0              5   ; Lookup table for 7-segment display patterns (common anode)
03C0              6   ; Index 0-F = segment pattern
03C0              7   ;--------------------------------------------------
03C0              8   
03C0              9   myLUT:
03C0 C0F9A4B0    10       DB 0C0h, 0F9h, 0A4h, 0B0h, 099h        ; digits 0-4
     99
03C5 9282F880    11       DB 092h, 082h, 0F8h, 080h, 090h        ; digits 5-9
     90
03CA 8883C6A1    12       DB 088h, 083h, 0C6h, 0A1h, 086h, 08Eh  ; A-F
     868E
03D0             13   
03D0             14   ;--------------------------------------------------
03D0             15   ; Macro: showBCD
03D0             16   ; Input : one byte containing two BCD digits
03D0             17   ; Output: two 7-seg displays
03D0             18   ;   %0 = bcd byte
03D0             19   ;   %1 = HEX low
03D0             20   ;   %2 = HEX high
03D0             21   ;--------------------------------------------------
03D0             22   
                 23   showBCD MAC
                 24       ; ---- Display lower nibble (LSD) ----
                 25       mov  A, %0           ; Load BCD byte
                 26       anl  A, #0Fh         ; Keep lower 4 bits
                 27       movc A, @A+dptr      ; Convert using LUT
                 28       mov  %1, A           ; Output to first HEX display
                 29   
                 30       ; ---- Display upper nibble (MSD) ----
                 31       mov  A, %0
                 32       swap A               ; Swap nibbles
                 33       anl  A, #0Fh
                 34       movc A, @A+dptr
                 35       mov  %2, A           ; Output to second HEX display
                 36   ENDMAC
03D0             37   
03D0             38   
03D0             39   ;--------------------------------------------------
03D0             40   ; Display routine - show BCD number on HEX displays
03D0             41   ; KEY3: 0 = show high digits, 1 = show low digits
03D0             42   ; LEDRA.7: overflow indicator if bcd+3 or bcd+4 != 0
03D0             43   ;--------------------------------------------------
03D0             44   
03D0             45   Display:
03D0 9003C0      46       mov dptr, #myLUT     ; Point to lookup table
03D3             47   
03D3             48       ; If digits 10-7 (bcd+3 and bcd+4) are NOT zero
03D3             49       ; turn ON LEDRA.7 as overflow indicator
03D3             50   
03D3 E53B        51       mov A, bcd+3
03D5 453C        52       orl A, bcd+4
03D7 6004        53       jz  Display_L1
03D9 D2EF        54       setb LEDRA.7         ; Alert LED on
03DB 8002        55       sjmp Display_L2
03DD             56   Display_L1:
03DD C2EF        57       clr LEDRA.7          ; Alert LED off
03DF             58   Display_L2:
03DF             59   
03DF             60       ; If KEY3 pressed (assuming active low) show HIGH digits
03DF             61       ; Otherwise show LOW digits
03DF             62   
03DF 30FB2F      63       jnb KEY.3, Display_high_digits
03E2             64   
03E2             65       ; Show lower 6 digits
03E2             66       ; ---- Display lower nibble (LSD) ----
03E2 E538        66       mov  A, bcd+0           ; Load BCD byte
03E4 540F        66       anl  A, #0Fh         ; Keep lower 4 bits
03E6 93          66       movc A, @A+dptr      ; Convert using LUT
03E7 F591        66       mov  HEX0, A           ; Output to first HEX display
03E9             66   
03E9             66       ; ---- Display upper nibble (MSD) ----
03E9 E538        66       mov  A, bcd+0
03EB C4          66       swap A               ; Swap nibbles
03EC 540F        66       anl  A, #0Fh
03EE 93          66       movc A, @A+dptr
03EF F592        66       mov  HEX1, A           ; Output to second HEX display
03F1             67       ; ---- Display lower nibble (LSD) ----
03F1 E539        67       mov  A, bcd+1           ; Load BCD byte
03F3 540F        67       anl  A, #0Fh         ; Keep lower 4 bits
03F5 93          67       movc A, @A+dptr      ; Convert using LUT
03F6 F593        67       mov  HEX2, A           ; Output to first HEX display
03F8             67   
03F8             67       ; ---- Display upper nibble (MSD) ----
03F8 E539        67       mov  A, bcd+1
03FA C4          67       swap A               ; Swap nibbles
03FB 540F        67       anl  A, #0Fh
03FD 93          67       movc A, @A+dptr
03FE F594        67       mov  HEX3, A           ; Output to second HEX display
0400             68       ; ---- Display lower nibble (LSD) ----
0400 E53A        68       mov  A, bcd+2           ; Load BCD byte
