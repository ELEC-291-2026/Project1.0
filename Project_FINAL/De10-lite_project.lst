                 -1   	$include(keypad_lib_3.asm)
03D7              1   
03D7              2   CSEG
03D7              3   
03D7              4   ;--------------------------------------------------
03D7              5   ; Lookup table for 7-segment display patterns (common anode)
03D7              6   ; Index 0-F = segment pattern
03D7              7   ;--------------------------------------------------
03D7              8   
03D7              9   myLUT:
03D7 C0F9A4B0    10       DB 0C0h, 0F9h, 0A4h, 0B0h, 099h        ; digits 0-4
     99
03DC 9282F880    11       DB 092h, 082h, 0F8h, 080h, 090h        ; digits 5-9
     90
03E1 8883C6A1    12       DB 088h, 083h, 0C6h, 0A1h, 086h, 08Eh  ; A-F
     868E
03E7             13   
03E7             14   ;--------------------------------------------------
03E7             15   ; Macro: showBCD
03E7             16   ; Input : one byte containing two BCD digits
03E7             17   ; Output: two 7-seg displays
03E7             18   ;   %0 = bcd byte
03E7             19   ;   %1 = HEX low
03E7             20   ;   %2 = HEX high
03E7             21   ;--------------------------------------------------
03E7             22   
                 23   showBCD MAC
                 24       ; ---- Display lower nibble (LSD) ----
                 25       mov  A, %0           ; Load BCD byte
                 26       anl  A, #0Fh         ; Keep lower 4 bits
                 27       movc A, @A+dptr      ; Convert using LUT
                 28       mov  %1, A           ; Output to first HEX display
                 29   
                 30       ; ---- Display upper nibble (MSD) ----
                 31       mov  A, %0
                 32       swap A               ; Swap nibbles
                 33       anl  A, #0Fh
                 34       movc A, @A+dptr
                 35       mov  %2, A           ; Output to second HEX display
                 36   ENDMAC
03E7             37   
03E7             38   
03E7             39   ;--------------------------------------------------
03E7             40   ; Display routine - show BCD number on HEX displays
03E7             41   ; KEY3: 0 = show high digits, 1 = show low digits
03E7             42   ; LEDRA.7: overflow indicator if bcd+3 or bcd+4 != 0
03E7             43   ;--------------------------------------------------
03E7             44   
03E7             45   Display:
03E7 9003D7      46       mov dptr, #myLUT     ; Point to lookup table
03EA             47   
03EA             48       ; If digits 10-7 (bcd+3 and bcd+4) are NOT zero
03EA             49       ; turn ON LEDRA.7 as overflow indicator
03EA             50   
03EA E53B        51       mov A, bcd+3
03EC 453C        52       orl A, bcd+4
03EE 6004        53       jz  Display_L1
03F0 D2EF        54       setb LEDRA.7         ; Alert LED on
03F2 8002        55       sjmp Display_L2
03F4             56   Display_L1:
03F4 C2EF        57       clr LEDRA.7          ; Alert LED off
03F6             58   Display_L2:
03F6             59   
03F6             60       ; If KEY3 pressed (assuming active low) show HIGH digits
03F6             61       ; Otherwise show LOW digits
03F6             62   
03F6 30FB2F      63       jnb KEY.3, Display_high_digits
03F9             64   
03F9             65       ; Show lower 6 digits
03F9             66       ; ---- Display lower nibble (LSD) ----
03F9 E538        66       mov  A, bcd+0           ; Load BCD byte
03FB 540F        66       anl  A, #0Fh         ; Keep lower 4 bits
03FD 93          66       movc A, @A+dptr      ; Convert using LUT
03FE F591        66       mov  HEX0, A           ; Output to first HEX display
0400             66   
0400             66       ; ---- Display upper nibble (MSD) ----
0400 E538        66       mov  A, bcd+0
0402 C4          66       swap A               ; Swap nibbles
0403 540F        66       anl  A, #0Fh
0405 93          66       movc A, @A+dptr
0406 F592        66       mov  HEX1, A           ; Output to second HEX display
0408             67       ; ---- Display lower nibble (LSD) ----
0408 E539        67       mov  A, bcd+1           ; Load BCD byte
040A 540F        67       anl  A, #0Fh         ; Keep lower 4 bits
040C 93          67       movc A, @A+dptr      ; Convert using LUT
040D F593        67       mov  HEX2, A           ; Output to first HEX display
040F             67   
040F             67       ; ---- Display upper nibble (MSD) ----
040F E539        67       mov  A, bcd+1
0411 C4          67       swap A               ; Swap nibbles
0412 540F        67       anl  A, #0Fh
0414 93          67       movc A, @A+dptr
0415 F594        67       mov  HEX3, A           ; Output to second HEX display
0417             68       ; ---- Display lower nibble (LSD) ----
0417 E53A        68       mov  A, bcd+2           ; Load BCD byte
0419 540F        68       anl  A, #0Fh         ; Keep lower 4 bits
041B 93          68       movc A, @A+dptr      ; Convert using LUT
041C F58E        68       mov  HEX4, A           ; Output to first HEX display
041E             68   
041E             68       ; ---- Display upper nibble (MSD) ----
041E E53A        68       mov  A, bcd+2
0420 C4          68       swap A               ; Swap nibbles
0421 540F        68       anl  A, #0Fh
0423 93          68       movc A, @A+dptr
0424 F58F        68       mov  HEX5, A           ; Output to second HEX display
0426 8024        69       sjmp Display_end
0428             70   
0428             71   Display_high_digits:
0428             72       ; Show upper 4 digits
0428             73       ; ---- Display lower nibble (LSD) ----
0428 E53B        73       mov  A, bcd+3           ; Load BCD byte
042A 540F        73       anl  A, #0Fh         ; Keep lower 4 bits
042C 93          73       movc A, @A+dptr      ; Convert using LUT
042D F591        73       mov  HEX0, A           ; Output to first HEX display
042F             73   
042F             73       ; ---- Display upper nibble (MSD) ----
042F E53B        73       mov  A, bcd+3
0431 C4          73       swap A               ; Swap nibbles
0432 540F        73       anl  A, #0Fh
0434 93          73       movc A, @A+dptr
0435 F592        73       mov  HEX1, A           ; Output to second HEX display
0437             74       ; ---- Display lower nibble (LSD) ----
0437 E53C        74       mov  A, bcd+4           ; Load BCD byte
0439 540F        74       anl  A, #0Fh         ; Keep lower 4 bits
043B 93          74       movc A, @A+dptr      ; Convert using LUT
043C F593        74       mov  HEX2, A           ; Output to first HEX display
043E             74   
043E             74       ; ---- Display upper nibble (MSD) ----
043E E53C        74       mov  A, bcd+4
0440 C4          74       swap A               ; Swap nibbles
0441 540F        74       anl  A, #0Fh
0443 93          74       movc A, @A+dptr
0444 F594        74       mov  HEX3, A           ; Output to second HEX display
0446             75   
0446             76       ; Blank remaining displays
0446 758EFF      77       mov HEX4, #0FFh
0449 758FFF      78       mov HEX5, #0FFh
044C             79   
044C             80   Display_end:
044C 22          81       ret
