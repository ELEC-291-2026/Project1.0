0BC4            344   ; TempAndLCD_Update
0BC4            345   ;   - Reads sensors
0BC4            346   ;   - Updates tempFinal
0BC4            347   ;   - Updates 7-seg (if not in state 0)
0BC4            348   ;   - Updates LCD according to FSM_state + ScreenSelect
0BC4            349   ;   Assumes:
0BC4            350   ;      - Called with interrupts enabled
0BC4            351   ;------------------------------------------------------
0BC4            352   TempAndLCD_Update:
0BC4            353       ; ALL TEMP MATH -------------------------
0BC4 C2AF       354       clr EA
0BC6            355   ; ---------------------------------------------------------
0BC6            356       ; 1) Read thermocouple channel and convert to mV
0BC6            357       ; ---------------------------------------------------------
0BC6 75A100     358       mov ADC_C, #LM335_ADC
0BC9            359   
0BC9 753300     360       mov x+3, #0
0BCC 753200     361       mov x+2, #0
0BCF 85A331     362       mov x+1, ADC_H
0BD2 85A230     363       mov x+0, ADC_L
0BD5            364   
0BD5 753488     365            mov y+0, #low (5000 % 0x10000) 
0BD8 753513     365            mov y+1, #high(5000 % 0x10000) 
0BDB 753600     365            mov y+2, #low (5000 / 0x10000) 
0BDE 753700     365            mov y+3, #high(5000 / 0x10000) 
0BE1 12018D     366       lcall mul32
0BE4 753400     367            mov y+0, #low (4096 % 0x10000) 
0BE7 753510     367            mov y+1, #high(4096 % 0x10000) 
0BEA 753600     367            mov y+2, #low (4096 / 0x10000) 
0BED 753700     367            mov y+3, #high(4096 / 0x10000) 
0BF0 120281     368       lcall div32           ; x now holds Vtc in mV
0BF3            369       
0BF3            370       ; Save it
0BF3 85304A     371       mov V_tc+0, x+0
0BF6 85314B     372       mov V_tc+1, x+1
0BF9 85324C     373       mov V_tc+2, x+2
0BFC 85334D     374       mov V_tc+3, x+3
0BFF            375   
0BFF            376       ; ---------------------------------------------------------
0BFF            377       ; 2) Read LM335 (next channel) and convert to Celsius
0BFF            378       ; ---------------------------------------------------------
0BFF 75A101     379       mov ADC_C, #OP07_ADC
0C02            380   
0C02 753300     381       mov x+3, #0
0C05 753200     382       mov x+2, #0
0C08 85A331     383       mov x+1, ADC_H
0C0B 85A230     384       mov x+0, ADC_L
0C0E            385   
0C0E 753488     386            mov y+0, #low (5000 % 0x10000) 
0C11 753513     386            mov y+1, #high(5000 % 0x10000) 
0C14 753600     386            mov y+2, #low (5000 / 0x10000) 
0C17 753700     386            mov y+3, #high(5000 / 0x10000) 
0C1A 12018D     387       lcall mul32
0C1D 753400     388            mov y+0, #low (4096 % 0x10000) 
0C20 753510     388            mov y+1, #high(4096 % 0x10000) 
0C23 753600     388            mov y+2, #low (4096 / 0x10000) 
0C26 753700     388            mov y+3, #high(4096 / 0x10000) 
0C29 120281     389       lcall div32           ; x = Vlm in mV
0C2C            390   
0C2C 75340A     391            mov y+0, #low (10 % 0x10000) 
0C2F 753500     391            mov y+1, #high(10 % 0x10000) 
0C32 753600     391            mov y+2, #low (10 / 0x10000) 
0C35 753700     391            mov y+3, #high(10 / 0x10000) 
0C38 120281     392       lcall div32           ; x = Kelvin
0C3B 753411     393            mov y+0, #low (273 % 0x10000) 
0C3E 753501     393            mov y+1, #high(273 % 0x10000) 
0C41 753600     393            mov y+2, #low (273 / 0x10000) 
0C44 753700     393            mov y+3, #high(273 / 0x10000) 
0C47 1200F7     394       lcall sub32           ; x = Celsius
0C4A            395       
0C4A            396       ; Save cold junction temp
0C4A 85304E     397       mov V_cj+0, x+0
0C4D 85314F     398       mov V_cj+1, x+1
0C50 853250     399       mov V_cj+2, x+2
0C53 853351     400       mov V_cj+3, x+3
0C56            401   
0C56            402   ; ---------------------------------------------------------
0C56            403       ; 3) Calculate: Temp_x10 = (V_tc * 10000 / 12300) + (V_cj * 10)
0C56            404       ; ---------------------------------------------------------
0C56 854A30     405       mov x+0, V_tc+0
0C59 854B31     406       mov x+1, V_tc+1
0C5C 854C32     407       mov x+2, V_tc+2
0C5F 854D33     408       mov x+3, V_tc+3
0C62            409   
0C62 753410     410            mov y+0, #low (10000 % 0x10000) 
0C65 753527     410            mov y+1, #high(10000 % 0x10000) 
0C68 753600     410            mov y+2, #low (10000 / 0x10000) 
0C6B 753700     410            mov y+3, #high(10000 / 0x10000)          ; keep one decimal place
0C6E 12018D     411       lcall mul32
0C71 75340C     412            mov y+0, #low (12300 % 0x10000) 
0C74 753530     412            mov y+1, #high(12300 % 0x10000) 
0C77 753600     412            mov y+2, #low (12300 / 0x10000) 
0C7A 753700     412            mov y+3, #high(12300 / 0x10000) 
0C7D 120281     413       lcall div32           ; x = scaled TC temperature (e.g., 123 for 12.3C)
0C80            414   
0C80            415       ; Save this intermediate result in y to free up x for CJ scaling
0C80 853034     416       mov y+0, x+0
0C83 853135     417       mov y+1, x+1
0C86 853236     418       mov y+2, x+2
0C89 853337     419       mov y+3, x+3
0C8C            420   
0C8C            421       ; Load Cold Junction and scale it by 10 to match units
0C8C 854E30     422       mov x+0, V_cj+0
0C8F 854F31     423       mov x+1, V_cj+1
0C92 855032     424       mov x+2, V_cj+2
