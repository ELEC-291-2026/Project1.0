0B59            261   ; The 8-bit hex number passed in the accumulator is converted to
0B59            262   ; BCD and stored in [R1, R0]
0B59            263   Hex_to_bcd_8bit:
0B59 75F064     264            mov b, #100
0B5C 84         265            div ab
0B5D F9         266            mov R1, a   ; After dividing, a has the 100s
0B5E E5F0       267            mov a, b    ; Remainder is in register b
0B60 75F00A     268            mov b, #10
0B63 84         269            div ab ; The tens are stored in a, the units are stored in b 
0B64 C4         270            swap a
0B65 54F0       271            anl a, #0xf0
0B67 45F0       272            orl a, b
0B69 F8         273            mov R0, a
0B6A 22         274            ret
