0505            264   ;--------------------------------------------------
0505            265   ; Keypad scanning routine
0505            266   ; Output:
0505            267   ;   C = 1 -> numeric key pressed, code in R7 (0-9, maybe E/F)
0505            268   ;   C = 0 -> no digit (no key, mode key, or backspace)
0505            269   ;--------------------------------------------------
0505            270   
0505            271   Keypad:
0505            272   
0505            273       ; KEY1 acts as BACKSPACE / ERASE
0505            274   
0505 20F90E     275       jb  KEY.1, keypad_L0     ; if KEY1=1 (not pressed) -> skip
0508 120494     276       lcall Wait25ms
050B 20F908     277       jb  KEY.1, keypad_L0     ; if bounced back high, skip
050E 30F9FD     278       jnb KEY.1, $             ; wait for release (KEY1 low while pressed)
0511 120475     279       lcall Shift_Digits_Right ; delete LSD for active parameter
0514 C3         280       clr C                    ; no digit returned
0515 22         281       ret
0516            282   
0516            283   keypad_L0:
0516            284   
0516            285       ; Drive all rows LOW - check if any column LOW
0516            286   
0516 C292       287       clr ROW1
0518 C294       288       clr ROW2
051A C296       289       clr ROW3
051C C2A0       290       clr ROW4
051E            291   
051E A2A2       292       mov C, COL1
0520 82A4       293       anl C, COL2
0522 82A6       294       anl C, COL3
0524 82B0       295       anl C, COL4
0526 5002       296       jnc Keypad_Debounce      ; if any column low -> possible key
0528 C3         297       clr C
0529 22         298       ret
052A            299   
052A            300   Keypad_Debounce:
052A            301       ; Wait and check again to avoid bouncing
052A 120494     302       lcall Wait25ms
052D            303   
052D A2A2       304       mov C, COL1
052F 82A4       305       anl C, COL2
0531 82A6       306       anl C, COL3
0533 82B0       307       anl C, COL4
0535 5002       308       jnc Keypad_Key_Code
0537 C3         309       clr C
0538 22         310       ret
0539            311   
0539            312   Keypad_Key_Code:
0539            313       ; Prepare to scan each row individually
0539 D292       314       setb ROW1
053B D294       315       setb ROW2
053D D296       316       setb ROW3
053F D2A0       317       setb ROW4
0541            318   
