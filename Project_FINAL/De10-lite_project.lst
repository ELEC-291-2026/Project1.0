000B 0208C2      28            ljmp Timer0_ISR
000E             29   
000E             30   ; Timer/Counter 2 overflow interrupt vector
002B             31   org 0x002B
002B 0208E3      32            ljmp Timer2_ISR
002E             33   
002E             34   
