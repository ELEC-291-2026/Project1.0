005A             45   soak_time:      ds 2      ; mode B 60-120
005C             46   soak_time_hex:   ds 2
005E             47   reflow_temp:    ds 2      ; mode C 230 < 240
0060             48   reflow_time:    ds 2      ; mode D  30 < 45
0062             49   reflow_time_hex: ds 2
