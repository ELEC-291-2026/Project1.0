09E7 540F       117       anl  a, #0FH        ; keep that nibble
09E9 4430       117       orl  a, #'0'        ; 0–9 -> ASCII
09EB 12035D     117       lcall ?WriteData
09EE            117   
09EE            117       ; --- Ones digit (from low nibble of var+0) ---
09EE E560       117       mov  a, reflow_time+0        ; load low BCD byte again
09F0 540F       117       anl  a, #0FH        ; low nibble = ones
09F2 4430       117       orl  a, #'0'        ; 0–9 -> ASCII
09F4 12035D     117       lcall ?WriteData
