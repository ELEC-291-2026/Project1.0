0B88            252   
0B88            253   ; The 8-bit hex number passed in the accumulator is converted to
0B88            254   ; BCD and stored in [R1, R0]
0B88            255   Hex_to_bcd_8bit:
0B88 75F064     256            mov b, #100
0B8B 84         257            div ab
0B8C F9         258            mov R1, a   ; After dividing, a has the 100s
0B8D E5F0       259            mov a, b    ; Remainder is in register b
0B8F 75F00A     260            mov b, #10
0B92 84         261            div ab ; The tens are stored in a, the units are stored in b 
0B93 C4         262            swap a
0B94 54F0       263            anl a, #0xf0
0B96 45F0       264            orl a, b
0B98 F8         265            mov R0, a
0B99 22         266            ret
0B9A            267            
0B9A            268            
0B9A            269   ;We should probably start using this from now on oh well live laugh love
                270   Mov_A_to_B MAC
                271   ;%0 is A, %1 is B
                272   	mov %1+0, %0+0
                273   	mov %1+1, %0+1
                274   	mov %1+2, #0
                275   	mov %1+3, #0
                276   ENDMAC
