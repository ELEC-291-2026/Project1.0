0744 758D01      11       mov TH1, #high(T1LOAD)     ; Load reload value
0747 758B00      12       mov TL1, #low(T1LOAD); Load initial value
074A D28E        13       setb TR1             ; Enable timer 1
074C 759852      14       mov SCON, #52H       ; Configure serial port (mode 1, REN=1)
074F 22          15       ret
