0398            129   ; Send a constant string to LCD   ;
0398            130   ;---------------------------------;
                131   Send_Constant_String mac
                132   	push dph
                133   	push dpl
                134   	push acc
                135   	mov dptr, %0
                136   	lcall ?Send_Constant_String
                137   	pop acc
                138   	pop dpl
                139   	pop dph
                140   endmac
0398            141   
0398            142   ?Send_Constant_String:
0398 E4         143       clr a
0399 93         144       movc a, @a+dptr
039A 6006       145       jz ?Send_Constant_String_Done
039C 12035B     146       lcall ?WriteData
039F A3         147       inc dptr
03A0 80F6       148       sjmp ?Send_Constant_String
03A2            149   ?Send_Constant_String_Done:
03A2 22         150       ret  
03A3            151   
03A3            152   ;---------------------------------;
03A3            153   ; Set LCD cursor at row, column   ;
03A3            154   ;---------------------------------;
                155   Set_Cursor mac
                156   	push acc
                157   	mov a, #%1
                158   	dec a
                159   	lcall ?Set_Cursor_%0 ; Select column and row
                160   	pop acc
                161   endmac
03A3            162   
03A3            163   ?Set_Cursor_2:
03A3 4440       164            orl a, #01000000B
03A5            165   ?Set_Cursor_1:
03A5 4480       166            orl a, #10000000B
03A7 020360     167            ljmp ?WriteCommand ; Select column and row
03AA            168   
