                145   mov y+2, #0
                146   mov y+3, #0
                147   ENDMAC
08AF            148   
                149   powerPercent MAC
                150   	;Convert percentage of time into a time it needs to be on %0 is percentage(i.e 20 is 20%) on, %1 is total time, %2 is the time on
                151   	;load_x(%0)
                152   	mov x+0, %0
                153   	mov x+1, #0
                154   	mov x+2, #0
                155   	mov x+3, #0
                156   	;converts x to a percentage through fractions
                157   	Load_Y_Var16(%1)
                158   	lcall mul32
                159   	
                160   	load_y(100)
                161   	lcall div32
                162   	
                163   	mov %2+0, x+0
                164   	mov %2+1, x+1
                165   ENDMAC
08AF            166   
08AF            167   ;We should probably start using this from now on oh well live laugh love
                168   Mov_A_to_B16Bit MAC
                169   ;%0 is A, %1 is B
                170   	mov %1+0, %0+0
                171   	mov %1+1, %0+1
                172   	mov %1+2, #0
                173   	mov %1+3, #0
                174   ENDMAC
