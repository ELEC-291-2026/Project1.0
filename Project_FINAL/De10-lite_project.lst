0000              7   CLK              EQU 33333333 ; Microcontroller system crystal frequency in Hz
0000              8   TIMER0_RATE      EQU 1024     ; 1000Hz, for a timer tick of 1ms
0000              9   TIMER0_RELOAD    EQU ((65536-(CLK/(12*TIMER0_RATE))))
0000             10   FREQ                     EQU 33333333
0000             11   BAUD                     EQU 115200
0000             12   T2LOAD                   EQU 65536-(FREQ/(32*BAUD))
0000             13   
0000             14   TONE_1024 EQU ((65536-(CLK/1024)))
0000             15   TONE_4096 EQU ((65536-(CLK/4096)))
0000             16   
0000             17   ;PIN Assignemet
