09DB E561       117       mov  a, reflow_time+1        ; load high BCD byte
09DD 540F       117       anl  a, #0FH        ; keep low nibble = hundreds
09DF 4430       117       orl  a, #'0'        ; convert 0–9 -> ASCII
09E1 12035D     117       lcall ?WriteData
09E4            117   
09E4            117       ; --- Tens digit (from high nibble of var+0) ---
09E4 E560       117       mov  a, reflow_time+0        ; load low BCD byte
