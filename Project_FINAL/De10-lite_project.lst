0BB2            327   
0BB2            328   ; The 8-bit hex number passed in the accumulator is converted to
0BB2            329   ; BCD and stored in [R1, R0]
0BB2            330   Hex_to_bcd_8bit:
0BB2 75F064     331            mov b, #100
0BB5 84         332            div ab
0BB6 F9         333            mov R1, a   ; After dividing, a has the 100s
0BB7 E5F0       334            mov a, b    ; Remainder is in register b
0BB9 75F00A     335            mov b, #10
0BBC 84         336            div ab ; The tens are stored in a, the units are stored in b 
0BBD C4         337            swap a
0BBE 54F0       338            anl a, #0xf0
0BC0 45F0       339            orl a, b
0BC2 F8         340            mov R0, a
0BC3 22         341            ret
