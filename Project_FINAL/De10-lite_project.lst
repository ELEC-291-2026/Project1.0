06EB            406   
06EB            407   ;--------------------------------------------------
06EB            408   ; Key_Found:
06EB            409   ;   R7 = key code (0-F), C = 1 when we get here.
06EB            410   ;   A/B/C/D (0Ah-0Dh) -> mode select
06EB            411   ;   * (0Eh)           -> delete / backspace one digit
06EB            412   ;   # (0Fh)           -> clear all digits
06EB            413   ;   others (0-9, maybe E/F) -> digit
06EB            414   ;--------------------------------------------------
06EB            415   
06EB            416   Key_Found:
06EB EF         417       mov A, R7
06EC            418   
06EC            419       ; --- Mode A (soak temperature) ---
06EC B40A0B     420       cjne A, #0Ah, KF_CheckB
06EF 1204A1     421       lcall Save_Current_BCD_Into_Param
06F2 756400     422       mov   active_param, #0       ; A: soak_temp
06F5 1204C8     423       lcall Load_Param_Into_BCD
06F8 C3         424       clr C                        ; do not treat as digit
06F9 22         425       ret
06FA            426   
06FA            427   KF_CheckB:
06FA            428       ; --- Mode B (soak time) ---
06FA B40B0B     429       cjne A, #0Bh, KF_CheckC
06FD 1204A1     430       lcall Save_Current_BCD_Into_Param
0700 756401     431       mov   active_param, #1       ; B: soak_time
0703 1204C8     432       lcall Load_Param_Into_BCD
0706 C3         433       clr C
0707 22         434       ret
0708            435   
0708            436   KF_CheckC:
0708            437       ; --- Mode C (reflow temperature) ---
0708 B40C0B     438       cjne A, #0Ch, KF_CheckD
070B 1204A1     439       lcall Save_Current_BCD_Into_Param
070E 756402     440       mov   active_param, #2       ; C: reflow_temp
0711 1204C8     441       lcall Load_Param_Into_BCD
0714 C3         442       clr C
0715 22         443       ret
0716            444   
0716            445   KF_CheckD:
0716            446       ; --- Mode D (reflow time) ---
0716 B40D0B     447       cjne A, #0Dh, KF_CheckStar
0719 1204A1     448       lcall Save_Current_BCD_Into_Param
071C 756403     449       mov   active_param, #3       ; D: reflow_time
071F 1204C8     450       lcall Load_Param_Into_BCD
0722 C3         451       clr C
0723 22         452       ret
0724            453   
0724            454   KF_CheckStar:
0724            455       ; --- '*' key (code 0Eh) -> delete / backspace ---
0724 B40E05     456       cjne A, #0Eh, KF_CheckHash
0727            457       ; Backspace = shift digits right by 1 digit
0727 120475     458       lcall Shift_Digits_Right
072A C3         459       clr C                        ; no new digit for main loop
072B 22         460       ret
072C            461   
072C            462   KF_CheckHash:
072C            463       ; --- '#' key (code 0Fh) -> clear ---
072C B40F0D     464       cjne A, #0Fh, KF_Digit
072F            465       ; Clear all BCD digits for current parameter
072F E4         466       clr A
0730 F538       467       mov bcd+0, A
0732 F539       468       mov bcd+1, A
0734 F53A       469       mov bcd+2, A
0736 F53B       470       mov bcd+3, A
0738 F53C       471       mov bcd+4, A
073A C3         472       clr C                        ; no digit to insert
073B 22         473       ret
073C            474   
073C            475   KF_Digit:
