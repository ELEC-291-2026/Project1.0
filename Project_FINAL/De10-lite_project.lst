09D1            213   ; The 8-bit hex number passed in the accumulator is converted to
09D1            214   ; BCD and stored in [R1, R0]
09D1            215   Hex_to_bcd_8bit:
09D1 75F064     216            mov b, #100
09D4 84         217            div ab
09D5 F9         218            mov R1, a   ; After dividing, a has the 100s
09D6 E5F0       219            mov a, b    ; Remainder is in register b
09D8 75F00A     220            mov b, #10
09DB 84         221            div ab ; The tens are stored in a, the units are stored in b 
09DC C4         222            swap a
09DD 54F0       223            anl a, #0xf0
09DF 45F0       224            orl a, b
09E1 F8         225            mov R0, a
09E2 22         226            ret
09E3            227            
09E3            228            
09E3            229   ;We should probably start using this from now on oh well live laugh love
                230   Mov_A_to_B MAC
                231   ;%0 is A, %1 is B
                232   	mov %1+0, %0+0
                233   	mov %1+1, %0+1
                234   	mov %1+2, #0
                235   	mov %1+3, #0
                236   ENDMAC
