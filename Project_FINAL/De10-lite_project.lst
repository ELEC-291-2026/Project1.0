0563 7F03       339       mov R7, #03h               ; store key code
0565 30A6FD     339       jnb COL3, $                ; wait until key is released
0568 D3         339       setb C                   ; mark "key found"
0569 0206EA     339       ljmp Key_Found           ; use long jump instead of short
056C            339   CHECK_COL_26:
056C 20B009     340       jb  COL4, CHECK_COL_27     ; if column=1 -> no key here -> skip
056F 7F0A       340       mov R7, #0Ah               ; store key code
0571 30B0FD     340       jnb COL4, $                ; wait until key is released
0574 D3         340       setb C                   ; mark "key found"
0575 0206EA     340       ljmp Key_Found           ; use long jump instead of short
0578            340   CHECK_COL_27:
0578 D292       341       setb ROW1
057A            342   
057A C294       343       clr ROW2
057C 20A209     344       jb  COL1, CHECK_COL_28     ; if column=1 -> no key here -> skip
057F 7F04       344       mov R7, #04h               ; store key code
0581 30A2FD     344       jnb COL1, $                ; wait until key is released
0584 D3         344       setb C                   ; mark "key found"
