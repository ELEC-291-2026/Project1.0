                614   $LIST
                 -1   $include(LCD_4bit_DE10Lite_no_RW.inc) ; A library of LCD related functions and utility macros
0321              1   ;  LCD routines adapted for the DE10-Lite configured as a CV_8052 processor
0321              2   cseg
0321              3   
0321              4   ; When using a 33.333333MHz crystal clock
0321              5   ; one cycle takes 1.0/33.333333MHz = 30 ns
0321              6   
0321              7   ;---------------------------------;
0321              8   ; Wait 40 microseconds            ;
0321              9   ;---------------------------------;
0321             10   Wait40uSec:
0321 C000        11            push AR0
0323 78BE        12            mov R0, #190
0325             13   L0: 
0325 00          14            nop
0326 00          15            nop
0327 00          16            nop
0328 00          17            nop
0329 D8FA        18            djnz R0, L0 ; 1+1+1+1+3 cycles->7*30ns*190=40us
032B D000        19            pop AR0
032D 22          20       ret
032E             21   
032E             22   ;---------------------------------;
032E             23   ; Wait 'R2' milliseconds          ;
032E             24   ;---------------------------------;
                 25   Wait_Milli_Seconds mac
                 26   	push AR2
                 27   	mov R2, %0
                 28   	lcall ?Wait_Milli_Seconds
                 29   	pop AR2
                 30   endmac
032E             31   
032E             32   ?Wait_Milli_Seconds:
032E C000        33            push AR0
0330 C001        34            push AR1
0332 7932        35   L3: mov R1, #50
0334 78DF        36   L2: mov R0, #223
0336 D8FE        37   L1: djnz R0, L1 ; 3 cycles->3*30ns*250=20.07us
0338 D9FA        38       djnz R1, L2 ; 20.07us*50=1.004ms
033A DAF6        39       djnz R2, L3 ; number of millisecons to wait passed in R2
033C D001        40       pop AR1
033E D000        41       pop AR0
0340 22          42       ret
0341             43            
0341             44   ;---------------------------------;
0341             45   ; Toggles the 'E' pin in the LCD  ;
0341             46   ;---------------------------------;
0341             47   ELCD_pulse:
0341 D291        48            setb ELCD_E
0343 120321      49            lcall Wait40uSec
0346 C291        50            clr ELCD_E
0348 120321      51       lcall Wait40uSec ; This line is needed in the DE1SoC running an 8051 because it is much faster than the AT89LP51RC2
034B 22          52       ret
034C             53   
034C             54   ;---------------------------------;
034C             55   ; Writes acc to LCD in 4-bit mode ;
034C             56   ;---------------------------------;
034C             57   ELCD_byte:
034C             58            ; Write high 4 bits first
034C A2E7        59            mov c, ACC.7
034E 9281        60            mov ELCD_D7, c
0350 A2E6        61            mov c, ACC.6
0352 9283        62            mov ELCD_D6, c
0354 A2E5        63            mov c, ACC.5
0356 9285        64            mov ELCD_D5, c
0358 A2E4        65            mov c, ACC.4
035A 9287        66            mov ELCD_D4, c
035C 120341      67       lcall ELCD_pulse
035F             68            ; Write low 4 bits next
035F A2E3        69            mov c, ACC.3
0361 9281        70            mov ELCD_D7, c
0363 A2E2        71            mov c, ACC.2
0365 9283        72            mov ELCD_D6, c
0367 A2E1        73            mov c, ACC.1
0369 9285        74            mov ELCD_D5, c
036B A2E0        75            mov c, ACC.0
036D 9287        76            mov ELCD_D4, c
036F 120341      77       lcall ELCD_pulse
0372 22          78            ret
0373             79   
0373             80   ;---------------------------------;
0373             81   ; Write data to LCD               ;
0373             82   ;---------------------------------;
                 83   WriteData mac
                 84   	mov a, %0
                 85   	lcall ?WriteData
                 86   endmac
0373             87            
0373             88   ?WriteData:
0373 D297        89            setb ELCD_RS
0375 02034C      90            ljmp ELCD_byte
0378             91   
0378             92   ;---------------------------------;
0378             93   ; Write command to LCD            ;
0378             94   ;---------------------------------;
                 95   WriteCommand mac
                 96   	mov a, %0
                 97   	lcall ?WriteCommand
                 98   endmac
0378             99   
0378            100   ?WriteCommand:
0378 C297       101            clr ELCD_RS
037A 02034C     102            ljmp ELCD_byte
037D            103   
037D            104   ;---------------------------------;
037D            105   ; Configure LCD in 4-bit mode     ;
037D            106   ;---------------------------------;
037D            107   ELCD_4BIT:
037D C291       108            clr ELCD_E   ; Resting state of LCD's enable pin is zero
037F            109            ;clr ELCD_RW  ; RW forced to zero
037F            110            
037F            111            ; After power on, let the LCD start up before initializing
037F C002       112            push AR2
0381 7A28       112            mov R2, #40
0383 12032E     112            lcall ?Wait_Milli_Seconds
0386 D002       112            pop AR2
0388            113            
0388            114            ; First make sure the LCD is in 8-bit mode and then change to 4-bit mode
0388 7433       115            mov a, #0x33
038A 120378     115            lcall ?WriteCommand
038D 7433       116            mov a, #0x33
038F 120378     116            lcall ?WriteCommand
0392 7432       117            mov a, #0x32
0394 120378     117            lcall ?WriteCommand ; change to 4-bit mode
0397            118   
0397            119            ; Configure the LCD
0397 7428       120            mov a, #0x28
0399 120378     120            lcall ?WriteCommand
039C 740C       121            mov a, #0x0c
039E 120378     121            lcall ?WriteCommand
03A1 7401       122            mov a, #0x01
03A3 120378     122            lcall ?WriteCommand ;  Clear screen command (takes some time)
03A6            123   
03A6            124       ;Wait for the clear screen command to finish.
03A6 C002       125            push AR2
03A8 7A02       125            mov R2, #2
03AA 12032E     125            lcall ?Wait_Milli_Seconds
03AD D002       125            pop AR2
03AF 22         126       ret
03B0            127   
03B0            128   ;---------------------------------;
03B0            129   ; Send a constant string to LCD   ;
03B0            130   ;---------------------------------;
                131   Send_Constant_String mac
                132   	push dph
                133   	push dpl
                134   	push acc
                135   	mov dptr, %0
                136   	lcall ?Send_Constant_String
                137   	pop acc
                138   	pop dpl
                139   	pop dph
                140   endmac
03B0            141   
03B0            142   ?Send_Constant_String:
03B0 E4         143       clr a
03B1 93         144       movc a, @a+dptr
03B2 6006       145       jz ?Send_Constant_String_Done
03B4 120373     146       lcall ?WriteData
03B7 A3         147       inc dptr
03B8 80F6       148       sjmp ?Send_Constant_String
03BA            149   ?Send_Constant_String_Done:
03BA 22         150       ret  
03BB            151   
03BB            152   ;---------------------------------;
03BB            153   ; Set LCD cursor at row, column   ;
03BB            154   ;---------------------------------;
                155   Set_Cursor mac
                156   	push acc
                157   	mov a, #%1
                158   	dec a
                159   	lcall ?Set_Cursor_%0 ; Select column and row
                160   	pop acc
                161   endmac
03BB            162   
03BB            163   ?Set_Cursor_2:
03BB 4440       164            orl a, #01000000B
03BD            165   ?Set_Cursor_1:
03BD 4480       166            orl a, #10000000B
03BF 020378     167            ljmp ?WriteCommand ; Select column and row
03C2            168   
03C2            169   ;---------------------------------;
03C2            170   ; Display a BCD number in the LCD ;
03C2            171   ;---------------------------------;
                172   Display_BCD mac
                173   	push ar0
                174   	mov r0, %0
                175   	lcall ?Display_BCD
                176   	pop ar0
                177   endmac
03C2            178   
03C2            179   ?Display_BCD:
03C2 C0E0       180            push acc
03C4            181            ; Write most significant digit
03C4 E8         182            mov a, r0
03C5 C4         183            swap a
03C6 540F       184            anl a, #0fh
03C8 4430       185            orl a, #30h
03CA 120373     186            lcall ?WriteData
03CD            187            ; write least significant digit
03CD E8         188            mov a, r0
03CE 540F       189            anl a, #0fh
03D0 4430       190            orl a, #30h
03D2 120373     191            lcall ?WriteData
03D5 D0E0       192            pop acc
03D7 22         193            ret
03D8            194   
03D8            195   ;------------------------------------;
03D8            196   ; Display a char in the LCD          ;
03D8            197   ;------------------------------------;
                198   Display_char mac
                199   	push acc
                200   	mov a, %0
                201   	lcall ?WriteData
                202   	pop acc
                203   endmac
03D8            204   
                 -1   	$include(keypad_lib_3.asm)
03D8              1   
03D8              2   CSEG
03D8              3   
03D8              4   ;--------------------------------------------------
03D8              5   ; Lookup table for 7-segment display patterns (common anode)
03D8              6   ; Index 0-F = segment pattern
03D8              7   ;--------------------------------------------------
03D8              8   
03D8              9   myLUT:
03D8 C0F9A4B0    10       DB 0C0h, 0F9h, 0A4h, 0B0h, 099h        ; digits 0-4
     99
03DD 9282F880    11       DB 092h, 082h, 0F8h, 080h, 090h        ; digits 5-9
     90
03E2 8883C6A1    12       DB 088h, 083h, 0C6h, 0A1h, 086h, 08Eh  ; A-F
     868E
03E8             13   
03E8             14   ;--------------------------------------------------
03E8             15   ; Macro: showBCD
03E8             16   ; Input : one byte containing two BCD digits
03E8             17   ; Output: two 7-seg displays
03E8             18   ;   %0 = bcd byte
03E8             19   ;   %1 = HEX low
03E8             20   ;   %2 = HEX high
03E8             21   ;--------------------------------------------------
03E8             22   
                 23   showBCD MAC
                 24       ; ---- Display lower nibble (LSD) ----
                 25       mov  A, %0           ; Load BCD byte
                 26       anl  A, #0Fh         ; Keep lower 4 bits
                 27       movc A, @A+dptr      ; Convert using LUT
                 28       mov  %1, A           ; Output to first HEX display
                 29   
                 30       ; ---- Display upper nibble (MSD) ----
                 31       mov  A, %0
                 32       swap A               ; Swap nibbles
                 33       anl  A, #0Fh
                 34       movc A, @A+dptr
                 35       mov  %2, A           ; Output to second HEX display
                 36   ENDMAC
03E8             37   
03E8             38   
03E8             39   ;--------------------------------------------------
03E8             40   ; Display routine - show BCD number on HEX displays
03E8             41   ; KEY3: 0 = show high digits, 1 = show low digits
03E8             42   ; LEDRA.7: overflow indicator if bcd+3 or bcd+4 != 0
03E8             43   ;--------------------------------------------------
03E8             44   
03E8             45   Display:
03E8 9003D8      46       mov dptr, #myLUT     ; Point to lookup table
03EB             47   
03EB             48       ; If digits 10-7 (bcd+3 and bcd+4) are NOT zero
03EB             49       ; turn ON LEDRA.7 as overflow indicator
03EB             50   
03EB E53B        51       mov A, bcd+3
03ED 453C        52       orl A, bcd+4
03EF 6004        53       jz  Display_L1
03F1 D2EF        54       setb LEDRA.7         ; Alert LED on
03F3 8002        55       sjmp Display_L2
03F5             56   Display_L1:
03F5 C2EF        57       clr LEDRA.7          ; Alert LED off
03F7             58   Display_L2:
03F7             59   
03F7             60       ; If KEY3 pressed (assuming active low) show HIGH digits
03F7             61       ; Otherwise show LOW digits
03F7             62   
03F7 30FB2F      63       jnb KEY.3, Display_high_digits
03FA             64   
03FA             65       ; Show lower 6 digits
03FA             66       ; ---- Display lower nibble (LSD) ----
03FA E538        66       mov  A, bcd+0           ; Load BCD byte
03FC 540F        66       anl  A, #0Fh         ; Keep lower 4 bits
03FE 93          66       movc A, @A+dptr      ; Convert using LUT
03FF F591        66       mov  HEX0, A           ; Output to first HEX display
0401             66   
0401             66       ; ---- Display upper nibble (MSD) ----
0401 E538        66       mov  A, bcd+0
0403 C4          66       swap A               ; Swap nibbles
0404 540F        66       anl  A, #0Fh
0406 93          66       movc A, @A+dptr
0407 F592        66       mov  HEX1, A           ; Output to second HEX display
0409             67       ; ---- Display lower nibble (LSD) ----
0409 E539        67       mov  A, bcd+1           ; Load BCD byte
040B 540F        67       anl  A, #0Fh         ; Keep lower 4 bits
040D 93          67       movc A, @A+dptr      ; Convert using LUT
040E F593        67       mov  HEX2, A           ; Output to first HEX display
0410             67   
0410             67       ; ---- Display upper nibble (MSD) ----
0410 E539        67       mov  A, bcd+1
0412 C4          67       swap A               ; Swap nibbles
0413 540F        67       anl  A, #0Fh
0415 93          67       movc A, @A+dptr
0416 F594        67       mov  HEX3, A           ; Output to second HEX display
0418             68       ; ---- Display lower nibble (LSD) ----
0418 E53A        68       mov  A, bcd+2           ; Load BCD byte
041A 540F        68       anl  A, #0Fh         ; Keep lower 4 bits
041C 93          68       movc A, @A+dptr      ; Convert using LUT
041D F58E        68       mov  HEX4, A           ; Output to first HEX display
041F             68   
041F             68       ; ---- Display upper nibble (MSD) ----
041F E53A        68       mov  A, bcd+2
0421 C4          68       swap A               ; Swap nibbles
0422 540F        68       anl  A, #0Fh
0424 93          68       movc A, @A+dptr
0425 F58F        68       mov  HEX5, A           ; Output to second HEX display
0427 8024        69       sjmp Display_end
0429             70   
0429             71   Display_high_digits:
0429             72       ; Show upper 4 digits
0429             73       ; ---- Display lower nibble (LSD) ----
0429 E53B        73       mov  A, bcd+3           ; Load BCD byte
042B 540F        73       anl  A, #0Fh         ; Keep lower 4 bits
042D 93          73       movc A, @A+dptr      ; Convert using LUT
042E F591        73       mov  HEX0, A           ; Output to first HEX display
0430             73   
0430             73       ; ---- Display upper nibble (MSD) ----
0430 E53B        73       mov  A, bcd+3
0432 C4          73       swap A               ; Swap nibbles
0433 540F        73       anl  A, #0Fh
0435 93          73       movc A, @A+dptr
0436 F592        73       mov  HEX1, A           ; Output to second HEX display
0438             74       ; ---- Display lower nibble (LSD) ----
0438 E53C        74       mov  A, bcd+4           ; Load BCD byte
043A 540F        74       anl  A, #0Fh         ; Keep lower 4 bits
043C 93          74       movc A, @A+dptr      ; Convert using LUT
043D F593        74       mov  HEX2, A           ; Output to first HEX display
043F             74   
043F             74       ; ---- Display upper nibble (MSD) ----
043F E53C        74       mov  A, bcd+4
0441 C4          74       swap A               ; Swap nibbles
0442 540F        74       anl  A, #0Fh
0444 93          74       movc A, @A+dptr
0445 F594        74       mov  HEX3, A           ; Output to second HEX display
0447             75   
0447             76       ; Blank remaining displays
0447 758EFF      77       mov HEX4, #0FFh
044A 758FFF      78       mov HEX5, #0FFh
044D             79   
044D             80   Display_end:
044D 22          81       ret
044E             82   
044E             83   ;--------------------------------------------------
044E             84   ; Macro: Rotate Left through Carry
044E             85   ;--------------------------------------------------
044E             86   
                 87   MYRLC MAC
                 88       mov A, %0
                 89       rlc A
                 90       mov %0, A
                 91   ENDMAC
044E             92   
044E             93   ;--------------------------------------------------
044E             94   ; Shift all BCD digits LEFT by 4 bits
044E             95   ; Makes room for new digit in LSD (R7)
044E             96   ;--------------------------------------------------
044E             97   
044E             98   Shift_Digits_Left:
044E 7804        99       mov R0, #4           ; 4 bit shifts (one nibble)
0450            100   
0450            101   Shift_Digits_Left_L0:
0450 C3         102       clr C                ; Clear carry before shift
0451 E538       103       mov A, bcd+0
0453 33         103       rlc A
0454 F538       103       mov bcd+0, A
0456 E539       104       mov A, bcd+1
0458 33         104       rlc A
0459 F539       104       mov bcd+1, A
045B E53A       105       mov A, bcd+2
045D 33         105       rlc A
045E F53A       105       mov bcd+2, A
0460 E53B       106       mov A, bcd+3
0462 33         106       rlc A
0463 F53B       106       mov bcd+3, A
0465 E53C       107       mov A, bcd+4
0467 33         107       rlc A
0468 F53C       107       mov bcd+4, A
046A D8E4       108       djnz R0, Shift_Digits_Left_L0
046C            109   
046C            110       ; Insert new digit from R7 into lowest nibble safely
046C            111       ; Keep upper nibble of bcd+0 unchanged
046C 5338F0     112       anl  bcd+0, #0F0h    ; clear lower nibble
046F EF         113       mov  A, R7
0470 540F       114       anl  A, #0Fh         ; ensure only 0-F
0472 4238       115       orl  bcd+0, A
0474 22         116       ret
0475            117   
0475            118   ;--------------------------------------------------
0475            119   ; Macro: Rotate Right through Carry
0475            120   ;--------------------------------------------------
0475            121   
                122   MYRRC MAC
                123       mov A, %0
                124       rrc A
                125       mov %0, A
                126   ENDMAC
0475            127   
0475            128   ;--------------------------------------------------
0475            129   ; Shift digits RIGHT by 4 bits
0475            130   ; Used for BACKSPACE (delete last digit)
0475            131   ;--------------------------------------------------
0475            132   
0475            133   Shift_Digits_Right:
0475 7804       134       mov R0, #4
0477            135   
0477            136   Shift_Digits_Right_L0:
0477 C3         137       clr C
0478 E53C       138       mov A, bcd+4
047A 13         138       rrc A
047B F53C       138       mov bcd+4, A
047D E53B       139       mov A, bcd+3
047F 13         139       rrc A
0480 F53B       139       mov bcd+3, A
0482 E53A       140       mov A, bcd+2
0484 13         140       rrc A
0485 F53A       140       mov bcd+2, A
0487 E539       141       mov A, bcd+1
0489 13         141       rrc A
048A F539       141       mov bcd+1, A
048C E538       142       mov A, bcd+0
048E 13         142       rrc A
048F F538       142       mov bcd+0, A
0491 D8E4       143       djnz R0, Shift_Digits_Right_L0
0493 22         144       ret
0494            145   
0494            146   
0494            147   ;--------------------------------------------------
0494            148   ; 25 ms delay (software debounce)
0494            149   ;--------------------------------------------------
0494            150   
0494            151   Wait25ms:
0494 780F       152       mov R0, #15
0496 794A       153   L6: mov R1, #74
0498 7AFA       154   L5: mov R2, #250
049A DAFE       155   L4: djnz R2, L4
049C D9FA       156       djnz R1, L5
049E D8F6       157       djnz R0, L6
04A0 22         158       ret
04A1            159   
04A1            160   
04A1            161   ;--------------------------------------------------
04A1            162   ; Helper routines for parameter storage
04A1            163   ; Each parameter value lives in bcd+0..bcd+1
04A1            164   ; active_param: 0=A, 1=B, 2=C, 3=D
04A1            165   ;--------------------------------------------------
04A1            166   
04A1            167   ; Save current BCD (bcd+0..bcd+1) into active parameter
04A1            168   Save_Current_BCD_Into_Param:
04A1 E564       169       mov A, active_param
04A3 B40007     170       cjne A, #0, Save_NotA
04A6            171       ; A: soak_temp
04A6 853858     172       mov soak_temp+0, bcd+0
04A9 853959     173       mov soak_temp+1, bcd+1
04AC 22         174       ret
04AD            175   Save_NotA:
04AD B40107     176       cjne A, #1, Save_NotB
04B0            177       ; B: soak_time
04B0 85385A     178       mov soak_time+0, bcd+0
04B3 85395B     179       mov soak_time+1, bcd+1
04B6 22         180       ret
04B7            181   Save_NotB:
04B7 B40207     182       cjne A, #2, Save_NotC
04BA            183       ; C: reflow_temp
04BA 85385E     184       mov reflow_temp+0, bcd+0
04BD 85395F     185       mov reflow_temp+1, bcd+1
04C0 22         186       ret
04C1            187   Save_NotC:
04C1            188       ; D: reflow_time (default case)
04C1 853860     189       mov reflow_time+0, bcd+0
04C4 853961     190       mov reflow_time+1, bcd+1
04C7 22         191       ret
04C8            192   
04C8            193   
04C8            194   ; Load active parameter into BCD (bcd+0..bcd+1)
04C8            195   ; Clear the higher digits.
04C8            196   Load_Param_Into_BCD:
04C8 753A00     197       mov bcd+2, #00h
04CB 753B00     198       mov bcd+3, #00h
04CE 753C00     199       mov bcd+4, #00h
04D1            200   
04D1 E564       201       mov A, active_param
04D3 B40007     202       cjne A, #0, Load_NotA
04D6            203       ; A: soak_temp
04D6 855838     204       mov bcd+0, soak_temp
04D9 855939     205       mov bcd+1, soak_temp+1
04DC 22         206       ret
04DD            207   Load_NotA:
04DD B40107     208       cjne A, #1, Load_NotB
04E0            209       ; B: soak_time
04E0 855A38     210       mov bcd+0, soak_time
04E3 855B39     211       mov bcd+1, soak_time+1
04E6 22         212       ret
04E7            213   Load_NotB:
04E7 B40207     214       cjne A, #2, Load_NotC
04EA            215       ; C: reflow_temp
04EA 855E38     216       mov bcd+0, reflow_temp
04ED 855F39     217       mov bcd+1, reflow_temp+1
04F0 22         218       ret
04F1            219   Load_NotC:
04F1            220       ; D: reflow_time (default)
