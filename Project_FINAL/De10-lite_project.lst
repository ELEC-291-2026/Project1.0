094F             97   ;---------------------------------;
094F             98   ; Routine to initialize the ISR   ;
094F             99   ; for timer 0                     ;
094F            100   ;---------------------------------;
094F            101   Timer0_Init:
094F E589       102            mov a, TMOD
0951 54F0       103            anl a, #0xf0 ; 11110000 Clear the bits for timer 0
0953 4401       104            orl a, #0x01 ; 00000001 Configure timer 0 as 16-timer
0955 F589       105            mov TMOD, a
0957            106            
0957 758CF5     107            mov TH0, #high(TIMER0_RELOAD)
095A 758A68     108            mov TL0, #low(TIMER0_RELOAD)
095D            109            
095D            110            ; Enable the timer and interrupts
095D D2A9       111       setb ET0  ; Enable timer 0 interrupt
095F D28C       112       setb TR0  ; Start timer 0
0961 22         113            ret
0962            114   
0962            115   ;---------------------------------;
0962            116   ; ISR for timer 0.  Runs every ms ;
0962            117   ;---------------------------------;
0962            118   Timer0_ISR:
0962 C28C       119            clr TR0
0964 758CF5     120            mov TH0, #high(TIMER0_RELOAD)
0967 758A68     121            mov TL0, #low(TIMER0_RELOAD)
096A D28C       122            setb TR0
096C            123            
096C            124            ; Increment the timers for each FSM. That is all we do here!
096C 0565       125            inc FSM_timer 
096E            126            
096E E565       127            mov a, FSM_timer
0970 B4FA1D     128            cjne a, #250, FSM_timer_done
0973            129            
0973 D203       130            setb QuarterSecondsFlag
0975            131            
0975 0566       132            inc QuarterSecondsCounter
0977 756500     133            mov FSM_timer, #0x00
097A            134            
097A E566       135            mov a, QuarterSecondsCounter
097C B40411     136            cjne a, #4, FSM_timer_done
097F            137            
097F 756600     138            mov QuarterSecondsCounter, #0x00
0982 0567       139            inc SecondsCounter
0984 0568       140            inc SecondsCounterTotal ; USE THIS FOR THE TOTAL TIMER. IT NEVER RESETS SO DONT WORRY
0986            141            
0986 E568       142            mov a, SecondsCounterTotal
0988 B43C05     143            cjne a, #60, FSM_timer_done
098B 0569       144            inc MinutesCounterTotal
098D 756800     145            mov SecondsCounterTotal, #0x00
0990            146            
0990            147   FSM_timer_done:
0990 32         148            reti
