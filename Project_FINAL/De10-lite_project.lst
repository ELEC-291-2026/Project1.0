093F              3   ; Variables
0030              4   dseg at 0x30
0030              5   tone_rh:      ds 1   ; Timer0 reload high byte for current note
0031              6   tone_rl:      ds 1   ; Timer0 reload low byte for current note
0032              7   songCounter:  ds 1
