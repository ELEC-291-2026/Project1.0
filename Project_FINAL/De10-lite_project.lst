                 -1   $include(LCD_4bit_DE10Lite_no_RW.inc) ; A library of LCD related functions and utility macros
030B              1   ;  LCD routines adapted for the DE10-Lite configured as a CV_8052 processor
030B              2   cseg
030B              3   
030B              4   ; When using a 33.333333MHz crystal clock
030B              5   ; one cycle takes 1.0/33.333333MHz = 30 ns
030B              6   
030B              7   ;---------------------------------;
030B              8   ; Wait 40 microseconds            ;
030B              9   ;---------------------------------;
030B             10   Wait40uSec:
030B C000        11            push AR0
030D 78BE        12            mov R0, #190
030F             13   L0: 
030F 00          14            nop
0310 00          15            nop
0311 00          16            nop
0312 00          17            nop
0313 D8FA        18            djnz R0, L0 ; 1+1+1+1+3 cycles->7*30ns*190=40us
0315 D000        19            pop AR0
0317 22          20       ret
0318             21   
0318             22   ;---------------------------------;
0318             23   ; Wait 'R2' milliseconds          ;
0318             24   ;---------------------------------;
                 25   Wait_Milli_Seconds mac
                 26   	push AR2
                 27   	mov R2, %0
                 28   	lcall ?Wait_Milli_Seconds
                 29   	pop AR2
                 30   endmac
0318             31   
0318             32   ?Wait_Milli_Seconds:
0318 C000        33            push AR0
031A C001        34            push AR1
031C 7932        35   L3: mov R1, #50
031E 78DF        36   L2: mov R0, #223
0320 D8FE        37   L1: djnz R0, L1 ; 3 cycles->3*30ns*250=20.07us
0322 D9FA        38       djnz R1, L2 ; 20.07us*50=1.004ms
0324 DAF6        39       djnz R2, L3 ; number of millisecons to wait passed in R2
0326 D001        40       pop AR1
0328 D000        41       pop AR0
032A 22          42       ret
032B             43            
032B             44   ;---------------------------------;
032B             45   ; Toggles the 'E' pin in the LCD  ;
032B             46   ;---------------------------------;
032B             47   ELCD_pulse:
032B D291        48            setb ELCD_E
032D 12030B      49            lcall Wait40uSec
0330 C291        50            clr ELCD_E
0332 12030B      51       lcall Wait40uSec ; This line is needed in the DE1SoC running an 8051 because it is much faster than the AT89LP51RC2
0335 22          52       ret
0336             53   
0336             54   ;---------------------------------;
0336             55   ; Writes acc to LCD in 4-bit mode ;
0336             56   ;---------------------------------;
0336             57   ELCD_byte:
0336             58            ; Write high 4 bits first
0336 A2E7        59            mov c, ACC.7
0338 9281        60            mov ELCD_D7, c
033A A2E6        61            mov c, ACC.6
033C 9283        62            mov ELCD_D6, c
033E A2E5        63            mov c, ACC.5
0340 9285        64            mov ELCD_D5, c
0342 A2E4        65            mov c, ACC.4
0344 9287        66            mov ELCD_D4, c
0346 12032B      67       lcall ELCD_pulse
0349             68            ; Write low 4 bits next
0349 A2E3        69            mov c, ACC.3
034B 9281        70            mov ELCD_D7, c
034D A2E2        71            mov c, ACC.2
034F 9283        72            mov ELCD_D6, c
0351 A2E1        73            mov c, ACC.1
0353 9285        74            mov ELCD_D5, c
0355 A2E0        75            mov c, ACC.0
0357 9287        76            mov ELCD_D4, c
0359 12032B      77       lcall ELCD_pulse
035C 22          78            ret
035D             79   
035D             80   ;---------------------------------;
035D             81   ; Write data to LCD               ;
035D             82   ;---------------------------------;
                 83   WriteData mac
                 84   	mov a, %0
                 85   	lcall ?WriteData
                 86   endmac
035D             87            
035D             88   ?WriteData:
035D D297        89            setb ELCD_RS
035F 020336      90            ljmp ELCD_byte
0362             91   
0362             92   ;---------------------------------;
0362             93   ; Write command to LCD            ;
0362             94   ;---------------------------------;
                 95   WriteCommand mac
                 96   	mov a, %0
                 97   	lcall ?WriteCommand
                 98   endmac
0362             99   
0362            100   ?WriteCommand:
0362 C297       101            clr ELCD_RS
0364 020336     102            ljmp ELCD_byte
0367            103   
0367            104   ;---------------------------------;
0367            105   ; Configure LCD in 4-bit mode     ;
0367            106   ;---------------------------------;
0367            107   ELCD_4BIT:
0367 C291       108            clr ELCD_E   ; Resting state of LCD's enable pin is zero
0369            109            ;clr ELCD_RW  ; RW forced to zero
0369            110            
0369            111            ; After power on, let the LCD start up before initializing
0369 C002       112            push AR2
036B 7A28       112            mov R2, #40
036D 120318     112            lcall ?Wait_Milli_Seconds
0370 D002       112            pop AR2
0372            113            
0372            114            ; First make sure the LCD is in 8-bit mode and then change to 4-bit mode
0372 7433       115            mov a, #0x33
0374 120362     115            lcall ?WriteCommand
0377 7433       116            mov a, #0x33
0379 120362     116            lcall ?WriteCommand
037C 7432       117            mov a, #0x32
037E 120362     117            lcall ?WriteCommand ; change to 4-bit mode
0381            118   
0381            119            ; Configure the LCD
0381 7428       120            mov a, #0x28
0383 120362     120            lcall ?WriteCommand
0386 740C       121            mov a, #0x0c
0388 120362     121            lcall ?WriteCommand
038B 7401       122            mov a, #0x01
038D 120362     122            lcall ?WriteCommand ;  Clear screen command (takes some time)
0390            123   
0390            124       ;Wait for the clear screen command to finish.
0390 C002       125            push AR2
0392 7A02       125            mov R2, #2
0394 120318     125            lcall ?Wait_Milli_Seconds
0397 D002       125            pop AR2
0399 22         126       ret
039A            127   
039A            128   ;---------------------------------;
039A            129   ; Send a constant string to LCD   ;
039A            130   ;---------------------------------;
                131   Send_Constant_String mac
                132   	push dph
                133   	push dpl
                134   	push acc
                135   	mov dptr, %0
                136   	lcall ?Send_Constant_String
                137   	pop acc
                138   	pop dpl
                139   	pop dph
                140   endmac
039A            141   
039A            142   ?Send_Constant_String:
039A E4         143       clr a
039B 93         144       movc a, @a+dptr
039C 6006       145       jz ?Send_Constant_String_Done
039E 12035D     146       lcall ?WriteData
03A1 A3         147       inc dptr
03A2 80F6       148       sjmp ?Send_Constant_String
03A4            149   ?Send_Constant_String_Done:
03A4 22         150       ret  
03A5            151   
03A5            152   ;---------------------------------;
03A5            153   ; Set LCD cursor at row, column   ;
03A5            154   ;---------------------------------;
                155   Set_Cursor mac
                156   	push acc
                157   	mov a, #%1
                158   	dec a
                159   	lcall ?Set_Cursor_%0 ; Select column and row
                160   	pop acc
                161   endmac
03A5            162   
03A5            163   ?Set_Cursor_2:
03A5 4440       164            orl a, #01000000B
03A7            165   ?Set_Cursor_1:
03A7 4480       166            orl a, #10000000B
03A9 020362     167            ljmp ?WriteCommand ; Select column and row
03AC            168   
03AC            169   ;---------------------------------;
03AC            170   ; Display a BCD number in the LCD ;
03AC            171   ;---------------------------------;
                172   Display_BCD mac
                173   	push ar0
                174   	mov r0, %0
                175   	lcall ?Display_BCD
                176   	pop ar0
                177   endmac
03AC            178   
03AC            179   ?Display_BCD:
03AC C0E0       180            push acc
03AE            181            ; Write most significant digit
03AE E8         182            mov a, r0
03AF C4         183            swap a
03B0 540F       184            anl a, #0fh
03B2 4430       185            orl a, #30h
03B4 12035D     186            lcall ?WriteData
03B7            187            ; write least significant digit
03B7 E8         188            mov a, r0
03B8 540F       189            anl a, #0fh
03BA 4430       190            orl a, #30h
03BC 12035D     191            lcall ?WriteData
03BF D0E0       192            pop acc
03C1 22         193            ret
03C2            194   
03C2            195   ;------------------------------------;
03C2            196   ; Display a char in the LCD          ;
03C2            197   ;------------------------------------;
                198   Display_char mac
                199   	push acc
                200   	mov a, %0
                201   	lcall ?WriteData
                202   	pop acc
                203   endmac
