0947            322   
0947            323   ; The 8-bit hex number passed in the accumulator is converted to
0947            324   ; BCD and stored in [R1, R0]
0947            325   Hex_to_bcd_8bit:
0947 75F064     326            mov b, #100
094A 84         327            div ab
094B F9         328            mov R1, a   ; After dividing, a has the 100s
094C E5F0       329            mov a, b    ; Remainder is in register b
094E 75F00A     330            mov b, #10
0951 84         331            div ab ; The tens are stored in a, the units are stored in b 
0952 C4         332            swap a
0953 54F0       333            anl a, #0xf0
0955 45F0       334            orl a, b
0957 F8         335            mov R0, a
0958 22         336            ret
