04ED            264   ;--------------------------------------------------
04ED            265   ; Keypad scanning routine
04ED            266   ; Output:
04ED            267   ;   C = 1 -> numeric key pressed, code in R7 (0-9, maybe E/F)
04ED            268   ;   C = 0 -> no digit (no key, mode key, or backspace)
04ED            269   ;--------------------------------------------------
04ED            270   
04ED            271   Keypad:
04ED            272   
04ED            273       ; KEY1 acts as BACKSPACE / ERASE
04ED            274   
04ED 20F90E     275       jb  KEY.1, keypad_L0     ; if KEY1=1 (not pressed) -> skip
04F0 12047C     276       lcall Wait25ms
04F3 20F908     277       jb  KEY.1, keypad_L0     ; if bounced back high, skip
04F6 30F9FD     278       jnb KEY.1, $             ; wait for release (KEY1 low while pressed)
04F9 12045D     279       lcall Shift_Digits_Right ; delete LSD for active parameter
04FC C3         280       clr C                    ; no digit returned
04FD 22         281       ret
04FE            282   
04FE            283   keypad_L0:
04FE            284   
04FE            285       ; Drive all rows LOW - check if any column LOW
04FE            286   
04FE C292       287       clr ROW1
0500 C294       288       clr ROW2
0502 C296       289       clr ROW3
0504 C2A0       290       clr ROW4
0506            291   
0506 A2A2       292       mov C, COL1
0508 82A4       293       anl C, COL2
050A 82A6       294       anl C, COL3
050C 82B0       295       anl C, COL4
050E 5002       296       jnc Keypad_Debounce      ; if any column low -> possible key
0510 C3         297       clr C
0511 22         298       ret
0512            299   
0512            300   Keypad_Debounce:
0512            301       ; Wait and check again to avoid bouncing
0512 12047C     302       lcall Wait25ms
0515            303   
0515 A2A2       304       mov C, COL1
0517 82A4       305       anl C, COL2
0519 82A6       306       anl C, COL3
051B 82B0       307       anl C, COL4
051D 5002       308       jnc Keypad_Key_Code
051F C3         309       clr C
0520 22         310       ret
