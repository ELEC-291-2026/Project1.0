0B1A            190   ;---------------------------------;
0B1A            191   ; Routine to initialize the ISR   ;
0B1A            192   ; for timer 0                     ;
0B1A            193   ;---------------------------------;
0B1A            194   Timer0_Init:
0B1A E589       195            mov a, TMOD
0B1C 54F0       196            anl a, #0xf0 ; 11110000 Clear the bits for timer 0
0B1E 4401       197            orl a, #0x01 ; 00000001 Configure timer 0 as 16-timer
0B20 F589       198            mov TMOD, a
0B22            199            
0B22 85668C     200            mov TH0, Timer0Reload+1
0B25 85658A     201            mov TL0, Timer0Reload+0
0B28            202            
0B28            203            ; Enable the timer and interrupts
0B28 D2A9       204       setb ET0  ; Enable timer 0 interrupt
0B2A D28C       205       setb TR0  ; Start timer 0
0B2C 22         206            ret
0B2D            207   
0B2D            208   ;---------------------------------;
0B2D            209   ; ISR for timer 0.  Set to execute;
0B2D            210   ; every 1/4096Hz to generate a    ;
0B2D            211   ; 2048 Hz wave at pin SOUND_OUT   ;
0B2D            212   ;---------------------------------;
0B2D            213   
0B2D            214   Timer0_ISR:
0B2D C28C       215            clr TR0
0B2F 85668C     216            mov TH0, Timer0Reload+1
0B32 85658A     217            mov TL0, Timer0Reload+0
0B35 D28C       218            setb TR0
0B37 B284       219            cpl SOUND_OUT ; Connect speaker the pin assigned to 'SOUND_OUT'!
0B39 32         220            reti
0B3A            221   
0B3A            222   ;---------------------------------;
0B3A            223   ; Routine to initialize the ISR   ;
0B3A            224   ; for timer 2                     ;
0B3A            225   ;---------------------------------;
0B3A            226   Timer2_Init:
0B3A 75C800     227            mov T2CON, #0 ; Stop timer/counter.  Autoreload mode.
0B3D 75CDF5     228            mov TH2, #high(TIMER2_RELOAD)
0B40 75CC27     229            mov TL2, #low(TIMER2_RELOAD)
0B43            230            ; Set the reload value
0B43 75CBF5     231            mov RCAP2H, #high(TIMER2_RELOAD)
0B46 75CA27     232            mov RCAP2L, #low(TIMER2_RELOAD)
0B49            233            ; Enable the timer and interrupts
0B49 D2AD       234       setb ET2  ; Enable timer 2 interrupt
0B4B D2CA       235       setb TR2  ; Enable timer 2
0B4D            236       
0B4D 22         237            ret
0B4E            238   
0B4E            239   ;---------------------------------;
0B4E            240   ; ISR for timer 2.  Runs every ms ;
0B4E            241   ;---------------------------------;
0B4E            242   
0B4E            243   Timer2_ISR:
0B4E            244   
0B4E C2CF       245            clr TF2  ; Timer 2 doesn't clear TF2 automatically. Do it in ISR
0B50            246            ; Increment the timers for each FSM. That is all we do here!
0B50 0567       247            inc FSM_timer 
0B52            248            
0B52 E567       249            mov a, FSM_timer
0B54 B4FA1D     250            cjne a, #250, FSM_timer_done
0B57            251            
0B57 D203       252            setb QuarterSecondsFlag
0B59            253            
0B59 0568       254            inc QuarterSecondsCounter
0B5B 756700     255            mov FSM_timer, #0x00
0B5E            256            
0B5E E568       257            mov a, QuarterSecondsCounter
0B60 B40411     258            cjne a, #4, FSM_timer_done
0B63            259            
0B63 756800     260            mov QuarterSecondsCounter, #0x00
0B66 0569       261            inc SecondsCounter
0B68 056A       262            inc SecondsCounterTotal ; USE THIS FOR THE TOTAL TIMER. IT NEVER RESETS SO DONT WORRY
0B6A            263            
0B6A E56A       264            mov a, SecondsCounterTotal
0B6C B43C05     265            cjne a, #60, FSM_timer_done
0B6F 056B       266            inc MinutesCounterTotal
0B71 756A00     267            mov SecondsCounterTotal, #0x00
0B74            268            
