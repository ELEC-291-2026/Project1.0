04A0            161   ;--------------------------------------------------
04A0            162   ; Helper routines for parameter storage
04A0            163   ; Each parameter value lives in bcd+0..bcd+1
04A0            164   ; active_param: 0=A, 1=B, 2=C, 3=D
04A0            165   ;--------------------------------------------------
04A0            166   
04A0            167   ; Save current BCD (bcd+0..bcd+1) into active parameter
04A0            168   Save_Current_BCD_Into_Param:
04A0 E564       169       mov A, active_param
04A2 B40007     170       cjne A, #0, Save_NotA
04A5            171       ; A: soak_temp
04A5 853858     172       mov soak_temp+0, bcd+0
04A8 853959     173       mov soak_temp+1, bcd+1
04AB 22         174       ret
04AC            175   Save_NotA:
04AC B40107     176       cjne A, #1, Save_NotB
04AF            177       ; B: soak_time
04AF 85385A     178       mov soak_time+0, bcd+0
04B2 85395B     179       mov soak_time+1, bcd+1
04B5 22         180       ret
04B6            181   Save_NotB:
04B6 B40207     182       cjne A, #2, Save_NotC
04B9            183       ; C: reflow_temp
04B9 85385E     184       mov reflow_temp+0, bcd+0
04BC 85395F     185       mov reflow_temp+1, bcd+1
04BF 22         186       ret
04C0            187   Save_NotC:
04C0            188       ; D: reflow_time (default case)
04C0 853860     189       mov reflow_time+0, bcd+0
04C3 853961     190       mov reflow_time+1, bcd+1
04C6 22         191       ret
04C7            192   
04C7            193   
04C7            194   ; Load active parameter into BCD (bcd+0..bcd+1)
04C7            195   ; Clear the higher digits.
04C7            196   Load_Param_Into_BCD:
04C7 753A00     197       mov bcd+2, #00h
04CA 753B00     198       mov bcd+3, #00h
04CD 753C00     199       mov bcd+4, #00h
04D0            200   
04D0 E564       201       mov A, active_param
04D2 B40007     202       cjne A, #0, Load_NotA
04D5            203       ; A: soak_temp
04D5 855838     204       mov bcd+0, soak_temp
04D8 855939     205       mov bcd+1, soak_temp+1
04DB 22         206       ret
04DC            207   Load_NotA:
04DC B40107     208       cjne A, #1, Load_NotB
04DF            209       ; B: soak_time
04DF 855A38     210       mov bcd+0, soak_time
04E2 855B39     211       mov bcd+1, soak_time+1
04E5 22         212       ret
04E6            213   Load_NotB:
04E6 B40207     214       cjne A, #2, Load_NotC
04E9            215       ; C: reflow_temp
04E9 855E38     216       mov bcd+0, reflow_temp
04EC 855F39     217       mov bcd+1, reflow_temp+1
04EF 22         218       ret
04F0            219   Load_NotC:
04F0            220       ; D: reflow_time (default)
04F0 856038     221       mov bcd+0, reflow_time
04F3 856139     222       mov bcd+1, reflow_time+1
04F6 22         223       ret
04F7            224   
04F7            225   
04F7            226   ;--------------------------------------------------
04F7            227   ; Macro: Check one keypad column
04F7            228   ; If pressed -> R7 = key value, C=1, jump to Key_Found
04F7            229   ; %0 = column bit, %1 = key code (immediate)
04F7            230   ;--------------------------------------------------
04F7            231   
                232   CHECK_COLUMN MAC
                233       jb  %0, CHECK_COL_%M     ; if column=1 -> no key here -> skip
                234       mov R7, %1               ; store key code
                235       jnb %0, $                ; wait until key is released
                236       setb C                   ; mark "key found"
                237       ljmp Key_Found           ; use long jump instead of short
                238   CHECK_COL_%M:
                239   ENDMAC
04F7            240   
04F7            241   
04F7            242   ;--------------------------------------------------
04F7            243   ; Configure GPIO directions for keypad
04F7            244   ;--------------------------------------------------
04F7            245   
04F7            246   Configure_Keypad_Pins:
04F7 439B54     247       orl P1MOD, #01010100b    ; Rows as output on P1
04FA 439C01     248       orl P2MOD, #00000001b
04FD 539CAB     249       anl P2MOD, #10101011b    ; Columns as input on P2
0500 539DFE     250       anl P3MOD, #11111110b    ; Column on P3.0 input
0503 22         251       ret
0504            252   
0504            253   ; Pin definitions for keypad
0504            254   ROW1 EQU P1.2
0504            255   ROW2 EQU P1.4
0504            256   ROW3 EQU P1.6
0504            257   ROW4 EQU P2.0
0504            258   
0504            259   COL1 EQU P2.2
0504            260   COL2 EQU P2.4
0504            261   COL3 EQU P2.6
0504            262   COL4 EQU P3.0
0504            263   
0504            264   ;--------------------------------------------------
0504            265   ; Keypad scanning routine
0504            266   ; Output:
0504            267   ;   C = 1 -> numeric key pressed, code in R7 (0-9, maybe E/F)
0504            268   ;   C = 0 -> no digit (no key, mode key, or backspace)
0504            269   ;--------------------------------------------------
0504            270   
0504            271   Keypad:
0504            272   
0504            273       ; KEY1 acts as BACKSPACE / ERASE
0504            274   
0504 20F90E     275       jb  KEY.1, keypad_L0     ; if KEY1=1 (not pressed) -> skip
0507 120493     276       lcall Wait25ms
050A 20F908     277       jb  KEY.1, keypad_L0     ; if bounced back high, skip
050D 30F9FD     278       jnb KEY.1, $             ; wait for release (KEY1 low while pressed)
0510 120474     279       lcall Shift_Digits_Right ; delete LSD for active parameter
0513 C3         280       clr C                    ; no digit returned
0514 22         281       ret
0515            282   
0515            283   keypad_L0:
0515            284   
0515            285       ; Drive all rows LOW - check if any column LOW
0515            286   
0515 C292       287       clr ROW1
0517 C294       288       clr ROW2
0519 C296       289       clr ROW3
051B C2A0       290       clr ROW4
051D            291   
051D A2A2       292       mov C, COL1
051F 82A4       293       anl C, COL2
0521 82A6       294       anl C, COL3
0523 82B0       295       anl C, COL4
0525 5002       296       jnc Keypad_Debounce      ; if any column low -> possible key
0527 C3         297       clr C
0528 22         298       ret
0529            299   
0529            300   Keypad_Debounce:
0529            301       ; Wait and check again to avoid bouncing
0529 120493     302       lcall Wait25ms
052C            303   
052C A2A2       304       mov C, COL1
052E 82A4       305       anl C, COL2
0530 82A6       306       anl C, COL3
0532 82B0       307       anl C, COL4
0534 5002       308       jnc Keypad_Key_Code
0536 C3         309       clr C
0537 22         310       ret
0538            311   
0538            312   Keypad_Key_Code:
0538            313       ; Prepare to scan each row individually
0538 D292       314       setb ROW1
053A D294       315       setb ROW2
053C D296       316       setb ROW3
053E D2A0       317       setb ROW4
0540            318   
0540            319       ; SW0 selects layout orientation
0540 30E803     320       jnb SWA.0, keypad_default
0543 020618     321       ljmp keypad_90deg
0546            322   
0546            323   
0546            324   ;--------------------------------------------------
0546            325   ; Default keypad layout
0546            326   ;--------------------------------------------------
0546            327   ; Mapping (default):
0546            328   ;   Row1: 1  2  3  A (0Ah)
0546            329   ;   Row2: 4  5  6  B (0Bh)
0546            330   ;   Row3: 7  8  9  C (0Ch)
0546            331   ;   Row4: *  0  #  D (0Eh,00h,0Fh,0Dh)
0546            332   ;--------------------------------------------------
0546            333   
0546            334   keypad_default:
0546            335   
