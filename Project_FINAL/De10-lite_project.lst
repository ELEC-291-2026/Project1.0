04D7 855F39     217       mov bcd+1, reflow_temp+1
04DA 22         218       ret
04DB            219   Load_NotC:
04DB            220       ; D: reflow_time (default)
04DB 856038     221       mov bcd+0, reflow_time
04DE 856139     222       mov bcd+1, reflow_time+1
04E1 22         223       ret
04E2            224   
04E2            225   
04E2            226   ;--------------------------------------------------
04E2            227   ; Macro: Check one keypad column
04E2            228   ; If pressed -> R7 = key value, C=1, jump to Key_Found
04E2            229   ; %0 = column bit, %1 = key code (immediate)
04E2            230   ;--------------------------------------------------
04E2            231   
                232   CHECK_COLUMN MAC
                233       jb  %0, CHECK_COL_%M     ; if column=1 -> no key here -> skip
                234       mov R7, %1               ; store key code
                235       jnb %0, $                ; wait until key is released
                236       setb C                   ; mark "key found"
                237       ljmp Key_Found           ; use long jump instead of short
                238   CHECK_COL_%M:
                239   ENDMAC
04E2            240   
04E2            241   
04E2            242   ;--------------------------------------------------
04E2            243   ; Configure GPIO directions for keypad
04E2            244   ;--------------------------------------------------
04E2            245   
04E2            246   Configure_Keypad_Pins:
04E2 439B54     247       orl P1MOD, #01010100b    ; Rows as output on P1
04E5 439C01     248       orl P2MOD, #00000001b
04E8 539CAB     249       anl P2MOD, #10101011b    ; Columns as input on P2
04EB 539DFE     250       anl P3MOD, #11111110b    ; Column on P3.0 input
04EE 22         251       ret
04EF            252   
04EF            253   ; Pin definitions for keypad
04EF            254   ROW1 EQU P1.2
04EF            255   ROW2 EQU P1.4
04EF            256   ROW3 EQU P1.6
04EF            257   ROW4 EQU P2.0
04EF            258   
04EF            259   COL1 EQU P2.2
04EF            260   COL2 EQU P2.4
04EF            261   COL3 EQU P2.6
04EF            262   COL4 EQU P3.0
04EF            263   
04EF            264   ;--------------------------------------------------
04EF            265   ; Keypad scanning routine
04EF            266   ; Output:
04EF            267   ;   C = 1 -> numeric key pressed, code in R7 (0-9, maybe E/F)
04EF            268   ;   C = 0 -> no digit (no key, mode key, or backspace)
04EF            269   ;--------------------------------------------------
04EF            270   
04EF            271   Keypad:
04EF            272   
04EF            273       ; KEY1 acts as BACKSPACE / ERASE
04EF            274   
04EF 20F90E     275       jb  KEY.1, keypad_L0     ; if KEY1=1 (not pressed) -> skip
04F2 12047E     276       lcall Wait25ms
04F5 20F908     277       jb  KEY.1, keypad_L0     ; if bounced back high, skip
04F8 30F9FD     278       jnb KEY.1, $             ; wait for release (KEY1 low while pressed)
04FB 12045F     279       lcall Shift_Digits_Right ; delete LSD for active parameter
04FE C3         280       clr C                    ; no digit returned
04FF 22         281       ret
0500            282   
0500            283   keypad_L0:
0500            284   
0500            285       ; Drive all rows LOW - check if any column LOW
0500            286   
0500 C292       287       clr ROW1
0502 C294       288       clr ROW2
0504 C296       289       clr ROW3
0506 C2A0       290       clr ROW4
0508            291   
0508 A2A2       292       mov C, COL1
050A 82A4       293       anl C, COL2
050C 82A6       294       anl C, COL3
050E 82B0       295       anl C, COL4
0510 5002       296       jnc Keypad_Debounce      ; if any column low -> possible key
0512 C3         297       clr C
0513 22         298       ret
0514            299   
0514            300   Keypad_Debounce:
0514            301       ; Wait and check again to avoid bouncing
0514 12047E     302       lcall Wait25ms
0517            303   
0517 A2A2       304       mov C, COL1
0519 82A4       305       anl C, COL2
051B 82A6       306       anl C, COL3
051D 82B0       307       anl C, COL4
051F 5002       308       jnc Keypad_Key_Code
0521 C3         309       clr C
0522 22         310       ret
0523            311   
0523            312   Keypad_Key_Code:
0523            313       ; Prepare to scan each row individually
0523 D292       314       setb ROW1
0525 D294       315       setb ROW2
0527 D296       316       setb ROW3
0529 D2A0       317       setb ROW4
052B            318   
052B            319       ; SW0 selects layout orientation
052B 30E803     320       jnb SWA.0, keypad_default
052E 020603     321       ljmp keypad_90deg
