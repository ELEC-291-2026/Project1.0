0A07            259   ; The 8-bit hex number passed in the accumulator is converted to
0A07            260   ; BCD and stored in [R1, R0]
0A07            261   Hex_to_bcd_8bit:
0A07 75F064     262            mov b, #100
0A0A 84         263            div ab
0A0B F9         264            mov R1, a   ; After dividing, a has the 100s
0A0C E5F0       265            mov a, b    ; Remainder is in register b
0A0E 75F00A     266            mov b, #10
0A11 84         267            div ab ; The tens are stored in a, the units are stored in b 
0A12 C4         268            swap a
0A13 54F0       269            anl a, #0xf0
0A15 45F0       270            orl a, b
0A17 F8         271            mov R0, a
0A18 22         272            ret
