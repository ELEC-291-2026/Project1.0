08AF            103   ;----------------------FUNCTIONS----------------
08AF            104   ;---------------------------------;
08AF            105   ; Routine to initialize the ISR   ;
08AF            106   ; for timer 0                     ;
08AF            107   ;---------------------------------;
08AF            108   Timer0_Init:
08AF E589       109            mov a, TMOD
08B1 54F0       110            anl a, #0xf0 ; 11110000 Clear the bits for timer 0
08B3 4401       111            orl a, #0x01 ; 00000001 Configure timer 0 as 16-timer
08B5 F589       112            mov TMOD, a
08B7            113            
08B7 85668C     114            mov TH0, Timer0Reload+1
08BA 85658A     115            mov TL0, Timer0Reload+0
08BD            116            
08BD            117            ; Enable the timer and interrupts
08BD D2A9       118       setb ET0  ; Enable timer 0 interrupt
08BF D28C       119       setb TR0  ; Start timer 0
08C1 22         120            ret
08C2            121   
08C2            122   ;---------------------------------;
08C2            123   ; ISR for timer 0.  Set to execute;
08C2            124   ; every 1/4096Hz to generate a    ;
08C2            125   ; 2048 Hz wave at pin SOUND_OUT   ;
08C2            126   ;---------------------------------;
08C2            127   
08C2            128   Timer0_ISR:
08C2 C28C       129            clr TR0
08C4 85668C     130            mov TH0, Timer0Reload+1
08C7 85658A     131            mov TL0, Timer0Reload+0
08CA D28C       132            setb TR0
08CC B284       133            cpl SOUND_OUT ; Connect speaker the pin assigned to 'SOUND_OUT'!
08CE 32         134            reti
08CF            135   
08CF            136   ;---------------------------------;
08CF            137   ; Routine to initialize the ISR   ;
08CF            138   ; for timer 2                     ;
08CF            139   ;---------------------------------;
08CF            140   Timer2_Init:
08CF 75C800     141            mov T2CON, #0 ; Stop timer/counter.  Autoreload mode.
08D2 75CDF5     142            mov TH2, #high(TIMER2_RELOAD)
08D5 75CC27     143            mov TL2, #low(TIMER2_RELOAD)
08D8            144            ; Set the reload value
08D8 75CBF5     145            mov RCAP2H, #high(TIMER2_RELOAD)
08DB 75CA27     146            mov RCAP2L, #low(TIMER2_RELOAD)
08DE            147            ; Enable the timer and interrupts
08DE D2AD       148       setb ET2  ; Enable timer 2 interrupt
08E0 D2CA       149       setb TR2  ; Enable timer 2
08E2            150       
08E2 22         151            ret
08E3            152   
08E3            153   ;---------------------------------;
08E3            154   ; ISR for timer 2.  Runs every ms ;
08E3            155   ;---------------------------------;
08E3            156   
08E3            157   Timer2_ISR:
08E3            158   
08E3 C2CF       159            clr TF2  ; Timer 2 doesn't clear TF2 automatically. Do it in ISR
08E5            160            ; Increment the timers for each FSM. That is all we do here!
08E5 0567       161            inc FSM_timer 
08E7            162            
08E7 E567       163            mov a, FSM_timer
08E9 B4FA1D     164            cjne a, #250, FSM_timer_done
08EC            165            
08EC D203       166            setb QuarterSecondsFlag
08EE            167            
08EE 0568       168            inc QuarterSecondsCounter
08F0 756700     169            mov FSM_timer, #0x00
08F3            170            
08F3 E568       171            mov a, QuarterSecondsCounter
08F5 B40411     172            cjne a, #4, FSM_timer_done
08F8            173            
08F8 756800     174            mov QuarterSecondsCounter, #0x00
08FB 0569       175            inc SecondsCounter
08FD 056A       176            inc SecondsCounterTotal ; USE THIS FOR THE TOTAL TIMER. IT NEVER RESETS SO DONT WORRY
08FF            177            
08FF E56A       178            mov a, SecondsCounterTotal
0901 B43C05     179            cjne a, #60, FSM_timer_done
0904 056B       180            inc MinutesCounterTotal
0906 756A00     181            mov SecondsCounterTotal, #0x00
0909            182            
0909            183            FSM_timer_done:
0909 32         184            reti
