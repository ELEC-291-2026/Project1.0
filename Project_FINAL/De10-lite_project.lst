                614   $LIST
                 -1   $include(LCD_4bit_DE10Lite_no_RW.inc) ; A library of LCD related functions and utility macros
0320              1   ;  LCD routines adapted for the DE10-Lite configured as a CV_8052 processor
0320              2   cseg
0320              3   
0320              4   ; When using a 33.333333MHz crystal clock
0320              5   ; one cycle takes 1.0/33.333333MHz = 30 ns
0320              6   
0320              7   ;---------------------------------;
0320              8   ; Wait 40 microseconds            ;
0320              9   ;---------------------------------;
0320             10   Wait40uSec:
0320 C000        11            push AR0
0322 78BE        12            mov R0, #190
0324             13   L0: 
0324 00          14            nop
0325 00          15            nop
0326 00          16            nop
0327 00          17            nop
0328 D8FA        18            djnz R0, L0 ; 1+1+1+1+3 cycles->7*30ns*190=40us
032A D000        19            pop AR0
032C 22          20       ret
032D             21   
032D             22   ;---------------------------------;
032D             23   ; Wait 'R2' milliseconds          ;
032D             24   ;---------------------------------;
                 25   Wait_Milli_Seconds mac
                 26   	push AR2
                 27   	mov R2, %0
                 28   	lcall ?Wait_Milli_Seconds
                 29   	pop AR2
                 30   endmac
032D             31   
032D             32   ?Wait_Milli_Seconds:
032D C000        33            push AR0
032F C001        34            push AR1
0331 7932        35   L3: mov R1, #50
0333 78DF        36   L2: mov R0, #223
0335 D8FE        37   L1: djnz R0, L1 ; 3 cycles->3*30ns*250=20.07us
0337 D9FA        38       djnz R1, L2 ; 20.07us*50=1.004ms
0339 DAF6        39       djnz R2, L3 ; number of millisecons to wait passed in R2
033B D001        40       pop AR1
033D D000        41       pop AR0
033F 22          42       ret
0340             43            
0340             44   ;---------------------------------;
0340             45   ; Toggles the 'E' pin in the LCD  ;
0340             46   ;---------------------------------;
0340             47   ELCD_pulse:
0340 D291        48            setb ELCD_E
0342 120320      49            lcall Wait40uSec
0345 C291        50            clr ELCD_E
0347 120320      51       lcall Wait40uSec ; This line is needed in the DE1SoC running an 8051 because it is much faster than the AT89LP51RC2
034A 22          52       ret
034B             53   
034B             54   ;---------------------------------;
034B             55   ; Writes acc to LCD in 4-bit mode ;
034B             56   ;---------------------------------;
034B             57   ELCD_byte:
034B             58            ; Write high 4 bits first
034B A2E7        59            mov c, ACC.7
034D 9281        60            mov ELCD_D7, c
034F A2E6        61            mov c, ACC.6
0351 9283        62            mov ELCD_D6, c
0353 A2E5        63            mov c, ACC.5
0355 9285        64            mov ELCD_D5, c
0357 A2E4        65            mov c, ACC.4
0359 9287        66            mov ELCD_D4, c
035B 120340      67       lcall ELCD_pulse
035E             68            ; Write low 4 bits next
035E A2E3        69            mov c, ACC.3
0360 9281        70            mov ELCD_D7, c
0362 A2E2        71            mov c, ACC.2
0364 9283        72            mov ELCD_D6, c
0366 A2E1        73            mov c, ACC.1
0368 9285        74            mov ELCD_D5, c
036A A2E0        75            mov c, ACC.0
036C 9287        76            mov ELCD_D4, c
036E 120340      77       lcall ELCD_pulse
0371 22          78            ret
0372             79   
0372             80   ;---------------------------------;
0372             81   ; Write data to LCD               ;
0372             82   ;---------------------------------;
                 83   WriteData mac
                 84   	mov a, %0
                 85   	lcall ?WriteData
                 86   endmac
0372             87            
0372             88   ?WriteData:
0372 D297        89            setb ELCD_RS
0374 02034B      90            ljmp ELCD_byte
0377             91   
0377             92   ;---------------------------------;
0377             93   ; Write command to LCD            ;
0377             94   ;---------------------------------;
                 95   WriteCommand mac
                 96   	mov a, %0
                 97   	lcall ?WriteCommand
                 98   endmac
0377             99   
0377            100   ?WriteCommand:
0377 C297       101            clr ELCD_RS
0379 02034B     102            ljmp ELCD_byte
037C            103   
037C            104   ;---------------------------------;
037C            105   ; Configure LCD in 4-bit mode     ;
037C            106   ;---------------------------------;
037C            107   ELCD_4BIT:
037C C291       108            clr ELCD_E   ; Resting state of LCD's enable pin is zero
037E            109            ;clr ELCD_RW  ; RW forced to zero
037E            110            
037E            111            ; After power on, let the LCD start up before initializing
037E C002       112            push AR2
0380 7A28       112            mov R2, #40
0382 12032D     112            lcall ?Wait_Milli_Seconds
0385 D002       112            pop AR2
0387            113            
0387            114            ; First make sure the LCD is in 8-bit mode and then change to 4-bit mode
0387 7433       115            mov a, #0x33
0389 120377     115            lcall ?WriteCommand
038C 7433       116            mov a, #0x33
038E 120377     116            lcall ?WriteCommand
0391 7432       117            mov a, #0x32
0393 120377     117            lcall ?WriteCommand ; change to 4-bit mode
0396            118   
0396            119            ; Configure the LCD
0396 7428       120            mov a, #0x28
0398 120377     120            lcall ?WriteCommand
039B 740C       121            mov a, #0x0c
039D 120377     121            lcall ?WriteCommand
03A0 7401       122            mov a, #0x01
03A2 120377     122            lcall ?WriteCommand ;  Clear screen command (takes some time)
03A5            123   
03A5            124       ;Wait for the clear screen command to finish.
03A5 C002       125            push AR2
03A7 7A02       125            mov R2, #2
03A9 12032D     125            lcall ?Wait_Milli_Seconds
03AC D002       125            pop AR2
03AE 22         126       ret
03AF            127   
03AF            128   ;---------------------------------;
03AF            129   ; Send a constant string to LCD   ;
03AF            130   ;---------------------------------;
                131   Send_Constant_String mac
                132   	push dph
                133   	push dpl
                134   	push acc
                135   	mov dptr, %0
                136   	lcall ?Send_Constant_String
                137   	pop acc
                138   	pop dpl
                139   	pop dph
                140   endmac
03AF            141   
03AF            142   ?Send_Constant_String:
03AF E4         143       clr a
03B0 93         144       movc a, @a+dptr
03B1 6006       145       jz ?Send_Constant_String_Done
03B3 120372     146       lcall ?WriteData
03B6 A3         147       inc dptr
03B7 80F6       148       sjmp ?Send_Constant_String
03B9            149   ?Send_Constant_String_Done:
03B9 22         150       ret  
03BA            151   
03BA            152   ;---------------------------------;
03BA            153   ; Set LCD cursor at row, column   ;
03BA            154   ;---------------------------------;
                155   Set_Cursor mac
                156   	push acc
                157   	mov a, #%1
                158   	dec a
                159   	lcall ?Set_Cursor_%0 ; Select column and row
                160   	pop acc
                161   endmac
03BA            162   
03BA            163   ?Set_Cursor_2:
03BA 4440       164            orl a, #01000000B
03BC            165   ?Set_Cursor_1:
03BC 4480       166            orl a, #10000000B
03BE 020377     167            ljmp ?WriteCommand ; Select column and row
03C1            168   
03C1            169   ;---------------------------------;
03C1            170   ; Display a BCD number in the LCD ;
03C1            171   ;---------------------------------;
                172   Display_BCD mac
                173   	push ar0
                174   	mov r0, %0
                175   	lcall ?Display_BCD
                176   	pop ar0
                177   endmac
03C1            178   
03C1            179   ?Display_BCD:
03C1 C0E0       180            push acc
03C3            181            ; Write most significant digit
03C3 E8         182            mov a, r0
03C4 C4         183            swap a
03C5 540F       184            anl a, #0fh
03C7 4430       185            orl a, #30h
03C9 120372     186            lcall ?WriteData
03CC            187            ; write least significant digit
03CC E8         188            mov a, r0
03CD 540F       189            anl a, #0fh
03CF 4430       190            orl a, #30h
03D1 120372     191            lcall ?WriteData
03D4 D0E0       192            pop acc
03D6 22         193            ret
03D7            194   
03D7            195   ;------------------------------------;
03D7            196   ; Display a char in the LCD          ;
03D7            197   ;------------------------------------;
                198   Display_char mac
                199   	push acc
                200   	mov a, %0
                201   	lcall ?WriteData
                202   	pop acc
                203   endmac
