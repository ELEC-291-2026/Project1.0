0B6B            277   ;We should probably start using this from now on oh well live laugh love
                278   Mov_A_to_B MAC
                279   ;%0 is A, %1 is B
                280   	mov %1+0, %0+0
                281   	mov %1+1, %0+1
                282   	mov %1+2, #0
                283   	mov %1+3, #0
                284   ENDMAC
