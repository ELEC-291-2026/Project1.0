04F4 856139     222       mov bcd+1, reflow_time+1
04F7 22         223       ret
04F8            224   
04F8            225   
04F8            226   ;--------------------------------------------------
04F8            227   ; Macro: Check one keypad column
04F8            228   ; If pressed -> R7 = key value, C=1, jump to Key_Found
04F8            229   ; %0 = column bit, %1 = key code (immediate)
04F8            230   ;--------------------------------------------------
04F8            231   
                232   CHECK_COLUMN MAC
                233       jb  %0, CHECK_COL_%M     ; if column=1 -> no key here -> skip
                234       mov R7, %1               ; store key code
                235       jnb %0, $                ; wait until key is released
                236       setb C                   ; mark "key found"
                237       ljmp Key_Found           ; use long jump instead of short
                238   CHECK_COL_%M:
                239   ENDMAC
04F8            240   
04F8            241   
04F8            242   ;--------------------------------------------------
04F8            243   ; Configure GPIO directions for keypad
04F8            244   ;--------------------------------------------------
04F8            245   
04F8            246   Configure_Keypad_Pins:
04F8 439B54     247       orl P1MOD, #01010100b    ; Rows as output on P1
04FB 439C01     248       orl P2MOD, #00000001b
04FE 539CAB     249       anl P2MOD, #10101011b    ; Columns as input on P2
0501 539DFE     250       anl P3MOD, #11111110b    ; Column on P3.0 input
0504 22         251       ret
