                 -1   	$include(keypad_lib_3.asm)
03D7              1   
03D7              2   CSEG
03D7              3   
03D7              4   ;--------------------------------------------------
03D7              5   ; Lookup table for 7-segment display patterns (common anode)
03D7              6   ; Index 0-F = segment pattern
03D7              7   ;--------------------------------------------------
03D7              8   
03D7              9   myLUT:
03D7 C0F9A4B0    10       DB 0C0h, 0F9h, 0A4h, 0B0h, 099h        ; digits 0-4
     99
03DC 9282F880    11       DB 092h, 082h, 0F8h, 080h, 090h        ; digits 5-9
     90
03E1 8883C6A1    12       DB 088h, 083h, 0C6h, 0A1h, 086h, 08Eh  ; A-F
     868E
03E7             13   
03E7             14   ;--------------------------------------------------
03E7             15   ; Macro: showBCD
03E7             16   ; Input : one byte containing two BCD digits
03E7             17   ; Output: two 7-seg displays
03E7             18   ;   %0 = bcd byte
03E7             19   ;   %1 = HEX low
03E7             20   ;   %2 = HEX high
03E7             21   ;--------------------------------------------------
03E7             22   
                 23   showBCD MAC
                 24       ; ---- Display lower nibble (LSD) ----
                 25       mov  A, %0           ; Load BCD byte
                 26       anl  A, #0Fh         ; Keep lower 4 bits
                 27       movc A, @A+dptr      ; Convert using LUT
                 28       mov  %1, A           ; Output to first HEX display
                 29   
                 30       ; ---- Display upper nibble (MSD) ----
                 31       mov  A, %0
                 32       swap A               ; Swap nibbles
                 33       anl  A, #0Fh
                 34       movc A, @A+dptr
                 35       mov  %2, A           ; Output to second HEX display
                 36   ENDMAC
03E7             37   
03E7             38   
03E7             39   ;--------------------------------------------------
03E7             40   ; Display routine - show BCD number on HEX displays
03E7             41   ; KEY3: 0 = show high digits, 1 = show low digits
03E7             42   ; LEDRA.7: overflow indicator if bcd+3 or bcd+4 != 0
03E7             43   ;--------------------------------------------------
03E7             44   
03E7             45   Display:
03E7 9003D7      46       mov dptr, #myLUT     ; Point to lookup table
03EA             47   
03EA             48       ; If digits 10-7 (bcd+3 and bcd+4) are NOT zero
03EA             49       ; turn ON LEDRA.7 as overflow indicator
03EA             50   
03EA E53B        51       mov A, bcd+3
03EC 453C        52       orl A, bcd+4
03EE 6004        53       jz  Display_L1
03F0 D2EF        54       setb LEDRA.7         ; Alert LED on
03F2 8002        55       sjmp Display_L2
03F4             56   Display_L1:
03F4 C2EF        57       clr LEDRA.7          ; Alert LED off
03F6             58   Display_L2:
03F6             59   
03F6             60       ; If KEY3 pressed (assuming active low) show HIGH digits
03F6             61       ; Otherwise show LOW digits
03F6             62   
03F6 30FB2F      63       jnb KEY.3, Display_high_digits
03F9             64   
03F9             65       ; Show lower 6 digits
03F9             66       ; ---- Display lower nibble (LSD) ----
03F9 E538        66       mov  A, bcd+0           ; Load BCD byte
03FB 540F        66       anl  A, #0Fh         ; Keep lower 4 bits
03FD 93          66       movc A, @A+dptr      ; Convert using LUT
03FE F591        66       mov  HEX0, A           ; Output to first HEX display
0400             66   
0400             66       ; ---- Display upper nibble (MSD) ----
0400 E538        66       mov  A, bcd+0
0402 C4          66       swap A               ; Swap nibbles
0403 540F        66       anl  A, #0Fh
0405 93          66       movc A, @A+dptr
0406 F592        66       mov  HEX1, A           ; Output to second HEX display
0408             67       ; ---- Display lower nibble (LSD) ----
0408 E539        67       mov  A, bcd+1           ; Load BCD byte
040A 540F        67       anl  A, #0Fh         ; Keep lower 4 bits
040C 93          67       movc A, @A+dptr      ; Convert using LUT
040D F593        67       mov  HEX2, A           ; Output to first HEX display
040F             67   
040F             67       ; ---- Display upper nibble (MSD) ----
040F E539        67       mov  A, bcd+1
0411 C4          67       swap A               ; Swap nibbles
0412 540F        67       anl  A, #0Fh
0414 93          67       movc A, @A+dptr
0415 F594        67       mov  HEX3, A           ; Output to second HEX display
0417             68       ; ---- Display lower nibble (LSD) ----
0417 E53A        68       mov  A, bcd+2           ; Load BCD byte
0419 540F        68       anl  A, #0Fh         ; Keep lower 4 bits
041B 93          68       movc A, @A+dptr      ; Convert using LUT
041C F58E        68       mov  HEX4, A           ; Output to first HEX display
041E             68   
041E             68       ; ---- Display upper nibble (MSD) ----
041E E53A        68       mov  A, bcd+2
0420 C4          68       swap A               ; Swap nibbles
0421 540F        68       anl  A, #0Fh
0423 93          68       movc A, @A+dptr
0424 F58F        68       mov  HEX5, A           ; Output to second HEX display
0426 8024        69       sjmp Display_end
0428             70   
0428             71   Display_high_digits:
0428             72       ; Show upper 4 digits
0428             73       ; ---- Display lower nibble (LSD) ----
0428 E53B        73       mov  A, bcd+3           ; Load BCD byte
042A 540F        73       anl  A, #0Fh         ; Keep lower 4 bits
042C 93          73       movc A, @A+dptr      ; Convert using LUT
042D F591        73       mov  HEX0, A           ; Output to first HEX display
042F             73   
042F             73       ; ---- Display upper nibble (MSD) ----
042F E53B        73       mov  A, bcd+3
0431 C4          73       swap A               ; Swap nibbles
0432 540F        73       anl  A, #0Fh
0434 93          73       movc A, @A+dptr
0435 F592        73       mov  HEX1, A           ; Output to second HEX display
0437             74       ; ---- Display lower nibble (LSD) ----
0437 E53C        74       mov  A, bcd+4           ; Load BCD byte
0439 540F        74       anl  A, #0Fh         ; Keep lower 4 bits
043B 93          74       movc A, @A+dptr      ; Convert using LUT
043C F593        74       mov  HEX2, A           ; Output to first HEX display
043E             74   
043E             74       ; ---- Display upper nibble (MSD) ----
043E E53C        74       mov  A, bcd+4
0440 C4          74       swap A               ; Swap nibbles
0441 540F        74       anl  A, #0Fh
0443 93          74       movc A, @A+dptr
0444 F594        74       mov  HEX3, A           ; Output to second HEX display
0446             75   
0446             76       ; Blank remaining displays
0446 758EFF      77       mov HEX4, #0FFh
0449 758FFF      78       mov HEX5, #0FFh
044C             79   
044C             80   Display_end:
044C 22          81       ret
044D             82   
044D             83   ;--------------------------------------------------
044D             84   ; Macro: Rotate Left through Carry
044D             85   ;--------------------------------------------------
044D             86   
                 87   MYRLC MAC
                 88       mov A, %0
                 89       rlc A
                 90       mov %0, A
                 91   ENDMAC
044D             92   
044D             93   ;--------------------------------------------------
044D             94   ; Shift all BCD digits LEFT by 4 bits
044D             95   ; Makes room for new digit in LSD (R7)
044D             96   ;--------------------------------------------------
044D             97   
044D             98   Shift_Digits_Left:
044D 7804        99       mov R0, #4           ; 4 bit shifts (one nibble)
044F            100   
044F            101   Shift_Digits_Left_L0:
044F C3         102       clr C                ; Clear carry before shift
0450 E538       103       mov A, bcd+0
0452 33         103       rlc A
0453 F538       103       mov bcd+0, A
0455 E539       104       mov A, bcd+1
0457 33         104       rlc A
0458 F539       104       mov bcd+1, A
045A E53A       105       mov A, bcd+2
045C 33         105       rlc A
045D F53A       105       mov bcd+2, A
045F E53B       106       mov A, bcd+3
0461 33         106       rlc A
0462 F53B       106       mov bcd+3, A
0464 E53C       107       mov A, bcd+4
0466 33         107       rlc A
0467 F53C       107       mov bcd+4, A
0469 D8E4       108       djnz R0, Shift_Digits_Left_L0
046B            109   
046B            110       ; Insert new digit from R7 into lowest nibble safely
046B            111       ; Keep upper nibble of bcd+0 unchanged
046B 5338F0     112       anl  bcd+0, #0F0h    ; clear lower nibble
046E EF         113       mov  A, R7
046F 540F       114       anl  A, #0Fh         ; ensure only 0-F
0471 4238       115       orl  bcd+0, A
0473 22         116       ret
0474            117   
0474            118   ;--------------------------------------------------
0474            119   ; Macro: Rotate Right through Carry
0474            120   ;--------------------------------------------------
0474            121   
                122   MYRRC MAC
                123       mov A, %0
                124       rrc A
                125       mov %0, A
                126   ENDMAC
0474            127   
0474            128   ;--------------------------------------------------
0474            129   ; Shift digits RIGHT by 4 bits
0474            130   ; Used for BACKSPACE (delete last digit)
0474            131   ;--------------------------------------------------
0474            132   
0474            133   Shift_Digits_Right:
0474 7804       134       mov R0, #4
0476            135   
0476            136   Shift_Digits_Right_L0:
0476 C3         137       clr C
0477 E53C       138       mov A, bcd+4
0479 13         138       rrc A
047A F53C       138       mov bcd+4, A
047C E53B       139       mov A, bcd+3
047E 13         139       rrc A
047F F53B       139       mov bcd+3, A
0481 E53A       140       mov A, bcd+2
0483 13         140       rrc A
0484 F53A       140       mov bcd+2, A
0486 E539       141       mov A, bcd+1
0488 13         141       rrc A
0489 F539       141       mov bcd+1, A
048B E538       142       mov A, bcd+0
048D 13         142       rrc A
048E F538       142       mov bcd+0, A
0490 D8E4       143       djnz R0, Shift_Digits_Right_L0
0492 22         144       ret
0493            145   
0493            146   
0493            147   ;--------------------------------------------------
0493            148   ; 25 ms delay (software debounce)
0493            149   ;--------------------------------------------------
0493            150   
0493            151   Wait25ms:
0493 780F       152       mov R0, #15
0495 794A       153   L6: mov R1, #74
0497 7AFA       154   L5: mov R2, #250
0499 DAFE       155   L4: djnz R2, L4
049B D9FA       156       djnz R1, L5
049D D8F6       157       djnz R0, L6
049F 22         158       ret
04A0            159   
04A0            160   
04A0            161   ;--------------------------------------------------
04A0            162   ; Helper routines for parameter storage
04A0            163   ; Each parameter value lives in bcd+0..bcd+1
04A0            164   ; active_param: 0=A, 1=B, 2=C, 3=D
04A0            165   ;--------------------------------------------------
04A0            166   
04A0            167   ; Save current BCD (bcd+0..bcd+1) into active parameter
04A0            168   Save_Current_BCD_Into_Param:
04A0 E564       169       mov A, active_param
04A2 B40007     170       cjne A, #0, Save_NotA
04A5            171       ; A: soak_temp
04A5 853858     172       mov soak_temp+0, bcd+0
04A8 853959     173       mov soak_temp+1, bcd+1
04AB 22         174       ret
04AC            175   Save_NotA:
04AC B40107     176       cjne A, #1, Save_NotB
04AF            177       ; B: soak_time
04AF 85385A     178       mov soak_time+0, bcd+0
04B2 85395B     179       mov soak_time+1, bcd+1
04B5 22         180       ret
04B6            181   Save_NotB:
04B6 B40207     182       cjne A, #2, Save_NotC
04B9            183       ; C: reflow_temp
04B9 85385E     184       mov reflow_temp+0, bcd+0
04BC 85395F     185       mov reflow_temp+1, bcd+1
04BF 22         186       ret
04C0            187   Save_NotC:
04C0            188       ; D: reflow_time (default case)
04C0 853860     189       mov reflow_time+0, bcd+0
04C3 853961     190       mov reflow_time+1, bcd+1
04C6 22         191       ret
04C7            192   
04C7            193   
04C7            194   ; Load active parameter into BCD (bcd+0..bcd+1)
04C7            195   ; Clear the higher digits.
04C7            196   Load_Param_Into_BCD:
04C7 753A00     197       mov bcd+2, #00h
04CA 753B00     198       mov bcd+3, #00h
04CD 753C00     199       mov bcd+4, #00h
04D0            200   
04D0 E564       201       mov A, active_param
04D2 B40007     202       cjne A, #0, Load_NotA
04D5            203       ; A: soak_temp
04D5 855838     204       mov bcd+0, soak_temp
04D8 855939     205       mov bcd+1, soak_temp+1
04DB 22         206       ret
04DC            207   Load_NotA:
04DC B40107     208       cjne A, #1, Load_NotB
04DF            209       ; B: soak_time
04DF 855A38     210       mov bcd+0, soak_time
04E2 855B39     211       mov bcd+1, soak_time+1
04E5 22         212       ret
04E6            213   Load_NotB:
04E6 B40207     214       cjne A, #2, Load_NotC
04E9            215       ; C: reflow_temp
04E9 855E38     216       mov bcd+0, reflow_temp
04EC 855F39     217       mov bcd+1, reflow_temp+1
04EF 22         218       ret
04F0            219   Load_NotC:
04F0            220       ; D: reflow_time (default)
04F0 856038     221       mov bcd+0, reflow_time
04F3 856139     222       mov bcd+1, reflow_time+1
04F6 22         223       ret
04F7            224   
04F7            225   
04F7            226   ;--------------------------------------------------
04F7            227   ; Macro: Check one keypad column
04F7            228   ; If pressed -> R7 = key value, C=1, jump to Key_Found
04F7            229   ; %0 = column bit, %1 = key code (immediate)
04F7            230   ;--------------------------------------------------
04F7            231   
                232   CHECK_COLUMN MAC
                233       jb  %0, CHECK_COL_%M     ; if column=1 -> no key here -> skip
                234       mov R7, %1               ; store key code
                235       jnb %0, $                ; wait until key is released
                236       setb C                   ; mark "key found"
                237       ljmp Key_Found           ; use long jump instead of short
                238   CHECK_COL_%M:
                239   ENDMAC
04F7            240   
04F7            241   
04F7            242   ;--------------------------------------------------
04F7            243   ; Configure GPIO directions for keypad
04F7            244   ;--------------------------------------------------
04F7            245   
04F7            246   Configure_Keypad_Pins:
04F7 439B54     247       orl P1MOD, #01010100b    ; Rows as output on P1
04FA 439C01     248       orl P2MOD, #00000001b
04FD 539CAB     249       anl P2MOD, #10101011b    ; Columns as input on P2
0500 539DFE     250       anl P3MOD, #11111110b    ; Column on P3.0 input
0503 22         251       ret
0504            252   
0504            253   ; Pin definitions for keypad
0504            254   ROW1 EQU P1.2
0504            255   ROW2 EQU P1.4
0504            256   ROW3 EQU P1.6
0504            257   ROW4 EQU P2.0
0504            258   
0504            259   COL1 EQU P2.2
0504            260   COL2 EQU P2.4
0504            261   COL3 EQU P2.6
0504            262   COL4 EQU P3.0
0504            263   
0504            264   ;--------------------------------------------------
0504            265   ; Keypad scanning routine
0504            266   ; Output:
0504            267   ;   C = 1 -> numeric key pressed, code in R7 (0-9, maybe E/F)
0504            268   ;   C = 0 -> no digit (no key, mode key, or backspace)
0504            269   ;--------------------------------------------------
0504            270   
0504            271   Keypad:
0504            272   
0504            273       ; KEY1 acts as BACKSPACE / ERASE
0504            274   
0504 20F90E     275       jb  KEY.1, keypad_L0     ; if KEY1=1 (not pressed) -> skip
0507 120493     276       lcall Wait25ms
050A 20F908     277       jb  KEY.1, keypad_L0     ; if bounced back high, skip
050D 30F9FD     278       jnb KEY.1, $             ; wait for release (KEY1 low while pressed)
0510 120474     279       lcall Shift_Digits_Right ; delete LSD for active parameter
0513 C3         280       clr C                    ; no digit returned
0514 22         281       ret
0515            282   
0515            283   keypad_L0:
0515            284   
0515            285       ; Drive all rows LOW - check if any column LOW
0515            286   
0515 C292       287       clr ROW1
0517 C294       288       clr ROW2
0519 C296       289       clr ROW3
051B C2A0       290       clr ROW4
051D            291   
051D A2A2       292       mov C, COL1
051F 82A4       293       anl C, COL2
0521 82A6       294       anl C, COL3
0523 82B0       295       anl C, COL4
0525 5002       296       jnc Keypad_Debounce      ; if any column low -> possible key
0527 C3         297       clr C
0528 22         298       ret
0529            299   
0529            300   Keypad_Debounce:
0529            301       ; Wait and check again to avoid bouncing
0529 120493     302       lcall Wait25ms
052C            303   
052C A2A2       304       mov C, COL1
052E 82A4       305       anl C, COL2
0530 82A6       306       anl C, COL3
0532 82B0       307       anl C, COL4
0534 5002       308       jnc Keypad_Key_Code
0536 C3         309       clr C
0537 22         310       ret
0538            311   
0538            312   Keypad_Key_Code:
0538            313       ; Prepare to scan each row individually
0538 D292       314       setb ROW1
053A D294       315       setb ROW2
053C D296       316       setb ROW3
053E D2A0       317       setb ROW4
0540            318   
0540            319       ; SW0 selects layout orientation
0540 30E803     320       jnb SWA.0, keypad_default
0543 020618     321       ljmp keypad_90deg
0546            322   
0546            323   
0546            324   ;--------------------------------------------------
0546            325   ; Default keypad layout
0546            326   ;--------------------------------------------------
0546            327   ; Mapping (default):
0546            328   ;   Row1: 1  2  3  A (0Ah)
0546            329   ;   Row2: 4  5  6  B (0Bh)
0546            330   ;   Row3: 7  8  9  C (0Ch)
0546            331   ;   Row4: *  0  #  D (0Eh,00h,0Fh,0Dh)
0546            332   ;--------------------------------------------------
0546            333   
0546            334   keypad_default:
0546            335   
