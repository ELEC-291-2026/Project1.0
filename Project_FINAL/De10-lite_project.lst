0436             84   ; Macro: Rotate Left through Carry
0436             85   ;--------------------------------------------------
0436             86   
                 87   MYRLC MAC
                 88       mov A, %0
                 89       rlc A
                 90       mov %0, A
                 91   ENDMAC
0436             92   
0436             93   ;--------------------------------------------------
0436             94   ; Shift all BCD digits LEFT by 4 bits
0436             95   ; Makes room for new digit in LSD (R7)
0436             96   ;--------------------------------------------------
0436             97   
0436             98   Shift_Digits_Left:
0436 7804        99       mov R0, #4           ; 4 bit shifts (one nibble)
0438            100   
0438            101   Shift_Digits_Left_L0:
0438 C3         102       clr C                ; Clear carry before shift
0439 E538       103       mov A, bcd+0
043B 33         103       rlc A
043C F538       103       mov bcd+0, A
043E E539       104       mov A, bcd+1
0440 33         104       rlc A
0441 F539       104       mov bcd+1, A
0443 E53A       105       mov A, bcd+2
0445 33         105       rlc A
0446 F53A       105       mov bcd+2, A
0448 E53B       106       mov A, bcd+3
044A 33         106       rlc A
044B F53B       106       mov bcd+3, A
044D E53C       107       mov A, bcd+4
044F 33         107       rlc A
0450 F53C       107       mov bcd+4, A
0452 D8E4       108       djnz R0, Shift_Digits_Left_L0
0454            109   
0454            110       ; Insert new digit from R7 into lowest nibble safely
0454            111       ; Keep upper nibble of bcd+0 unchanged
0454 5338F0     112       anl  bcd+0, #0F0h    ; clear lower nibble
0457 EF         113       mov  A, R7
0458 540F       114       anl  A, #0Fh         ; ensure only 0-F
045A 4238       115       orl  bcd+0, A
045C 22         116       ret
045D            117   
045D            118   ;--------------------------------------------------
045D            119   ; Macro: Rotate Right through Carry
045D            120   ;--------------------------------------------------
045D            121   
                122   MYRRC MAC
                123       mov A, %0
                124       rrc A
                125       mov %0, A
                126   ENDMAC
045D            127   
045D            128   ;--------------------------------------------------
045D            129   ; Shift digits RIGHT by 4 bits
045D            130   ; Used for BACKSPACE (delete last digit)
045D            131   ;--------------------------------------------------
045D            132   
045D            133   Shift_Digits_Right:
045D 7804       134       mov R0, #4
045F            135   
045F            136   Shift_Digits_Right_L0:
045F C3         137       clr C
0460 E53C       138       mov A, bcd+4
0462 13         138       rrc A
0463 F53C       138       mov bcd+4, A
0465 E53B       139       mov A, bcd+3
0467 13         139       rrc A
0468 F53B       139       mov bcd+3, A
046A E53A       140       mov A, bcd+2
046C 13         140       rrc A
046D F53A       140       mov bcd+2, A
046F E539       141       mov A, bcd+1
0471 13         141       rrc A
0472 F539       141       mov bcd+1, A
0474 E538       142       mov A, bcd+0
0476 13         142       rrc A
0477 F538       142       mov bcd+0, A
0479 D8E4       143       djnz R0, Shift_Digits_Right_L0
047B 22         144       ret
