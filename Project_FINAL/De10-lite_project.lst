06E9 22         404       ret
06EA            405   
06EA            406   
06EA            407   ;--------------------------------------------------
06EA            408   ; Key_Found:
06EA            409   ;   R7 = key code (0-F), C = 1 when we get here.
06EA            410   ;   A/B/C/D (0Ah-0Dh) -> mode select
06EA            411   ;   * (0Eh)           -> delete / backspace one digit
06EA            412   ;   # (0Fh)           -> clear all digits
06EA            413   ;   others (0-9, maybe E/F) -> digit
06EA            414   ;--------------------------------------------------
06EA            415   
06EA            416   Key_Found:
06EA EF         417       mov A, R7
06EB            418   
06EB            419       ; --- Mode A (soak temperature) ---
06EB B40A0B     420       cjne A, #0Ah, KF_CheckB
06EE 1204A0     421       lcall Save_Current_BCD_Into_Param
06F1 756400     422       mov   active_param, #0       ; A: soak_temp
06F4 1204C7     423       lcall Load_Param_Into_BCD
06F7 C3         424       clr C                        ; do not treat as digit
06F8 22         425       ret
06F9            426   
06F9            427   KF_CheckB:
06F9            428       ; --- Mode B (soak time) ---
06F9 B40B0B     429       cjne A, #0Bh, KF_CheckC
06FC 1204A0     430       lcall Save_Current_BCD_Into_Param
06FF 756401     431       mov   active_param, #1       ; B: soak_time
0702 1204C7     432       lcall Load_Param_Into_BCD
0705 C3         433       clr C
0706 22         434       ret
0707            435   
0707            436   KF_CheckC:
0707            437       ; --- Mode C (reflow temperature) ---
0707 B40C0B     438       cjne A, #0Ch, KF_CheckD
070A 1204A0     439       lcall Save_Current_BCD_Into_Param
070D 756402     440       mov   active_param, #2       ; C: reflow_temp
0710 1204C7     441       lcall Load_Param_Into_BCD
0713 C3         442       clr C
0714 22         443       ret
0715            444   
0715            445   KF_CheckD:
0715            446       ; --- Mode D (reflow time) ---
0715 B40D0B     447       cjne A, #0Dh, KF_CheckStar
0718 1204A0     448       lcall Save_Current_BCD_Into_Param
071B 756403     449       mov   active_param, #3       ; D: reflow_time
071E 1204C7     450       lcall Load_Param_Into_BCD
0721 C3         451       clr C
0722 22         452       ret
0723            453   
0723            454   KF_CheckStar:
0723            455       ; --- '*' key (code 0Eh) -> delete / backspace ---
0723 B40E05     456       cjne A, #0Eh, KF_CheckHash
0726            457       ; Backspace = shift digits right by 1 digit
0726 120474     458       lcall Shift_Digits_Right
0729 C3         459       clr C                        ; no new digit for main loop
072A 22         460       ret
072B            461   
072B            462   KF_CheckHash:
072B            463       ; --- '#' key (code 0Fh) -> clear ---
072B B40F0D     464       cjne A, #0Fh, KF_Digit
072E            465       ; Clear all BCD digits for current parameter
072E E4         466       clr A
072F F538       467       mov bcd+0, A
0731 F539       468       mov bcd+1, A
0733 F53A       469       mov bcd+2, A
0735 F53B       470       mov bcd+3, A
0737 F53C       471       mov bcd+4, A
0739 C3         472       clr C                        ; no digit to insert
073A 22         473       ret
073B            474   
073B            475   KF_Digit:
073B            476       ; Not A/B/C/D/*/# -> treat as numeric digit key
073B            477       ; R7 holds the digit, Carry = 1 -> main loop will append it
073B 22         478       ret
073C            479   
073C            480   
