09CE            207   
09CE            208   ; The 8-bit hex number passed in the accumulator is converted to
09CE            209   ; BCD and stored in [R1, R0]
09CE            210   Hex_to_bcd_8bit:
09CE 75F064     211            mov b, #100
09D1 84         212            div ab
09D2 F9         213            mov R1, a   ; After dividing, a has the 100s
09D3 E5F0       214            mov a, b    ; Remainder is in register b
09D5 75F00A     215            mov b, #10
09D8 84         216            div ab ; The tens are stored in a, the units are stored in b 
09D9 C4         217            swap a
09DA 54F0       218            anl a, #0xf0
09DC 45F0       219            orl a, b
09DE F8         220            mov R0, a
09DF 22         221            ret
09E0            222            
09E0            223            
09E0            224   ;We should probably start using this from now on oh well live laugh love
                225   Mov_A_to_B MAC
                226   ;%0 is A, %1 is B
                227   	mov %1+0, %0+0
                228   	mov %1+1, %0+1
                229   	mov %1+2, #0
                230   	mov %1+3, #0
                231   ENDMAC
