08AF            103   ;-------MACROS--------------------;
08AF            104   ;Example macro to help with process %0,1,etc represents the input number, this is all pass by reference(i.e it can actually affect the variable)
                105   Load_X_Var32 MAC
                106   mov x+0, %0+0
                107   mov x+1, %0+1
                108   mov x+2, %0+2
                109   mov x+3, %0+3
                110   ENDMAC
08AF            111   
                112   Load_Y_Var32 MAC
                113   mov y+0, %0+0
                114   mov y+1, %0+1
                115   mov y+2, %0+2
                116   mov y+3, %0+3
                117   ENDMAC
08AF            118   
                119   Load_X_Var16 MAC
                120   mov x+0, %0+0
                121   mov x+1, %0+1
                122   mov x+2, #0
                123   mov x+3, #0
                124   ENDMAC
08AF            125   
                126   Load_Y_Var16 MAC
                127   mov y+0, %0+0
                128   mov y+1, %0+1
                129   mov y+2, #0
                130   mov y+3, #0
                131   ENDMAC
08AF            132   
                133   Load_X_Var8 MAC
                134       
                135   mov x+0, %0+0
                136   mov x+1, #0
                137   mov x+2, #0
                138   mov x+3, #0
                139   ENDMAC
08AF            140   
                141   Load_Y_Var8 MAC
                142       
                143   mov y+0, %0+0
