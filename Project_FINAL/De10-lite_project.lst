06D3            405   
06D3            406   
06D3            407   ;--------------------------------------------------
06D3            408   ; Key_Found:
06D3            409   ;   R7 = key code (0-F), C = 1 when we get here.
06D3            410   ;   A/B/C/D (0Ah-0Dh) -> mode select
06D3            411   ;   * (0Eh)           -> delete / backspace one digit
06D3            412   ;   # (0Fh)           -> clear all digits
06D3            413   ;   others (0-9, maybe E/F) -> digit
06D3            414   ;--------------------------------------------------
06D3            415   
06D3            416   Key_Found:
06D3 EF         417       mov A, R7
06D4            418   
06D4            419       ; --- Mode A (soak temperature) ---
06D4 B40A0B     420       cjne A, #0Ah, KF_CheckB
06D7 120489     421       lcall Save_Current_BCD_Into_Param
06DA 756400     422       mov   active_param, #0       ; A: soak_temp
06DD 1204B0     423       lcall Load_Param_Into_BCD
06E0 C3         424       clr C                        ; do not treat as digit
06E1 22         425       ret
06E2            426   
06E2            427   KF_CheckB:
06E2            428       ; --- Mode B (soak time) ---
06E2 B40B0B     429       cjne A, #0Bh, KF_CheckC
06E5 120489     430       lcall Save_Current_BCD_Into_Param
06E8 756401     431       mov   active_param, #1       ; B: soak_time
06EB 1204B0     432       lcall Load_Param_Into_BCD
06EE C3         433       clr C
06EF 22         434       ret
06F0            435   
06F0            436   KF_CheckC:
06F0            437       ; --- Mode C (reflow temperature) ---
06F0 B40C0B     438       cjne A, #0Ch, KF_CheckD
06F3 120489     439       lcall Save_Current_BCD_Into_Param
06F6 756402     440       mov   active_param, #2       ; C: reflow_temp
06F9 1204B0     441       lcall Load_Param_Into_BCD
06FC C3         442       clr C
06FD 22         443       ret
06FE            444   
06FE            445   KF_CheckD:
06FE            446       ; --- Mode D (reflow time) ---
06FE B40D0B     447       cjne A, #0Dh, KF_CheckStar
0701 120489     448       lcall Save_Current_BCD_Into_Param
0704 756403     449       mov   active_param, #3       ; D: reflow_time
0707 1204B0     450       lcall Load_Param_Into_BCD
070A C3         451       clr C
070B 22         452       ret
070C            453   
070C            454   KF_CheckStar:
070C            455       ; --- '*' key (code 0Eh) -> delete / backspace ---
070C B40E05     456       cjne A, #0Eh, KF_CheckHash
070F            457       ; Backspace = shift digits right by 1 digit
070F 12045D     458       lcall Shift_Digits_Right
0712 C3         459       clr C                        ; no new digit for main loop
0713 22         460       ret
0714            461   
0714            462   KF_CheckHash:
0714            463       ; --- '#' key (code 0Fh) -> clear ---
0714 B40F0D     464       cjne A, #0Fh, KF_Digit
0717            465       ; Clear all BCD digits for current parameter
0717 E4         466       clr A
0718 F538       467       mov bcd+0, A
071A F539       468       mov bcd+1, A
071C F53A       469       mov bcd+2, A
071E F53B       470       mov bcd+3, A
0720 F53C       471       mov bcd+4, A
0722 C3         472       clr C                        ; no digit to insert
0723 22         473       ret
0724            474   
0724            475   KF_Digit:
0724            476       ; Not A/B/C/D/*/# -> treat as numeric digit key
0724            477       ; R7 holds the digit, Carry = 1 -> main loop will append it
0724 22         478       ret
0725            479   
0725            480   
0725            481   END
                 -1   $include(temperature_lib.asm)
