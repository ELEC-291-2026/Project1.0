                 -1   $include(LCD_4bit_DE10Lite_no_RW.inc) ; A library of LCD related functions and utility macros
0309              1   ;  LCD routines adapted for the DE10-Lite configured as a CV_8052 processor
0309              2   cseg
0309              3   
0309              4   ; When using a 33.333333MHz crystal clock
0309              5   ; one cycle takes 1.0/33.333333MHz = 30 ns
0309              6   
0309              7   ;---------------------------------;
0309              8   ; Wait 40 microseconds            ;
0309              9   ;---------------------------------;
0309             10   Wait40uSec:
0309 C000        11            push AR0
030B 78BE        12            mov R0, #190
030D             13   L0: 
030D 00          14            nop
030E 00          15            nop
030F 00          16            nop
0310 00          17            nop
0311 D8FA        18            djnz R0, L0 ; 1+1+1+1+3 cycles->7*30ns*190=40us
0313 D000        19            pop AR0
0315 22          20       ret
0316             21   
0316             22   ;---------------------------------;
0316             23   ; Wait 'R2' milliseconds          ;
0316             24   ;---------------------------------;
                 25   Wait_Milli_Seconds mac
                 26   	push AR2
                 27   	mov R2, %0
                 28   	lcall ?Wait_Milli_Seconds
                 29   	pop AR2
                 30   endmac
0316             31   
0316             32   ?Wait_Milli_Seconds:
0316 C000        33            push AR0
0318 C001        34            push AR1
031A 7932        35   L3: mov R1, #50
031C 78DF        36   L2: mov R0, #223
031E D8FE        37   L1: djnz R0, L1 ; 3 cycles->3*30ns*250=20.07us
0320 D9FA        38       djnz R1, L2 ; 20.07us*50=1.004ms
0322 DAF6        39       djnz R2, L3 ; number of millisecons to wait passed in R2
0324 D001        40       pop AR1
0326 D000        41       pop AR0
0328 22          42       ret
0329             43            
0329             44   ;---------------------------------;
0329             45   ; Toggles the 'E' pin in the LCD  ;
0329             46   ;---------------------------------;
0329             47   ELCD_pulse:
0329 D291        48            setb ELCD_E
032B 120309      49            lcall Wait40uSec
032E C291        50            clr ELCD_E
0330 120309      51       lcall Wait40uSec ; This line is needed in the DE1SoC running an 8051 because it is much faster than the AT89LP51RC2
0333 22          52       ret
0334             53   
0334             54   ;---------------------------------;
0334             55   ; Writes acc to LCD in 4-bit mode ;
0334             56   ;---------------------------------;
0334             57   ELCD_byte:
0334             58            ; Write high 4 bits first
0334 A2E7        59            mov c, ACC.7
0336 9281        60            mov ELCD_D7, c
0338 A2E6        61            mov c, ACC.6
033A 9283        62            mov ELCD_D6, c
033C A2E5        63            mov c, ACC.5
033E 9285        64            mov ELCD_D5, c
0340 A2E4        65            mov c, ACC.4
0342 9287        66            mov ELCD_D4, c
0344 120329      67       lcall ELCD_pulse
0347             68            ; Write low 4 bits next
0347 A2E3        69            mov c, ACC.3
0349 9281        70            mov ELCD_D7, c
034B A2E2        71            mov c, ACC.2
034D 9283        72            mov ELCD_D6, c
034F A2E1        73            mov c, ACC.1
0351 9285        74            mov ELCD_D5, c
0353 A2E0        75            mov c, ACC.0
0355 9287        76            mov ELCD_D4, c
0357 120329      77       lcall ELCD_pulse
035A 22          78            ret
035B             79   
035B             80   ;---------------------------------;
035B             81   ; Write data to LCD               ;
035B             82   ;---------------------------------;
                 83   WriteData mac
                 84   	mov a, %0
                 85   	lcall ?WriteData
                 86   endmac
035B             87            
035B             88   ?WriteData:
035B D297        89            setb ELCD_RS
035D 020334      90            ljmp ELCD_byte
0360             91   
0360             92   ;---------------------------------;
0360             93   ; Write command to LCD            ;
0360             94   ;---------------------------------;
                 95   WriteCommand mac
                 96   	mov a, %0
                 97   	lcall ?WriteCommand
                 98   endmac
0360             99   
0360            100   ?WriteCommand:
0360 C297       101            clr ELCD_RS
0362 020334     102            ljmp ELCD_byte
0365            103   
0365            104   ;---------------------------------;
0365            105   ; Configure LCD in 4-bit mode     ;
0365            106   ;---------------------------------;
0365            107   ELCD_4BIT:
0365 C291       108            clr ELCD_E   ; Resting state of LCD's enable pin is zero
0367            109            ;clr ELCD_RW  ; RW forced to zero
0367            110            
0367            111            ; After power on, let the LCD start up before initializing
0367 C002       112            push AR2
0369 7A28       112            mov R2, #40
036B 120316     112            lcall ?Wait_Milli_Seconds
036E D002       112            pop AR2
0370            113            
0370            114            ; First make sure the LCD is in 8-bit mode and then change to 4-bit mode
0370 7433       115            mov a, #0x33
0372 120360     115            lcall ?WriteCommand
0375 7433       116            mov a, #0x33
0377 120360     116            lcall ?WriteCommand
037A 7432       117            mov a, #0x32
037C 120360     117            lcall ?WriteCommand ; change to 4-bit mode
037F            118   
037F            119            ; Configure the LCD
037F 7428       120            mov a, #0x28
0381 120360     120            lcall ?WriteCommand
0384 740C       121            mov a, #0x0c
0386 120360     121            lcall ?WriteCommand
0389 7401       122            mov a, #0x01
038B 120360     122            lcall ?WriteCommand ;  Clear screen command (takes some time)
038E            123   
038E            124       ;Wait for the clear screen command to finish.
038E C002       125            push AR2
0390 7A02       125            mov R2, #2
0392 120316     125            lcall ?Wait_Milli_Seconds
0395 D002       125            pop AR2
0397 22         126       ret
0398            127   
