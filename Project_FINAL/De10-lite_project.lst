0629 7F0B       376       mov R7, #0Bh               ; store key code
062B 30A4FD     376       jnb COL2, $                ; wait until key is released
062E D3         376       setb C                   ; mark "key found"
062F 0206EA     376       ljmp Key_Found           ; use long jump instead of short
0632            376   CHECK_COL_41:
0632 20A609     377       jb  COL3, CHECK_COL_42     ; if column=1 -> no key here -> skip
0635 7F0C       377       mov R7, #0Ch               ; store key code
0637 30A6FD     377       jnb COL3, $                ; wait until key is released
063A D3         377       setb C                   ; mark "key found"
063B 0206EA     377       ljmp Key_Found           ; use long jump instead of short
063E            377   CHECK_COL_42:
063E 20B009     378       jb  COL4, CHECK_COL_43     ; if column=1 -> no key here -> skip
0641 7F0D       378       mov R7, #0Dh               ; store key code
0643 30B0FD     378       jnb COL4, $                ; wait until key is released
0646 D3         378       setb C                   ; mark "key found"
0647 0206EA     378       ljmp Key_Found           ; use long jump instead of short
064A            378   CHECK_COL_43:
064A D292       379       setb ROW1
064C            380   
064C C294       381       clr ROW2
064E 20A209     382       jb  COL1, CHECK_COL_44     ; if column=1 -> no key here -> skip
0651 7F03       382       mov R7, #03h               ; store key code
0653 30A2FD     382       jnb COL1, $                ; wait until key is released
0656 D3         382       setb C                   ; mark "key found"
0657 0206EA     382       ljmp Key_Found           ; use long jump instead of short
065A            382   CHECK_COL_44:
065A 20A409     383       jb  COL2, CHECK_COL_45     ; if column=1 -> no key here -> skip
065D 7F06       383       mov R7, #06h               ; store key code
065F 30A4FD     383       jnb COL2, $                ; wait until key is released
0662 D3         383       setb C                   ; mark "key found"
0663 0206EA     383       ljmp Key_Found           ; use long jump instead of short
0666            383   CHECK_COL_45:
0666 20A609     384       jb  COL3, CHECK_COL_46     ; if column=1 -> no key here -> skip
0669 7F09       384       mov R7, #09h               ; store key code
066B 30A6FD     384       jnb COL3, $                ; wait until key is released
066E D3         384       setb C                   ; mark "key found"
066F 0206EA     384       ljmp Key_Found           ; use long jump instead of short
0672            384   CHECK_COL_46:
0672 20B009     385       jb  COL4, CHECK_COL_47     ; if column=1 -> no key here -> skip
0675 7F0F       385       mov R7, #0Fh               ; store key code
0677 30B0FD     385       jnb COL4, $                ; wait until key is released
067A D3         385       setb C                   ; mark "key found"
067B 0206EA     385       ljmp Key_Found           ; use long jump instead of short
067E            385   CHECK_COL_47:
067E D294       386       setb ROW2
0680            387   
0680 C296       388       clr ROW3
0682 20A209     389       jb  COL1, CHECK_COL_48     ; if column=1 -> no key here -> skip
0685 7F02       389       mov R7, #02h               ; store key code
0687 30A2FD     389       jnb COL1, $                ; wait until key is released
068A D3         389       setb C                   ; mark "key found"
068B 0206EA     389       ljmp Key_Found           ; use long jump instead of short
068E            389   CHECK_COL_48:
068E 20A409     390       jb  COL2, CHECK_COL_49     ; if column=1 -> no key here -> skip
0691 7F05       390       mov R7, #05h               ; store key code
0693 30A4FD     390       jnb COL2, $                ; wait until key is released
0696 D3         390       setb C                   ; mark "key found"
0697 0206EA     390       ljmp Key_Found           ; use long jump instead of short
069A            390   CHECK_COL_49:
069A 20A609     391       jb  COL3, CHECK_COL_50     ; if column=1 -> no key here -> skip
069D 7F08       391       mov R7, #08h               ; store key code
069F 30A6FD     391       jnb COL3, $                ; wait until key is released
06A2 D3         391       setb C                   ; mark "key found"
06A3 0206EA     391       ljmp Key_Found           ; use long jump instead of short
06A6            391   CHECK_COL_50:
