094D             98   ; Routine to initialize the ISR   ;
094D             99   ; for timer 0                     ;
094D            100   ;---------------------------------;
094D            101   Timer0_Init:
094D E589       102            mov a, TMOD
094F 54F0       103            anl a, #0xf0 ; 11110000 Clear the bits for timer 0
0951 4401       104            orl a, #0x01 ; 00000001 Configure timer 0 as 16-timer
0953 F589       105            mov TMOD, a
0955            106            
0955 758CF5     107            mov TH0, #high(TIMER0_RELOAD)
0958 758A68     108            mov TL0, #low(TIMER0_RELOAD)
095B            109            
095B            110            ; Enable the timer and interrupts
095B D2A9       111       setb ET0  ; Enable timer 0 interrupt
095D D28C       112       setb TR0  ; Start timer 0
095F 22         113            ret
0960            114   
0960            115   ;---------------------------------;
0960            116   ; ISR for timer 0.  Runs every ms ;
0960            117   ;---------------------------------;
0960            118   Timer0_ISR:
0960 C28C       119            clr TR0
0962 758CF5     120            mov TH0, #high(TIMER0_RELOAD)
0965 758A68     121            mov TL0, #low(TIMER0_RELOAD)
0968 D28C       122            setb TR0
096A            123            
096A            124            
096A 300502     125            jnb SpeakerFlag, skip_speaker
096D B284       126            cpl SOUND_OUT
096F            127            skip_speaker:
096F            128            
096F            129            ; Increment the timers for each FSM. That is all we do here!
096F 0565       130            inc FSM_timer 
0971            131            
0971 E565       132            mov a, FSM_timer
0973 B4FA1D     133            cjne a, #250, FSM_timer_done
0976            134            
0976 D203       135            setb QuarterSecondsFlag
0978            136            
0978 0566       137            inc QuarterSecondsCounter
097A 756500     138            mov FSM_timer, #0x00
097D            139            
097D E566       140            mov a, QuarterSecondsCounter
097F B40411     141            cjne a, #4, FSM_timer_done
0982            142            
0982 756600     143            mov QuarterSecondsCounter, #0x00
0985 0567       144            inc SecondsCounter
0987 0568       145            inc SecondsCounterTotal ; USE THIS FOR THE TOTAL TIMER. IT NEVER RESETS SO DONT WORRY
0989            146            
0989 E568       147            mov a, SecondsCounterTotal
098B B43C05     148            cjne a, #60, FSM_timer_done
098E 0569       149            inc MinutesCounterTotal
