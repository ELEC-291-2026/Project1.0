03AA            178   
03AA            179   ?Display_BCD:
03AA C0E0       180            push acc
03AC            181            ; Write most significant digit
03AC E8         182            mov a, r0
03AD C4         183            swap a
03AE 540F       184            anl a, #0fh
03B0 4430       185            orl a, #30h
03B2 12035B     186            lcall ?WriteData
03B5            187            ; write least significant digit
03B5 E8         188            mov a, r0
03B6 540F       189            anl a, #0fh
03B8 4430       190            orl a, #30h
03BA 12035B     191            lcall ?WriteData
03BD D0E0       192            pop acc
03BF 22         193            ret
