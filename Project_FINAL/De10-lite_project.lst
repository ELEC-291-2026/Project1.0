054B 7F01       337       mov R7, #01h               ; store key code
054D 30A2FD     337       jnb COL1, $                ; wait until key is released
0550 D3         337       setb C                   ; mark "key found"
0551 0206EA     337       ljmp Key_Found           ; use long jump instead of short
0554            337   CHECK_COL_24:
0554 20A409     338       jb  COL2, CHECK_COL_25     ; if column=1 -> no key here -> skip
0557 7F02       338       mov R7, #02h               ; store key code
0559 30A4FD     338       jnb COL2, $                ; wait until key is released
055C D3         338       setb C                   ; mark "key found"
055D 0206EA     338       ljmp Key_Found           ; use long jump instead of short
0560            338   CHECK_COL_25:
