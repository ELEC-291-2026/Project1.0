08AF            184   ;----------------------FUNCTIONS----------------
08AF            185   ;---------------------------------;
08AF            186   ; Routine to initialize the ISR   ;
08AF            187   ; for timer 0                     ;
08AF            188   ;---------------------------------;
08AF            189   Timer0_Init:
08AF E589       190            mov a, TMOD
08B1 54F0       191            anl a, #0xf0 ; 11110000 Clear the bits for timer 0
08B3 4401       192            orl a, #0x01 ; 00000001 Configure timer 0 as 16-timer
08B5 F589       193            mov TMOD, a
08B7            194            
08B7 85668C     195            mov TH0, Timer0Reload+1
08BA 85658A     196            mov TL0, Timer0Reload+0
08BD            197            
08BD            198            ; Enable the timer and interrupts
08BD D2A9       199       setb ET0  ; Enable timer 0 interrupt
08BF D28C       200       setb TR0  ; Start timer 0
08C1 22         201            ret
08C2            202   
08C2            203   ;---------------------------------;
08C2            204   ; ISR for timer 0.  Set to execute;
08C2            205   ; every 1/4096Hz to generate a    ;
08C2            206   ; 2048 Hz wave at pin SOUND_OUT   ;
08C2            207   ;---------------------------------;
08C2            208   
08C2            209   Timer0_ISR:
08C2 C28C       210            clr TR0
08C4 85668C     211            mov TH0, Timer0Reload+1
08C7 85658A     212            mov TL0, Timer0Reload+0
08CA D28C       213            setb TR0
08CC B284       214            cpl SOUND_OUT ; Connect speaker the pin assigned to 'SOUND_OUT'!
08CE 32         215            reti
08CF            216   
08CF            217   ;---------------------------------;
08CF            218   ; Routine to initialize the ISR   ;
08CF            219   ; for timer 2                     ;
08CF            220   ;---------------------------------;
08CF            221   Timer2_Init:
08CF 75C800     222            mov T2CON, #0 ; Stop timer/counter.  Autoreload mode.
08D2 75CDF5     223            mov TH2, #high(TIMER2_RELOAD)
08D5 75CC27     224            mov TL2, #low(TIMER2_RELOAD)
08D8            225            ; Set the reload value
08D8 75CBF5     226            mov RCAP2H, #high(TIMER2_RELOAD)
08DB 75CA27     227            mov RCAP2L, #low(TIMER2_RELOAD)
08DE            228            ; Enable the timer and interrupts
08DE D2AD       229       setb ET2  ; Enable timer 2 interrupt
08E0 D2CA       230       setb TR2  ; Enable timer 2
08E2            231       
08E2 22         232            ret
08E3            233   
08E3            234   ;---------------------------------;
08E3            235   ; ISR for timer 2.  Runs every ms ;
08E3            236   ;---------------------------------;
08E3            237   
08E3            238   Timer2_ISR:
08E3            239   
08E3 C2CF       240            clr TF2  ; Timer 2 doesn't clear TF2 automatically. Do it in ISR
08E5            241            ; Increment the timers for each FSM. That is all we do here!
08E5 0567       242            inc FSM_timer 
08E7            243            
08E7 E567       244            mov a, FSM_timer
08E9 B4FA1D     245            cjne a, #250, FSM_timer_done
08EC            246            
08EC D203       247            setb QuarterSecondsFlag
08EE            248            
08EE 0568       249            inc QuarterSecondsCounter
08F0 756700     250            mov FSM_timer, #0x00
08F3            251            
08F3 E568       252            mov a, QuarterSecondsCounter
08F5 B40411     253            cjne a, #4, FSM_timer_done
08F8            254            
08F8 756800     255            mov QuarterSecondsCounter, #0x00
08FB 0569       256            inc SecondsCounter
08FD 056A       257            inc SecondsCounterTotal ; USE THIS FOR THE TOTAL TIMER. IT NEVER RESETS SO DONT WORRY
08FF            258            
08FF E56A       259            mov a, SecondsCounterTotal
0901 B43C05     260            cjne a, #60, FSM_timer_done
0904 056B       261            inc MinutesCounterTotal
0906 756A00     262            mov SecondsCounterTotal, #0x00
0909            263            
0909            264            FSM_timer_done:
0909 32         265            reti
