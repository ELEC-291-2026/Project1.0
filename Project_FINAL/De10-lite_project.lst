0947            242   ; The 8-bit hex number passed in the accumulator is converted to
0947            243   ; BCD and stored in [R1, R0]
0947            244   Hex_to_bcd_8bit:
0947 75F064     245            mov b, #100
094A 84         246            div ab
094B F9         247            mov R1, a   ; After dividing, a has the 100s
094C E5F0       248            mov a, b    ; Remainder is in register b
094E 75F00A     249            mov b, #10
0951 84         250            div ab ; The tens are stored in a, the units are stored in b 
0952 C4         251            swap a
0953 54F0       252            anl a, #0xf0
0955 45F0       253            orl a, b
0957 F8         254            mov R0, a
0958 22         255            ret
