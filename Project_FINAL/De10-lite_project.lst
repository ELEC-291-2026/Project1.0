06D5            406   
06D5            407   ;--------------------------------------------------
06D5            408   ; Key_Found:
06D5            409   ;   R7 = key code (0-F), C = 1 when we get here.
06D5            410   ;   A/B/C/D (0Ah-0Dh) -> mode select
06D5            411   ;   * (0Eh)           -> delete / backspace one digit
06D5            412   ;   # (0Fh)           -> clear all digits
06D5            413   ;   others (0-9, maybe E/F) -> digit
06D5            414   ;--------------------------------------------------
06D5            415   
06D5            416   Key_Found:
06D5 EF         417       mov A, R7
06D6            418   
06D6            419       ; --- Mode A (soak temperature) ---
06D6 B40A0B     420       cjne A, #0Ah, KF_CheckB
06D9 12048B     421       lcall Save_Current_BCD_Into_Param
06DC 756400     422       mov   active_param, #0       ; A: soak_temp
06DF 1204B2     423       lcall Load_Param_Into_BCD
06E2 C3         424       clr C                        ; do not treat as digit
06E3 22         425       ret
06E4            426   
06E4            427   KF_CheckB:
06E4            428       ; --- Mode B (soak time) ---
06E4 B40B0B     429       cjne A, #0Bh, KF_CheckC
06E7 12048B     430       lcall Save_Current_BCD_Into_Param
06EA 756401     431       mov   active_param, #1       ; B: soak_time
06ED 1204B2     432       lcall Load_Param_Into_BCD
06F0 C3         433       clr C
06F1 22         434       ret
06F2            435   
06F2            436   KF_CheckC:
06F2            437       ; --- Mode C (reflow temperature) ---
06F2 B40C0B     438       cjne A, #0Ch, KF_CheckD
06F5 12048B     439       lcall Save_Current_BCD_Into_Param
06F8 756402     440       mov   active_param, #2       ; C: reflow_temp
06FB 1204B2     441       lcall Load_Param_Into_BCD
06FE C3         442       clr C
06FF 22         443       ret
0700            444   
0700            445   KF_CheckD:
0700            446       ; --- Mode D (reflow time) ---
0700 B40D0B     447       cjne A, #0Dh, KF_CheckStar
0703 12048B     448       lcall Save_Current_BCD_Into_Param
0706 756403     449       mov   active_param, #3       ; D: reflow_time
0709 1204B2     450       lcall Load_Param_Into_BCD
070C C3         451       clr C
070D 22         452       ret
070E            453   
070E            454   KF_CheckStar:
070E            455       ; --- '*' key (code 0Eh) -> delete / backspace ---
070E B40E05     456       cjne A, #0Eh, KF_CheckHash
0711            457       ; Backspace = shift digits right by 1 digit
0711 12045F     458       lcall Shift_Digits_Right
0714 C3         459       clr C                        ; no new digit for main loop
0715 22         460       ret
0716            461   
0716            462   KF_CheckHash:
0716            463       ; --- '#' key (code 0Fh) -> clear ---
0716 B40F0D     464       cjne A, #0Fh, KF_Digit
0719            465       ; Clear all BCD digits for current parameter
0719 E4         466       clr A
071A F538       467       mov bcd+0, A
071C F539       468       mov bcd+1, A
071E F53A       469       mov bcd+2, A
0720 F53B       470       mov bcd+3, A
0722 F53C       471       mov bcd+4, A
0724 C3         472       clr C                        ; no digit to insert
0725 22         473       ret
0726            474   
0726            475   KF_Digit:
0726            476       ; Not A/B/C/D/*/# -> treat as numeric digit key
0726            477       ; R7 holds the digit, Carry = 1 -> main loop will append it
0726 22         478       ret
