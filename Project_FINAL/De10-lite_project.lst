                 -1   	$include(keypad_lib_3.asm)
03C2              1   
03C2              2   CSEG
03C2              3   
03C2              4   ;--------------------------------------------------
03C2              5   ; Lookup table for 7-segment display patterns (common anode)
03C2              6   ; Index 0-F = segment pattern
03C2              7   ;--------------------------------------------------
03C2              8   
03C2              9   myLUT:
03C2 C0F9A4B0    10       DB 0C0h, 0F9h, 0A4h, 0B0h, 099h        ; digits 0-4
     99
03C7 9282F880    11       DB 092h, 082h, 0F8h, 080h, 090h        ; digits 5-9
     90
03CC 8883C6A1    12       DB 088h, 083h, 0C6h, 0A1h, 086h, 08Eh  ; A-F
     868E
03D2             13   
03D2             14   ;--------------------------------------------------
03D2             15   ; Macro: showBCD
03D2             16   ; Input : one byte containing two BCD digits
03D2             17   ; Output: two 7-seg displays
03D2             18   ;   %0 = bcd byte
03D2             19   ;   %1 = HEX low
03D2             20   ;   %2 = HEX high
03D2             21   ;--------------------------------------------------
03D2             22   
                 23   showBCD MAC
                 24       ; ---- Display lower nibble (LSD) ----
                 25       mov  A, %0           ; Load BCD byte
                 26       anl  A, #0Fh         ; Keep lower 4 bits
                 27       movc A, @A+dptr      ; Convert using LUT
                 28       mov  %1, A           ; Output to first HEX display
                 29   
                 30       ; ---- Display upper nibble (MSD) ----
                 31       mov  A, %0
                 32       swap A               ; Swap nibbles
                 33       anl  A, #0Fh
                 34       movc A, @A+dptr
                 35       mov  %2, A           ; Output to second HEX display
                 36   ENDMAC
03D2             37   
03D2             38   
03D2             39   ;--------------------------------------------------
03D2             40   ; Display routine - show BCD number on HEX displays
03D2             41   ; KEY3: 0 = show high digits, 1 = show low digits
03D2             42   ; LEDRA.7: overflow indicator if bcd+3 or bcd+4 != 0
03D2             43   ;--------------------------------------------------
03D2             44   
03D2             45   Display:
03D2 9003C2      46       mov dptr, #myLUT     ; Point to lookup table
03D5             47   
03D5             48       ; If digits 10-7 (bcd+3 and bcd+4) are NOT zero
03D5             49       ; turn ON LEDRA.7 as overflow indicator
03D5             50   
03D5 E53B        51       mov A, bcd+3
03D7 453C        52       orl A, bcd+4
03D9 6004        53       jz  Display_L1
03DB D2EF        54       setb LEDRA.7         ; Alert LED on
03DD 8002        55       sjmp Display_L2
03DF             56   Display_L1:
03DF C2EF        57       clr LEDRA.7          ; Alert LED off
03E1             58   Display_L2:
03E1             59   
03E1             60       ; If KEY3 pressed (assuming active low) show HIGH digits
03E1             61       ; Otherwise show LOW digits
03E1             62   
03E1 30FB2F      63       jnb KEY.3, Display_high_digits
03E4             64   
03E4             65       ; Show lower 6 digits
03E4             66       ; ---- Display lower nibble (LSD) ----
03E4 E538        66       mov  A, bcd+0           ; Load BCD byte
03E6 540F        66       anl  A, #0Fh         ; Keep lower 4 bits
03E8 93          66       movc A, @A+dptr      ; Convert using LUT
03E9 F591        66       mov  HEX0, A           ; Output to first HEX display
03EB             66   
03EB             66       ; ---- Display upper nibble (MSD) ----
03EB E538        66       mov  A, bcd+0
03ED C4          66       swap A               ; Swap nibbles
03EE 540F        66       anl  A, #0Fh
03F0 93          66       movc A, @A+dptr
03F1 F592        66       mov  HEX1, A           ; Output to second HEX display
03F3             67       ; ---- Display lower nibble (LSD) ----
03F3 E539        67       mov  A, bcd+1           ; Load BCD byte
03F5 540F        67       anl  A, #0Fh         ; Keep lower 4 bits
03F7 93          67       movc A, @A+dptr      ; Convert using LUT
03F8 F593        67       mov  HEX2, A           ; Output to first HEX display
03FA             67   
03FA             67       ; ---- Display upper nibble (MSD) ----
03FA E539        67       mov  A, bcd+1
03FC C4          67       swap A               ; Swap nibbles
03FD 540F        67       anl  A, #0Fh
03FF 93          67       movc A, @A+dptr
0400 F594        67       mov  HEX3, A           ; Output to second HEX display
0402             68       ; ---- Display lower nibble (LSD) ----
0402 E53A        68       mov  A, bcd+2           ; Load BCD byte
0404 540F        68       anl  A, #0Fh         ; Keep lower 4 bits
0406 93          68       movc A, @A+dptr      ; Convert using LUT
0407 F58E        68       mov  HEX4, A           ; Output to first HEX display
0409             68   
0409             68       ; ---- Display upper nibble (MSD) ----
0409 E53A        68       mov  A, bcd+2
040B C4          68       swap A               ; Swap nibbles
040C 540F        68       anl  A, #0Fh
040E 93          68       movc A, @A+dptr
040F F58F        68       mov  HEX5, A           ; Output to second HEX display
0411 8024        69       sjmp Display_end
0413             70   
0413             71   Display_high_digits:
0413             72       ; Show upper 4 digits
0413             73       ; ---- Display lower nibble (LSD) ----
0413 E53B        73       mov  A, bcd+3           ; Load BCD byte
0415 540F        73       anl  A, #0Fh         ; Keep lower 4 bits
0417 93          73       movc A, @A+dptr      ; Convert using LUT
0418 F591        73       mov  HEX0, A           ; Output to first HEX display
041A             73   
041A             73       ; ---- Display upper nibble (MSD) ----
041A E53B        73       mov  A, bcd+3
041C C4          73       swap A               ; Swap nibbles
041D 540F        73       anl  A, #0Fh
041F 93          73       movc A, @A+dptr
0420 F592        73       mov  HEX1, A           ; Output to second HEX display
0422             74       ; ---- Display lower nibble (LSD) ----
0422 E53C        74       mov  A, bcd+4           ; Load BCD byte
0424 540F        74       anl  A, #0Fh         ; Keep lower 4 bits
0426 93          74       movc A, @A+dptr      ; Convert using LUT
