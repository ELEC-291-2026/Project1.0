                260   Mov_A_to_B MAC
                261   ;%0 is A, %1 is B
                262   	mov %1+0, %0+0
                263   	mov %1+1, %0+1
                264   	mov %1+2, #0
                265   	mov %1+3, #0
                266   ENDMAC
