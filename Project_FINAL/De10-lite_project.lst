0034              9   
093F             10   cseg
093F             11   
093F             12   ; -------- Note reload values (CLK = 33,333,333 Hz, prescaler = 12) --------
093F             13   ; Timer0 overflow rate = 2*freq (because we toggle pin each overflow)
093F             14   
093F             15   R_C5  EQU 0xF5A2   ; 523.25 Hz (Do)
093F             16   R_Cs5 EQU 0xF63F   ; 622.25 Hz (Do Sharp)
093F             17   R_D5  EQU 0xF6C3   ; 587.33 Hz (Re)
093F             18   R_Ds5 EQU 0xF74D   ; 739.99 Hz (Dsharp)
093F             19   R_E5  EQU 0xF7C5   ; 659.26 Hz (Mi)
093F             20   R_F5  EQU 0xF83B   ; 698.46 Hz (Fa)
093F             21   R_Fs5 EQU 0xF8AC   ; 739.99 Hz (Fa Sharp)
093F             22   R_G5  EQU 0xF914   ; 783.99 Hz (Sol)
093F             23   R_Gs5 EQU 0xF97B   ; 830.61 Hz (Sol Sharp)
093F             24   R_A5  EQU 0xF9D6   ; 880.00 Hz (La)
093F             25   R_As5 EQU 0xFA31   ; 932.33 Hz (La Sharp)
093F             26   R_B5  EQU 0xFA82   ; 987.77 Hz (Si)
093F             27   R_C6  EQU 0xFAD0   ; 1046.50 Hz (Do - higher octave)
093F             28   R_Cs6 EQU 0xFB1F   ; 1108.73 Hz
093F             29   R_D6  EQU 0xFB61   ; 1174.66 Hz
093F             30   R_Ds6 EQU 0xFBA7   ; 1244.51 Hz
093F             31   R_E6  EQU 0xFBE3   ; 1318.51 Hz
093F             32   R_F6  EQU 0xFC1D   ; 1396.91 Hz
093F             33   R_Fs6 EQU 0xFC56   ; 1479.98 Hz
093F             34   R_G6  EQU 0xFC8A   ; 1567.98 Hz
093F             35   R_Gs6 EQU 0xFCBD   ; 1661.22 Hz
093F             36   R_A6  EQU 0xFCEB   ; 1760.00 Hz
093F             37   R_As6 EQU 0xFD19   ; 1864.66 Hz
093F             38   R_B6  EQU 0xFD41   ; 1975.53 Hz
093F             39   R_C7  EQU 0xFD68   ; 2093.00 Hz
093F             40   No_Note  EQU 0x0000   ; 000 Hz
093F             41   
093F             42   
