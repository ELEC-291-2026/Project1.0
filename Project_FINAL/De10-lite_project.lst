                220   Mov_A_to_B MAC
                221   ;%0 is A, %1 is B
                222   	mov %1+0, %0+0
                223   	mov %1+1, %0+1
                224   	mov %1+2, #0
                225   	mov %1+3, #0
                226   ENDMAC
