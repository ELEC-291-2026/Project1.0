0000              1   ; main project file
                  3   $LIST
0000              5   
0000              6   
0000              7   CLK              EQU 33333333 ; Microcontroller system crystal frequency in Hz
0000              8   TIMER2_RATE      EQU 1000     ; 1000Hz, for a timer tick of 1ms
0000              9   TIMER2_RELOAD    EQU ((65536-(CLK/(12*TIMER2_RATE))))
0000             10   TIMER0_RATE     EQU 1024    ; 2048Hz squarewave (peak amplitude of CEM-1203 speaker)
0000             11   TIMER0_RELOAD   EQU ((65536-(CLK/TIMER0_RATE)))
0000             12   FREQ                     EQU 33333333
0000             13   BAUD                     EQU 115200
0000             14   T1LOAD                   EQU 256-(FREQ/(32*12*BAUD))
0000             15   T2LOAD          EQU 65536-(FREQ/(32*BAUD)) 
0000             16   
0000             17   ;PIN Assignemet
0000             18   ;Need to figure out wich ADC pins the LM335 and OP07 are on 
0000             19   LM335_ADC equ 0
0000             20   OP07_ADC equ 1
0000             21   
0000             22   
0000             23   ; Reset vector
0000             24   org 0x0000
0000 020F5D      25       ljmp main
0003             26       
