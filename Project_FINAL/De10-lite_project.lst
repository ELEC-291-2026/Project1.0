09AB            100   
09AB            101       ; RT=xxx   (reflow_temp)
09AB            102       ; --- Hundreds digit (from low nibble of var+1) ---
09AB E55F       102       mov  a, reflow_temp+1        ; load high BCD byte
09AD 540F       102       anl  a, #0FH        ; keep low nibble = hundreds
09AF 4430       102       orl  a, #'0'        ; convert 0–9 -> ASCII
09B1 12035D     102       lcall ?WriteData
09B4            102   
09B4            102       ; --- Tens digit (from high nibble of var+0) ---
09B4 E55E       102       mov  a, reflow_temp+0        ; load low BCD byte
09B6 C4         102       swap a              ; high nibble -> low nibble
09B7 540F       102       anl  a, #0FH        ; keep that nibble
09B9 4430       102       orl  a, #'0'        ; 0–9 -> ASCII
09BB 12035D     102       lcall ?WriteData
09BE            102   
09BE            102       ; --- Ones digit (from low nibble of var+0) ---
09BE E55E       102       mov  a, reflow_temp+0        ; load low BCD byte again
09C0 540F       102       anl  a, #0FH        ; low nibble = ones
09C2 4430       102       orl  a, #'0'        ; 0–9 -> ASCII
09C4 12035D     102       lcall ?WriteData
09C7            103   
09C7            104       ; "  " (two spaces)
09C7 7420       105       mov  a, #' '
09C9 12035D     106       lcall ?WriteData
09CC 7420       107       mov  a, #' '
09CE 12035D     108       lcall ?WriteData
