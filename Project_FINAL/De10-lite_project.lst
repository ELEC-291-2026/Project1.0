                259   Mov_A_to_B MAC
                260   ;%0 is A, %1 is B
                261   	mov %1+0, %0+0
                262   	mov %1+1, %0+1
                263   	mov %1+2, #0
                264   	mov %1+3, #0
                265   ENDMAC
