094F            117   Timer0_Init:
094F E589       118            mov a, TMOD
0951 54F0       119            anl a, #0xf0 ; 11110000 Clear the bits for timer 0
0953 4401       120            orl a, #0x01 ; 00000001 Configure timer 0 as 16-timer
0955 F589       121            mov TMOD, a
0957            122            
0957 758CF5     123            mov TH0, #high(TIMER0_RELOAD)
095A 758A68     124            mov TL0, #low(TIMER0_RELOAD)
