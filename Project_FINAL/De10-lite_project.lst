                423   powerPercent MAC
                424   	;Convert percentage of time into a time it needs to be on %0 is percentage(i.e 20 is 20%) on, %1 is total time, %2 is the time on
                425   	;load_x(%0)
                426   	mov x+0, %0
                427   	mov x+1, #0
                428   	mov x+2, #0
                429   	mov x+3, #0
                430   	;converts x to a percentage through fractions
                431   	Load_Y_Var16(%1)
                432   	lcall mul32
                433   	
                434   	load_y(100)
                435   	lcall div32
                436   	
                437   	mov %2+0, x+0
                438   	mov %2+1, x+1
                439   ENDMAC
