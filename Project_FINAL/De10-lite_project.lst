                173   Mov_A_to_B16Bit MAC
                174   ;%0 is A, %1 is B
                175   	mov %1+0, %0+0
                176   	mov %1+1, %0+1
                177   	mov %1+2, #0
                178   	mov %1+3, #0
                179   ENDMAC
