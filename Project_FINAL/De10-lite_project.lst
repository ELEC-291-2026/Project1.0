0B07            252   
0B07            253   ; The 8-bit hex number passed in the accumulator is converted to
0B07            254   ; BCD and stored in [R1, R0]
0B07            255   Hex_to_bcd_8bit:
0B07 75F064     256            mov b, #100
0B0A 84         257            div ab
0B0B F9         258            mov R1, a   ; After dividing, a has the 100s
0B0C E5F0       259            mov a, b    ; Remainder is in register b
0B0E 75F00A     260            mov b, #10
0B11 84         261            div ab ; The tens are stored in a, the units are stored in b 
0B12 C4         262            swap a
0B13 54F0       263            anl a, #0xf0
0B15 45F0       264            orl a, b
0B17 F8         265            mov R0, a
0B18 22         266            ret
0B19            267            
0B19            268            
0B19            269   ;We should probably start using this from now on oh well live laugh love
                270   Mov_A_to_B MAC
                271   ;%0 is A, %1 is B
                272   	mov %1+0, %0+0
                273   	mov %1+1, %0+1
                274   	mov %1+2, #0
                275   	mov %1+3, #0
                276   ENDMAC
