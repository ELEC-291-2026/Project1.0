073C              7       ; Configure serial port and baud rate using Timer 1
073C C28E         8       clr TR1              ; Disable timer 1
073E 53890F       9       anl TMOD, #0FH       ; Clear timer 1 mode bits
0741 438920      10       orl TMOD, #20H       ; Set timer 1 to mode 2 (8-bit auto-reload)
0744 758D01      11       mov TH1, #high(T1LOAD)     ; Load reload value
0747 758B00      12       mov TL1, #low(T1LOAD); Load initial value
074A D28E        13       setb TR1             ; Enable timer 1
074C 759852      14       mov SCON, #52H       ; Configure serial port (mode 1, REN=1)
074F 22          15       ret
