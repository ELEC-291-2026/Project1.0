09C8 E589       112            mov a, TMOD
09CA 54F0       113            anl a, #0xf0 ; 11110000 Clear the bits for timer 0
09CC 4401       114            orl a, #0x01 ; 00000001 Configure timer 0 as 16-timer
09CE F589       115            mov TMOD, a
