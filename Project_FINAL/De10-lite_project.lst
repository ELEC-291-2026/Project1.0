047E            147   ;--------------------------------------------------
047E            148   ; 25 ms delay (software debounce)
047E            149   ;--------------------------------------------------
047E            150   
047E            151   Wait25ms:
047E 780F       152       mov R0, #15
0480 794A       153   L6: mov R1, #74
0482 7AFA       154   L5: mov R2, #250
0484 DAFE       155   L4: djnz R2, L4
0486 D9FA       156       djnz R1, L5
0488 D8F6       157       djnz R0, L6
048A 22         158       ret
