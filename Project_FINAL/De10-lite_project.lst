090B            203   ; The 8-bit hex number passed in the accumulator is converted to
090B            204   ; BCD and stored in [R1, R0]
090B            205   Hex_to_bcd_8bit:
090B 75F064     206            mov b, #100
090E 84         207            div ab
090F F9         208            mov R1, a   ; After dividing, a has the 100s
0910 E5F0       209            mov a, b    ; Remainder is in register b
0912 75F00A     210            mov b, #10
0915 84         211            div ab ; The tens are stored in a, the units are stored in b 
0916 C4         212            swap a
0917 54F0       213            anl a, #0xf0
0919 45F0       214            orl a, b
091B F8         215            mov R0, a
091C 22         216            ret
