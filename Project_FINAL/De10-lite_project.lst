0489            167   ; Save current BCD (bcd+0..bcd+1) into active parameter
0489            168   Save_Current_BCD_Into_Param:
0489 E564       169       mov A, active_param
048B B40007     170       cjne A, #0, Save_NotA
048E            171       ; A: soak_temp
048E 853858     172       mov soak_temp+0, bcd+0
0491 853959     173       mov soak_temp+1, bcd+1
0494 22         174       ret
0495            175   Save_NotA:
0495 B40107     176       cjne A, #1, Save_NotB
0498            177       ; B: soak_time
0498 85385A     178       mov soak_time+0, bcd+0
049B 85395B     179       mov soak_time+1, bcd+1
049E 22         180       ret
049F            181   Save_NotB:
049F B40207     182       cjne A, #2, Save_NotC
04A2            183       ; C: reflow_temp
04A2 85385E     184       mov reflow_temp+0, bcd+0
04A5 85395F     185       mov reflow_temp+1, bcd+1
04A8 22         186       ret
04A9            187   Save_NotC:
04A9            188       ; D: reflow_time (default case)
04A9 853860     189       mov reflow_time+0, bcd+0
04AC 853961     190       mov reflow_time+1, bcd+1
