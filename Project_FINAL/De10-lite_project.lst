04BB B40007     202       cjne A, #0, Load_NotA
04BE            203       ; A: soak_temp
04BE 855838     204       mov bcd+0, soak_temp
04C1 855939     205       mov bcd+1, soak_temp+1
04C4 22         206       ret
04C5            207   Load_NotA:
04C5 B40107     208       cjne A, #1, Load_NotB
04C8            209       ; B: soak_time
04C8 855A38     210       mov bcd+0, soak_time
04CB 855B39     211       mov bcd+1, soak_time+1
04CE 22         212       ret
04CF            213   Load_NotB:
04CF B40207     214       cjne A, #2, Load_NotC
04D2            215       ; C: reflow_temp
04D2 855E38     216       mov bcd+0, reflow_temp
04D5 855F39     217       mov bcd+1, reflow_temp+1
04D8 22         218       ret
04D9            219   Load_NotC:
04D9            220       ; D: reflow_time (default)
04D9 856038     221       mov bcd+0, reflow_time
04DC 856139     222       mov bcd+1, reflow_time+1
04DF 22         223       ret
04E0            224   
04E0            225   
04E0            226   ;--------------------------------------------------
04E0            227   ; Macro: Check one keypad column
04E0            228   ; If pressed -> R7 = key value, C=1, jump to Key_Found
04E0            229   ; %0 = column bit, %1 = key code (immediate)
04E0            230   ;--------------------------------------------------
04E0            231   
                232   CHECK_COLUMN MAC
                233       jb  %0, CHECK_COL_%M     ; if column=1 -> no key here -> skip
                234       mov R7, %1               ; store key code
                235       jnb %0, $                ; wait until key is released
                236       setb C                   ; mark "key found"
                237       ljmp Key_Found           ; use long jump instead of short
                238   CHECK_COL_%M:
                239   ENDMAC
04E0            240   
04E0            241   
04E0            242   ;--------------------------------------------------
04E0            243   ; Configure GPIO directions for keypad
04E0            244   ;--------------------------------------------------
04E0            245   
04E0            246   Configure_Keypad_Pins:
04E0 439B54     247       orl P1MOD, #01010100b    ; Rows as output on P1
04E3 439C01     248       orl P2MOD, #00000001b
04E6 539CAB     249       anl P2MOD, #10101011b    ; Columns as input on P2
04E9 539DFE     250       anl P3MOD, #11111110b    ; Column on P3.0 input
04EC 22         251       ret
04ED            252   
