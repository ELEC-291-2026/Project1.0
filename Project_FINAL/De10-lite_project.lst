048B            161   ;--------------------------------------------------
048B            162   ; Helper routines for parameter storage
048B            163   ; Each parameter value lives in bcd+0..bcd+1
048B            164   ; active_param: 0=A, 1=B, 2=C, 3=D
048B            165   ;--------------------------------------------------
048B            166   
048B            167   ; Save current BCD (bcd+0..bcd+1) into active parameter
048B            168   Save_Current_BCD_Into_Param:
048B E564       169       mov A, active_param
048D B40007     170       cjne A, #0, Save_NotA
0490            171       ; A: soak_temp
0490 853858     172       mov soak_temp+0, bcd+0
0493 853959     173       mov soak_temp+1, bcd+1
0496 22         174       ret
0497            175   Save_NotA:
0497 B40107     176       cjne A, #1, Save_NotB
049A            177       ; B: soak_time
049A 85385A     178       mov soak_time+0, bcd+0
049D 85395B     179       mov soak_time+1, bcd+1
04A0 22         180       ret
04A1            181   Save_NotB:
04A1 B40207     182       cjne A, #2, Save_NotC
04A4            183       ; C: reflow_temp
04A4 85385E     184       mov reflow_temp+0, bcd+0
04A7 85395F     185       mov reflow_temp+1, bcd+1
04AA 22         186       ret
04AB            187   Save_NotC:
04AB            188       ; D: reflow_time (default case)
04AB 853860     189       mov reflow_time+0, bcd+0
04AE 853961     190       mov reflow_time+1, bcd+1
04B1 22         191       ret
04B2            192   
04B2            193   
04B2            194   ; Load active parameter into BCD (bcd+0..bcd+1)
04B2            195   ; Clear the higher digits.
04B2            196   Load_Param_Into_BCD:
04B2 753A00     197       mov bcd+2, #00h
04B5 753B00     198       mov bcd+3, #00h
04B8 753C00     199       mov bcd+4, #00h
04BB            200   
04BB E564       201       mov A, active_param
04BD B40007     202       cjne A, #0, Load_NotA
04C0            203       ; A: soak_temp
04C0 855838     204       mov bcd+0, soak_temp
04C3 855939     205       mov bcd+1, soak_temp+1
04C6 22         206       ret
04C7            207   Load_NotA:
04C7 B40107     208       cjne A, #1, Load_NotB
04CA            209       ; B: soak_time
04CA 855A38     210       mov bcd+0, soak_time
04CD 855B39     211       mov bcd+1, soak_time+1
04D0 22         212       ret
