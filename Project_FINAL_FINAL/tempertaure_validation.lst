03D0             73   
03D0             74   ; Look-up table for 7-seg displays
03D0             75   myLUT:
03D0 C0F9A4B0    76       DB 0xC0, 0xF9, 0xA4, 0xB0, 0x99        ; 0 TO 4
     99
03D5 9282F880    77       DB 0x92, 0x82, 0xF8, 0x80, 0x90        ; 4 TO 9
     90
03DA 8883C6A1    78       DB 0x88, 0x83, 0xC6, 0xA1, 0x86, 0x8E  ; A to F
     868E
