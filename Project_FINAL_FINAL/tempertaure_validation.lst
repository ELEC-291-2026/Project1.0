0595 753600     291            mov y+2, #low (12300 / 0x10000) 
0598 753700     291            mov y+3, #high(12300 / 0x10000) 
059B 120279     292       lcall div32           ; x = scaled TC temperature (e.g., 123 for 12.3C)
059E            293   
059E            294       ; Save this intermediate result in y to free up x for CJ scaling
059E 853034     295       mov y+0, x+0
05A1 853135     296       mov y+1, x+1
05A4 853236     297       mov y+2, x+2
05A7 853337     298       mov y+3, x+3
05AA            299   
05AA            300       ; Load Cold Junction and scale it by 10 to match units
05AA 854130     301       mov x+0, V_cj+0
05AD 854231     302       mov x+1, V_cj+1
05B0 854332     303       mov x+2, V_cj+2
05B3 854433     304       mov x+3, V_cj+3
05B6            305       
05B6 C034       306       push y+0              ; Save our TC result safely
05B8 C035       307       push y+1
05BA C036       308       push y+2
05BC C037       309       push y+3
05BE            310       
05BE 75340A     311            mov y+0, #low (10 % 0x10000) 
05C1 753500     311            mov y+1, #high(10 % 0x10000) 
05C4 753600     311            mov y+2, #low (10 / 0x10000) 
05C7 753700     311            mov y+3, #high(10 / 0x10000) 
05CA 120185     312       lcall mul32           ; x = CJ * 10
05CD            313       
05CD D037       314       pop y+3               ; Restore TC result into y
05CF D036       315       pop y+2
05D1 D035       316       pop y+1
05D3 D034       317       pop y+0
05D5            318       
05D5 1200CC     319       lcall add32           ; Final result: (TC_temp*10) + (CJ_temp*10)
05D8            320   
05D8            321       ; ---------------------------------------------------------
05D8            322       ; 4) Display
05D8            323       ; ---------------------------------------------------------
05D8 120027     324       lcall hex2bcd
05DB 1203ED     325       lcall Display_Voltage_7seg
05DE 120411     326       lcall Display_Voltage_LCD
05E1 120451     327       lcall Display_Voltage_Serial
05E4            328       
05E4 7F14       329       mov R7, #20 
05E6            330   delay_loop:     
05E6 1203E0     331       lcall Wait50ms     
05E9 DFFB       332       djnz R7, delay_loop
05EB 0204DD     333       ljmp forever
