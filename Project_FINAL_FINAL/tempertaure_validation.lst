04E4 753300     236       mov x+3, #0
04E7 753200     237       mov x+2, #0
04EA 85A331     238       mov x+1, ADC_H
04ED 85A230     239       mov x+0, ADC_L
04F0            240   
04F0 753488     241            mov y+0, #low (5000 % 0x10000) 
04F3 753513     241            mov y+1, #high(5000 % 0x10000) 
04F6 753600     241            mov y+2, #low (5000 / 0x10000) 
04F9 753700     241            mov y+3, #high(5000 / 0x10000) 
04FC 120185     242       lcall mul32
