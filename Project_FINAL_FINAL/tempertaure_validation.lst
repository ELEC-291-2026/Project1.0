03E0             80   Wait50ms:
03E0             81   ;33.33MHz, 1 clk per cycle: 0.03us
03E0 781E        82   mov R0, #30
03E2             83   Wait50ms_L3:
03E2 794A        84   mov R1, #74
03E4             85   Wait50ms_L2:
03E4 7AFA        86   mov R2, #250
03E6             87   Wait50ms_L1:
03E6 DAFE        88   djnz R2, Wait50ms_L1 ;3*250*0.03us=22.5us
03E8 D9FA        89       djnz R1, Wait50ms_L2 ;74*22.5us=1.665ms
03EA D8F6        90       djnz R0, Wait50ms_L3 ;1.665ms*30=50ms
03EC 22          91       ret
