0319             59   cseg
0319             60   ; These 'equ' must match the wiring between the DE10Lite board and the LCD!
0319             61   ; P0 is in connector JPIO.  Check "CV-8052 Soft Processor in the DE10Lite Board: Getting
0319             62   ; Started Guide" for the details.
0319             63   ELCD_RS equ P1.7
0319             64   ; ELCD_RW equ Px.x ; Not used.  Connected to ground
0319             65   ELCD_E  equ P1.1
0319             66   ELCD_D4 equ P0.7
0319             67   ELCD_D5 equ P0.5
0319             68   ELCD_D6 equ P0.3
0319             69   ELCD_D7 equ P0.1
