04F3 E5E8       247       mov a, SWA
04F5 5407       248       anl a, #0x07
04F7 FF         249       mov R7, a             ; Save channel number
04F8 F5A1       250       mov ADC_C, a
04FA            251   
04FA 753300     252       mov x+3, #0
04FD 753200     253       mov x+2, #0
0500 85A331     254       mov x+1, ADC_H
0503 85A230     255       mov x+0, ADC_L
0506            256   
0506 753488     257            mov y+0, #low (5000 % 0x10000) 
0509 753513     257            mov y+1, #high(5000 % 0x10000) 
050C 753600     257            mov y+2, #low (5000 / 0x10000) 
050F 753700     257            mov y+3, #high(5000 / 0x10000) 
0512 12019B     258       lcall mul32
