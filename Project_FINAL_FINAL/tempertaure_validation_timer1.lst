0518 753510     259            mov y+1, #high(4096 % 0x10000) 
051B 753600     259            mov y+2, #low (4096 / 0x10000) 
051E 753700     259            mov y+3, #high(4096 / 0x10000) 
0521 12028F     260       lcall div32           ; x now holds Vtc in mV
0524            261       
0524            262       ; Save it
