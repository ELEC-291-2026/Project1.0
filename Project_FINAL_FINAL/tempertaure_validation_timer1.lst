0003             36   InitSerialPort:
0003 C28E        37       clr TR1                   
0005 53890F      38       anl TMOD, #0x0F           
0008 438920      39       orl TMOD, #0x20           
000B 758DFB      40       mov TH1, #0xFB            ; 256-(33333333/(32*12*19200)) = 251
000E 758BFB      41       mov TL1, #0xFB            
0011 759852      42       mov SCON, #0x52           
0014 D28E        43       setb TR1                  
0016 22          44       ret
0017             45       
0017             46    InitSerialPort2:
0017 758920      47       mov TMOD, #0x20       ; Timer1, mode2 (8-bit auto-reload)
001A 758DFD      48       mov TH1, #-3          ; 9600 bps (11.0592 MHz crystal)
001D D28E        49       setb TR1              ; Start Timer1
001F D29F        50       setb SM0              ; UART mode1
0021 D29E        51       setb SM1
0023 D29C        52       setb REN              ; Enable receive
0025 C299        53       clr TI                ; Clear transmit flag
0027 C298        54       clr RI
0029 22          55       ret
