032F             75   cseg
032F             76   ; These 'equ' must match the wiring between the DE10Lite board and the LCD!
032F             77   ; P0 is in connector JPIO.  Check "CV-8052 Soft Processor in the DE10Lite Board: Getting
032F             78   ; Started Guide" for the details.
032F             79   ELCD_RS equ P1.7
032F             80   ; ELCD_RW equ Px.x ; Not used.  Connected to ground
032F             81   ELCD_E  equ P1.1
032F             82   ELCD_D4 equ P0.7
032F             83   ELCD_D5 equ P0.5
032F             84   ELCD_D6 equ P0.3
032F             85   ELCD_D7 equ P0.1
