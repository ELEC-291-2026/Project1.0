03E6             90   ; Look-up table for 7-seg displays
03E6             91   myLUT:
03E6 C0F9A4B0    92       DB 0xC0, 0xF9, 0xA4, 0xB0, 0x99        ; 0 TO 4
     99
03EB 9282F880    93       DB 0x92, 0x82, 0xF8, 0x80, 0x90        ; 4 TO 9
     90
03F0 8883C6A1    94       DB 0x88, 0x83, 0xC6, 0xA1, 0x86, 0x8E  ; A to F
     868E
