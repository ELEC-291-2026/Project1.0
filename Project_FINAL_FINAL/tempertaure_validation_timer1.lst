03F6             96   Wait50ms:
03F6             97   ;33.33MHz, 1 clk per cycle: 0.03us
03F6 781E        98   mov R0, #30
03F8             99   Wait50ms_L3:
03F8 794A       100   mov R1, #74
03FA            101   Wait50ms_L2:
03FA 7AFA       102   mov R2, #250
03FC            103   Wait50ms_L1:
03FC DAFE       104   djnz R2, Wait50ms_L1 ;3*250*0.03us=22.5us
03FE D9FA       105       djnz R1, Wait50ms_L2 ;74*22.5us=1.665ms
0400 D8F6       106       djnz R0, Wait50ms_L3 ;1.665ms*30=50ms
0402 22         107       ret
