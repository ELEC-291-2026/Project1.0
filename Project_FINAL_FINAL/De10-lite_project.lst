041B              2   CSEG
041B              3   
041B              4   ;--------------------------------------------------
041B              5   ; Lookup table for 7-segment display patterns (common anode)
041B              6   ; Index 0-F = segment pattern
041B              7   ;--------------------------------------------------
041B              8   
041B              9   myLUT:
041B C0F9A4B0    10       DB 0C0h, 0F9h, 0A4h, 0B0h, 099h        ; digits 0-4
     99
0420 9282F880    11       DB 092h, 082h, 0F8h, 080h, 090h        ; digits 5-9
     90
0425 8883C6A1    12       DB 088h, 083h, 0C6h, 0A1h, 086h, 08Eh  ; A-F
     868E
042B             13   
042B             14   ;--------------------------------------------------
042B             15   ; Macro: showBCD
042B             16   ; Input : one byte containing two BCD digits
042B             17   ; Output: two 7-seg displays
042B             18   ;   %0 = bcd byte
042B             19   ;   %1 = HEX low
042B             20   ;   %2 = HEX high
042B             21   ;--------------------------------------------------
042B             22   
                 23   showBCD MAC
                 24       ; ---- Display lower nibble (LSD) ----
                 25       mov  A, %0           ; Load BCD byte
                 26       anl  A, #0Fh         ; Keep lower 4 bits
                 27       movc A, @A+dptr      ; Convert using LUT
                 28       mov  %1, A           ; Output to first HEX display
                 29       ; ---- Display upper nibble (MSD) ----
                 30       mov  A, %0
                 31       swap A               ; Swap nibbles
                 32       anl  A, #0Fh
                 33       movc A, @A+dptr
                 34       mov  %2, A           ; Output to second HEX display
                 35   ENDMAC
042B             37   
042B             38   
042B             39   ;--------------------------------------------------
042B             40   ; Display routine - show BCD number on HEX displays
042B             41   ; KEY3: 0 = show high digits, 1 = show low digits
042B             42   ; LEDRA.7: overflow indicator if bcd+3 or bcd+4 != 0
042B             43   ;--------------------------------------------------
042B             44   
042B             45   Display:
042B 90041B      46       mov dptr, #myLUT     ; Point to lookup table
042E             47   
042E             48       ; If digits 10-7 (bcd+3 and bcd+4) are NOT zero
042E             49       ; turn ON LEDRA.7 as overflow indicator
042E             50   
042E E53B        51       mov A, bcd+3
0430 453C        52       orl A, bcd+4
0432 6004        53       jz  Display_L1
0434 D2EF        54       setb LEDRA.7         ; Alert LED on
0436 8002        55       sjmp Display_L2
0438             56   Display_L1:
0438 C2EF        57       clr LEDRA.7          ; Alert LED off
043A             58   Display_L2:
043A             59   
043A             60       ; If KEY3 pressed (assuming active low) show HIGH digits
043A             61       ; Otherwise show LOW digits
043A             62   
043A 30FB2F      63       jnb KEY.3, Display_high_digits
043D             64   
043D             65       ; Show lower 6 digits
043D             66       ; ---- Display lower nibble (LSD) ----
043D E538        66       mov  A, bcd+0           ; Load BCD byte
043F 540F        66       anl  A, #0Fh         ; Keep lower 4 bits
0441 93          66       movc A, @A+dptr      ; Convert using LUT
0442 F591        66       mov  HEX0, A           ; Output to first HEX display
0444             66   
0444             66       ; ---- Display upper nibble (MSD) ----
0444 E538        66       mov  A, bcd+0
0446 C4          66       swap A               ; Swap nibbles
0447 540F        66       anl  A, #0Fh
0449 93          66       movc A, @A+dptr
044A F592        66       mov  HEX1, A           ; Output to second HEX display
044C             67       ; ---- Display lower nibble (LSD) ----
044C E539        67       mov  A, bcd+1           ; Load BCD byte
044E 540F        67       anl  A, #0Fh         ; Keep lower 4 bits
0450 93          67       movc A, @A+dptr      ; Convert using LUT
0451 F593        67       mov  HEX2, A           ; Output to first HEX display
0453             67   
0453             67       ; ---- Display upper nibble (MSD) ----
0453 E539        67       mov  A, bcd+1
0455 C4          67       swap A               ; Swap nibbles
0456 540F        67       anl  A, #0Fh
0458 93          67       movc A, @A+dptr
0459 F594        67       mov  HEX3, A           ; Output to second HEX display
045B             68       ; ---- Display lower nibble (LSD) ----
045B E53A        68       mov  A, bcd+2           ; Load BCD byte
045D 540F        68       anl  A, #0Fh         ; Keep lower 4 bits
045F 93          68       movc A, @A+dptr      ; Convert using LUT
0460 F58E        68       mov  HEX4, A           ; Output to first HEX display
0462             68   
0462             68       ; ---- Display upper nibble (MSD) ----
0462 E53A        68       mov  A, bcd+2
0464 C4          68       swap A               ; Swap nibbles
0465 540F        68       anl  A, #0Fh
0467 93          68       movc A, @A+dptr
0468 F58F        68       mov  HEX5, A           ; Output to second HEX display
046A 8024        69       sjmp Display_end
046C             70   
046C             71   Display_high_digits:
046C             72       ; Show upper 4 digits
046C             73       ; ---- Display lower nibble (LSD) ----
046C E53B        73       mov  A, bcd+3           ; Load BCD byte
046E 540F        73       anl  A, #0Fh         ; Keep lower 4 bits
0470 93          73       movc A, @A+dptr      ; Convert using LUT
0471 F591        73       mov  HEX0, A           ; Output to first HEX display
0473             73   
0473             73       ; ---- Display upper nibble (MSD) ----
