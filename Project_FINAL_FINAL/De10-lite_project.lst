03B6             81   ; Write data to LCD               ;
03B6             82   ;---------------------------------;
                 83   WriteData mac
                 84   	mov a, %0
                 85   	lcall ?WriteData
                 86   endmac
03B6             87            
03B6             88   ?WriteData:
03B6 D297        89            setb ELCD_RS
03B8 02038F      90            ljmp ELCD_byte
03BB             91   
03BB             92   ;---------------------------------;
03BB             93   ; Write command to LCD            ;
03BB             94   ;---------------------------------;
                 95   WriteCommand mac
                 96   	mov a, %0
                 97   	lcall ?WriteCommand
                 98   endmac
03BB             99   
03BB            100   ?WriteCommand:
03BB C297       101            clr ELCD_RS
03BD 02038F     102            ljmp ELCD_byte
03C0            103   
03C0            104   ;---------------------------------;
03C0            105   ; Configure LCD in 4-bit mode     ;
03C0            106   ;---------------------------------;
03C0            107   ELCD_4BIT:
03C0 C291       108            clr ELCD_E   ; Resting state of LCD's enable pin is zero
03C2            109            ;clr ELCD_RW  ; RW forced to zero
03C2            110            
03C2            111            ; After power on, let the LCD start up before initializing
03C2 C002       112            push AR2
03C4 7A28       112            mov R2, #40
03C6 120371     112            lcall ?Wait_Milli_Seconds
03C9 D002       112            pop AR2
03CB            113            
03CB            114            ; First make sure the LCD is in 8-bit mode and then change to 4-bit mode
03CB 7433       115            mov a, #0x33
03CD 1203BB     115            lcall ?WriteCommand
03D0 7433       116            mov a, #0x33
03D2 1203BB     116            lcall ?WriteCommand
03D5 7432       117            mov a, #0x32
03D7 1203BB     117            lcall ?WriteCommand ; change to 4-bit mode
03DA            118   
03DA            119            ; Configure the LCD
03DA 7428       120            mov a, #0x28
03DC 1203BB     120            lcall ?WriteCommand
03DF 740C       121            mov a, #0x0c
03E1 1203BB     121            lcall ?WriteCommand
03E4 7401       122            mov a, #0x01
03E6 1203BB     122            lcall ?WriteCommand ;  Clear screen command (takes some time)
03E9            123   
03E9            124       ;Wait for the clear screen command to finish.
03E9 C002       125            push AR2
03EB 7A02       125            mov R2, #2
03ED 120371     125            lcall ?Wait_Milli_Seconds
03F0 D002       125            pop AR2
03F2 22         126       ret
03F3            127   
03F3            128   ;---------------------------------;
03F3            129   ; Send a constant string to LCD   ;
03F3            130   ;---------------------------------;
                131   Send_Constant_String mac
                132   	push dph
                133   	push dpl
                134   	push acc
                135   	mov dptr, %0
                136   	lcall ?Send_Constant_String
                137   	pop acc
                138   	pop dpl
                139   	pop dph
                140   endmac
03F3            141   
03F3            142   ?Send_Constant_String:
03F3 E4         143       clr a
03F4 93         144       movc a, @a+dptr
03F5 6006       145       jz ?Send_Constant_String_Done
03F7 1203B6     146       lcall ?WriteData
03FA A3         147       inc dptr
03FB 80F6       148       sjmp ?Send_Constant_String
03FD            149   ?Send_Constant_String_Done:
03FD 22         150       ret  
03FE            151   
03FE            152   ;---------------------------------;
03FE            153   ; Set LCD cursor at row, column   ;
03FE            154   ;---------------------------------;
                155   Set_Cursor mac
                156   	push acc
                157   	mov a, #%1
                158   	dec a
                159   	lcall ?Set_Cursor_%0 ; Select column and row
                160   	pop acc
                161   endmac
03FE            162   
03FE            163   ?Set_Cursor_2:
03FE 4440       164            orl a, #01000000B
0400            165   ?Set_Cursor_1:
0400 4480       166            orl a, #10000000B
0402 0203BB     167            ljmp ?WriteCommand ; Select column and row
