072E            406   
072E            407   ;--------------------------------------------------
072E            408   ; Key_Found:
072E            409   ;   R7 = key code (0-F), C = 1 when we get here.
072E            410   ;   A/B/C/D (0Ah-0Dh) -> mode select
072E            411   ;   * (0Eh)           -> delete / backspace one digit
072E            412   ;   # (0Fh)           -> clear all digits
072E            413   ;   others (0-9, maybe E/F) -> digit
072E            414   ;--------------------------------------------------
072E            415   
072E            416   Key_Found:
072E EF         417       mov A, R7
072F            418   
072F            419       ; --- Mode A (soak temperature) ---
072F B40A0B     420       cjne A, #0Ah, KF_CheckB
0732 1204E4     421       lcall Save_Current_BCD_Into_Param
0735 755C00     422       mov   active_param, #0       ; A: soak_temp
0738 12050B     423       lcall Load_Param_Into_BCD
073B C3         424       clr C                        ; do not treat as digit
073C 22         425       ret
073D            426   
073D            427   KF_CheckB:
073D            428       ; --- Mode B (soak time) ---
073D B40B0B     429       cjne A, #0Bh, KF_CheckC
0740 1204E4     430       lcall Save_Current_BCD_Into_Param
0743 755C01     431       mov   active_param, #1       ; B: soak_time
0746 12050B     432       lcall Load_Param_Into_BCD
0749 C3         433       clr C
074A 22         434       ret
074B            435   
074B            436   KF_CheckC:
074B            437       ; --- Mode C (reflow temperature) ---
074B B40C0B     438       cjne A, #0Ch, KF_CheckD
074E 1204E4     439       lcall Save_Current_BCD_Into_Param
0751 755C02     440       mov   active_param, #2       ; C: reflow_temp
0754 12050B     441       lcall Load_Param_Into_BCD
0757 C3         442       clr C
0758 22         443       ret
0759            444   
0759            445   KF_CheckD:
0759            446       ; --- Mode D (reflow time) ---
0759 B40D0B     447       cjne A, #0Dh, KF_CheckStar
075C 1204E4     448       lcall Save_Current_BCD_Into_Param
075F 755C03     449       mov   active_param, #3       ; D: reflow_time
0762 12050B     450       lcall Load_Param_Into_BCD
0765 C3         451       clr C
