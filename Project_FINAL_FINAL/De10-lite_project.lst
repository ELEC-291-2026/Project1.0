                298   Mov_A_to_B MAC
                299   ;%0 is A, %1 is B
                300   	mov %1+0, %0+0
                301   	mov %1+1, %0+1
                302   	mov %1+2, #0
                303   	mov %1+3, #0
                304   ENDMAC
