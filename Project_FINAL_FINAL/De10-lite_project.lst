0405            178   
0405            179   ?Display_BCD:
0405 C0E0       180            push acc
0407            181            ; Write most significant digit
0407 E8         182            mov a, r0
0408 C4         183            swap a
0409 540F       184            anl a, #0fh
040B 4430       185            orl a, #30h
040D 1203B6     186            lcall ?WriteData
0410            187            ; write least significant digit
0410 E8         188            mov a, r0
0411 540F       189            anl a, #0fh
0413 4430       190            orl a, #30h
0415 1203B6     191            lcall ?WriteData
0418 D0E0       192            pop acc
041A 22         193            ret
041B            194   
