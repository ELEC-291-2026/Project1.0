                 15   Write_3digits MAC
                 16       ; --- Hundreds digit (from low nibble of var+1) ---
                 17       mov  a, %0+1        ; load high BCD byte
                 18       anl  a, #0FH        ; keep low nibble = hundreds
                 19       orl  a, #'0'        ; convert 0–9 -> ASCII
                 20       lcall ?WriteData
                 21       ; --- Tens digit (from high nibble of var+0) ---
                 22       mov  a, %0+0        ; load low BCD byte
                 23       swap a              ; high nibble -> low nibble
                 24       anl  a, #0FH        ; keep that nibble
                 25       orl  a, #'0'        ; 0–9 -> ASCII
                 26       lcall ?WriteData
                 27       ; --- Ones digit (from low nibble of var+0) ---
                 28       mov  a, %0+0        ; load low BCD byte again
                 29       anl  a, #0FH        ; low nibble = ones
                 30       orl  a, #'0'        ; 0–9 -> ASCII
                 31       lcall ?WriteData
                 32   ENDMAC
