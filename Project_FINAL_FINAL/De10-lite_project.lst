                 -1   $include(LCD_4bit_DE10Lite_no_RW.inc) ; A library of LCD related functions and utility macros
0364              1   ;  LCD routines adapted for the DE10-Lite configured as a CV_8052 processor
0364              2   cseg
0364              3   
0364              4   ; When using a 33.333333MHz crystal clock
0364              5   ; one cycle takes 1.0/33.333333MHz = 30 ns
0364              6   
0364              7   ;---------------------------------;
0364              8   ; Wait 40 microseconds            ;
0364              9   ;---------------------------------;
0364             10   Wait40uSec:
0364 C000        11            push AR0
0366 78BE        12            mov R0, #190
0368             13   L0: 
0368 00          14            nop
0369 00          15            nop
036A 00          16            nop
036B 00          17            nop
036C D8FA        18            djnz R0, L0 ; 1+1+1+1+3 cycles->7*30ns*190=40us
036E D000        19            pop AR0
0370 22          20       ret
0371             21   
0371             22   ;---------------------------------;
0371             23   ; Wait 'R2' milliseconds          ;
0371             24   ;---------------------------------;
                 25   Wait_Milli_Seconds mac
                 26   	push AR2
                 27   	mov R2, %0
                 28   	lcall ?Wait_Milli_Seconds
                 29   	pop AR2
                 30   endmac
0371             31   
0371             32   ?Wait_Milli_Seconds:
0371 C000        33            push AR0
0373 C001        34            push AR1
0375 7932        35   L3: mov R1, #50
0377 78DF        36   L2: mov R0, #223
0379 D8FE        37   L1: djnz R0, L1 ; 3 cycles->3*30ns*250=20.07us
037B D9FA        38       djnz R1, L2 ; 20.07us*50=1.004ms
037D DAF6        39       djnz R2, L3 ; number of millisecons to wait passed in R2
037F D001        40       pop AR1
0381 D000        41       pop AR0
0383 22          42       ret
0384             43            
0384             44   ;---------------------------------;
0384             45   ; Toggles the 'E' pin in the LCD  ;
0384             46   ;---------------------------------;
0384             47   ELCD_pulse:
0384 D291        48            setb ELCD_E
0386 120364      49            lcall Wait40uSec
0389 C291        50            clr ELCD_E
038B 120364      51       lcall Wait40uSec ; This line is needed in the DE1SoC running an 8051 because it is much faster than the AT89LP51RC2
038E 22          52       ret
038F             53   
038F             54   ;---------------------------------;
038F             55   ; Writes acc to LCD in 4-bit mode ;
038F             56   ;---------------------------------;
038F             57   ELCD_byte:
038F             58            ; Write high 4 bits first
038F A2E7        59            mov c, ACC.7
0391 9281        60            mov ELCD_D7, c
0393 A2E6        61            mov c, ACC.6
0395 9283        62            mov ELCD_D6, c
0397 A2E5        63            mov c, ACC.5
0399 9285        64            mov ELCD_D5, c
039B A2E4        65            mov c, ACC.4
039D 9287        66            mov ELCD_D4, c
039F 120384      67       lcall ELCD_pulse
03A2             68            ; Write low 4 bits next
03A2 A2E3        69            mov c, ACC.3
03A4 9281        70            mov ELCD_D7, c
03A6 A2E2        71            mov c, ACC.2
03A8 9283        72            mov ELCD_D6, c
03AA A2E1        73            mov c, ACC.1
03AC 9285        74            mov ELCD_D5, c
03AE A2E0        75            mov c, ACC.0
03B0 9287        76            mov ELCD_D4, c
03B2 120384      77       lcall ELCD_pulse
03B5 22          78            ret
03B6             79   
