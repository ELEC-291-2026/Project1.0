0491             83   ;--------------------------------------------------
0491             84   ; Macro: Rotate Left through Carry
0491             85   ;--------------------------------------------------
0491             86   
                 87   MYRLC MAC
                 88       mov A, %0
                 89       rlc A
                 90       mov %0, A
                 91   ENDMAC
0491             92   
0491             93   ;--------------------------------------------------
0491             94   ; Shift all BCD digits LEFT by 4 bits
0491             95   ; Makes room for new digit in LSD (R7)
0491             96   ;--------------------------------------------------
0491             97   
0491             98   Shift_Digits_Left:
0491 7804        99       mov R0, #4           ; 4 bit shifts (one nibble)
0493            100   
0493            101   Shift_Digits_Left_L0:
0493 C3         102       clr C                ; Clear carry before shift
0494 E538       103       mov A, bcd+0
0496 33         103       rlc A
0497 F538       103       mov bcd+0, A
0499 E539       104       mov A, bcd+1
049B 33         104       rlc A
049C F539       104       mov bcd+1, A
049E E53A       105       mov A, bcd+2
04A0 33         105       rlc A
04A1 F53A       105       mov bcd+2, A
04A3 E53B       106       mov A, bcd+3
04A5 33         106       rlc A
04A6 F53B       106       mov bcd+3, A
04A8 E53C       107       mov A, bcd+4
04AA 33         107       rlc A
04AB F53C       107       mov bcd+4, A
04AD D8E4       108       djnz R0, Shift_Digits_Left_L0
04AF            109   
04AF            110       ; Insert new digit from R7 into lowest nibble safely
04AF            111       ; Keep upper nibble of bcd+0 unchanged
04AF 5338F0     112       anl  bcd+0, #0F0h    ; clear lower nibble
04B2 EF         113       mov  A, R7
04B3 540F       114       anl  A, #0Fh         ; ensure only 0-F
04B5 4238       115       orl  bcd+0, A
04B7 22         116       ret
04B8            117   
04B8            118   ;--------------------------------------------------
04B8            119   ; Macro: Rotate Right through Carry
04B8            120   ;--------------------------------------------------
04B8            121   
                122   MYRRC MAC
                123       mov A, %0
                124       rrc A
                125       mov %0, A
                126   ENDMAC
04B8            127   
04B8            128   ;--------------------------------------------------
04B8            129   ; Shift digits RIGHT by 4 bits
04B8            130   ; Used for BACKSPACE (delete last digit)
04B8            131   ;--------------------------------------------------
04B8            132   
04B8            133   Shift_Digits_Right:
04B8 7804       134       mov R0, #4
04BA            135   
04BA            136   Shift_Digits_Right_L0:
04BA C3         137       clr C
04BB E53C       138       mov A, bcd+4
04BD 13         138       rrc A
04BE F53C       138       mov bcd+4, A
04C0 E53B       139       mov A, bcd+3
04C2 13         139       rrc A
04C3 F53B       139       mov bcd+3, A
04C5 E53A       140       mov A, bcd+2
04C7 13         140       rrc A
04C8 F53A       140       mov bcd+2, A
04CA E539       141       mov A, bcd+1
04CC 13         141       rrc A
04CD F539       141       mov bcd+1, A
04CF E538       142       mov A, bcd+0
04D1 13         142       rrc A
04D2 F538       142       mov bcd+0, A
04D4 D8E4       143       djnz R0, Shift_Digits_Right_L0
04D6 22         144       ret
04D7            145   
04D7            146   
04D7            147   ;--------------------------------------------------
04D7            148   ; 25 ms delay (software debounce)
04D7            149   ;--------------------------------------------------
04D7            150   
04D7            151   Wait25ms:
04D7 780F       152       mov R0, #15
04D9 794A       153   L6: mov R1, #74
04DB 7AFA       154   L5: mov R2, #250
04DD DAFE       155   L4: djnz R2, L4
04DF D9FA       156       djnz R1, L5
04E1 D8F6       157       djnz R0, L6
04E3 22         158       ret
