04E4            161   ;--------------------------------------------------
04E4            162   ; Helper routines for parameter storage
04E4            163   ; Each parameter value lives in bcd+0..bcd+1
04E4            164   ; active_param: 0=A, 1=B, 2=C, 3=D
04E4            165   ;--------------------------------------------------
04E4            166   
04E4            167   ; Save current BCD (bcd+0..bcd+1) into active parameter
04E4            168   Save_Current_BCD_Into_Param:
04E4 E55C       169       mov A, active_param
04E6 B40007     170       cjne A, #0, Save_NotA
04E9            171       ; A: soak_temp
04E9 853850     172       mov soak_temp+0, bcd+0
04EC 853951     173       mov soak_temp+1, bcd+1
04EF 22         174       ret
04F0            175   Save_NotA:
04F0 B40107     176       cjne A, #1, Save_NotB
04F3            177       ; B: soak_time
04F3 853852     178       mov soak_time+0, bcd+0
04F6 853953     179       mov soak_time+1, bcd+1
04F9 22         180       ret
04FA            181   Save_NotB:
04FA B40207     182       cjne A, #2, Save_NotC
04FD            183       ; C: reflow_temp
04FD 853856     184       mov reflow_temp+0, bcd+0
0500 853957     185       mov reflow_temp+1, bcd+1
0503 22         186       ret
0504            187   Save_NotC:
0504            188       ; D: reflow_time (default case)
0504 853858     189       mov reflow_time+0, bcd+0
0507 853959     190       mov reflow_time+1, bcd+1
050A 22         191       ret
050B            192   
050B            193   
050B            194   ; Load active parameter into BCD (bcd+0..bcd+1)
050B            195   ; Clear the higher digits.
050B            196   Load_Param_Into_BCD:
050B 753A00     197       mov bcd+2, #00h
050E 753B00     198       mov bcd+3, #00h
0511 753C00     199       mov bcd+4, #00h
0514            200   
0514 E55C       201       mov A, active_param
0516 B40007     202       cjne A, #0, Load_NotA
0519            203       ; A: soak_temp
0519 855038     204       mov bcd+0, soak_temp
051C 855139     205       mov bcd+1, soak_temp+1
051F 22         206       ret
0520            207   Load_NotA:
0520 B40107     208       cjne A, #1, Load_NotB
0523            209       ; B: soak_time
0523 855238     210       mov bcd+0, soak_time
0526 855339     211       mov bcd+1, soak_time+1
0529 22         212       ret
052A            213   Load_NotB:
052A B40207     214       cjne A, #2, Load_NotC
052D            215       ; C: reflow_temp
052D 855638     216       mov bcd+0, reflow_temp
0530 855739     217       mov bcd+1, reflow_temp+1
0533 22         218       ret
0534            219   Load_NotC:
0534            220       ; D: reflow_time (default)
0534 855838     221       mov bcd+0, reflow_time
0537 855939     222       mov bcd+1, reflow_time+1
053A 22         223       ret
053B            224   
053B            225   
053B            226   ;--------------------------------------------------
053B            227   ; Macro: Check one keypad column
053B            228   ; If pressed -> R7 = key value, C=1, jump to Key_Found
053B            229   ; %0 = column bit, %1 = key code (immediate)
053B            230   ;--------------------------------------------------
053B            231   
                232   CHECK_COLUMN MAC
                233       jb  %0, CHECK_COL_%M     ; if column=1 -> no key here -> skip
                234       mov R7, %1               ; store key code
                235       jnb %0, $                ; wait until key is released
                236       setb C                   ; mark "key found"
                237       ljmp Key_Found           ; use long jump instead of short
                238   CHECK_COL_%M:
                239   ENDMAC
053B            240   
053B            241   
053B            242   ;--------------------------------------------------
053B            243   ; Configure GPIO directions for keypad
053B            244   ;--------------------------------------------------
053B            245   
053B            246   Configure_Keypad_Pins:
053B 439B54     247       orl P1MOD, #01010100b    ; Rows as output on P1
053E 439C01     248       orl P2MOD, #00000001b
0541 539CAB     249       anl P2MOD, #10101011b    ; Columns as input on P2
0544 539DFE     250       anl P3MOD, #11111110b    ; Column on P3.0 input
0547 22         251       ret
0548            252   
0548            253   ; Pin definitions for keypad
0548            254   ROW1 EQU P1.2
0548            255   ROW2 EQU P1.4
0548            256   ROW3 EQU P1.6
0548            257   ROW4 EQU P2.0
0548            258   
0548            259   COL1 EQU P2.2
0548            260   COL2 EQU P2.4
0548            261   COL3 EQU P2.6
0548            262   COL4 EQU P3.0
0548            263   
0548            264   ;--------------------------------------------------
0548            265   ; Keypad scanning routine
0548            266   ; Output:
0548            267   ;   C = 1 -> numeric key pressed, code in R7 (0-9, maybe E/F)
0548            268   ;   C = 0 -> no digit (no key, mode key, or backspace)
0548            269   ;--------------------------------------------------
0548            270   
0548            271   Keypad:
0548            272   
0548            273       ; KEY1 acts as BACKSPACE / ERASE
0548            274   
0548 20F90E     275       jb  KEY.1, keypad_L0     ; if KEY1=1 (not pressed) -> skip
054B 1204D7     276       lcall Wait25ms
054E 20F908     277       jb  KEY.1, keypad_L0     ; if bounced back high, skip
0551 30F9FD     278       jnb KEY.1, $             ; wait for release (KEY1 low while pressed)
0554 1204B8     279       lcall Shift_Digits_Right ; delete LSD for active parameter
0557 C3         280       clr C                    ; no digit returned
0558 22         281       ret
0559            282   
0559            283   keypad_L0:
0559            284   
0559            285       ; Drive all rows LOW - check if any column LOW
0559            286   
0559 C292       287       clr ROW1
055B C294       288       clr ROW2
055D C296       289       clr ROW3
055F C2A0       290       clr ROW4
0561            291   
0561 A2A2       292       mov C, COL1
0563 82A4       293       anl C, COL2
0565 82A6       294       anl C, COL3
0567 82B0       295       anl C, COL4
0569 5002       296       jnc Keypad_Debounce      ; if any column low -> possible key
056B C3         297       clr C
056C 22         298       ret
056D            299   
056D            300   Keypad_Debounce:
056D            301       ; Wait and check again to avoid bouncing
056D 1204D7     302       lcall Wait25ms
0570            303   
0570 A2A2       304       mov C, COL1
0572 82A4       305       anl C, COL2
0574 82A6       306       anl C, COL3
0576 82B0       307       anl C, COL4
0578 5002       308       jnc Keypad_Key_Code
057A C3         309       clr C
057B 22         310       ret
057C            311   
057C            312   Keypad_Key_Code:
057C            313       ; Prepare to scan each row individually
057C D292       314       setb ROW1
057E D294       315       setb ROW2
0580 D296       316       setb ROW3
0582 D2A0       317       setb ROW4
0584            318   
0584            319       ; SW0 selects layout orientation
0584 30E803     320       jnb SWA.0, keypad_default
0587 02065C     321       ljmp keypad_90deg
058A            322   
058A            323   
058A            324   ;--------------------------------------------------
058A            325   ; Default keypad layout
058A            326   ;--------------------------------------------------
058A            327   ; Mapping (default):
058A            328   ;   Row1: 1  2  3  A (0Ah)
058A            329   ;   Row2: 4  5  6  B (0Bh)
058A            330   ;   Row3: 7  8  9  C (0Ch)
058A            331   ;   Row4: *  0  #  D (0Eh,00h,0Fh,0Dh)
058A            332   ;--------------------------------------------------
058A            333   
058A            334   keypad_default:
058A            335   
058A C292       336       clr ROW1
058C 20A209     337       jb  COL1, CHECK_COL_24     ; if column=1 -> no key here -> skip
058F 7F01       337       mov R7, #01h               ; store key code
0591 30A2FD     337       jnb COL1, $                ; wait until key is released
0594 D3         337       setb C                   ; mark "key found"
0595 02072E     337       ljmp Key_Found           ; use long jump instead of short
0598            337   CHECK_COL_24:
