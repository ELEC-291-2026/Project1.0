1115            273   ; The 8-bit hex number passed in the accumulator is converted to
1115            274   ; BCD and stored in [R1, R0]
1115            275   Hex_to_bcd_8bit:
1115 75F064     276            mov b, #100
1118 84         277            div ab
1119 F9         278            mov R1, a   ; After dividing, a has the 100s
111A E5F0       279            mov a, b    ; Remainder is in register b
111C 75F00A     280            mov b, #10
111F 84         281            div ab ; The tens are stored in a, the units are stored in b 
1120 C4         282            swap a
1121 54F0       283            anl a, #0xf0
1123 45F0       284            orl a, b
1125 F8         285            mov R0, a
1126 22         286            ret
