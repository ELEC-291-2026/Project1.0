0767            453   
0767            454   KF_CheckStar:
0767            455       ; --- '*' key (code 0Eh) -> delete / backspace ---
0767 B40E05     456       cjne A, #0Eh, KF_CheckHash
076A            457       ; Backspace = shift digits right by 1 digit
076A 1204B8     458       lcall Shift_Digits_Right
076D C3         459       clr C                        ; no new digit for main loop
076E 22         460       ret
076F            461   
076F            462   KF_CheckHash:
076F            463       ; --- '#' key (code 0Fh) -> clear ---
076F B40F0D     464       cjne A, #0Fh, KF_Digit
0772            465       ; Clear all BCD digits for current parameter
0772 E4         466       clr A
0773 F538       467       mov bcd+0, A
0775 F539       468       mov bcd+1, A
0777 F53A       469       mov bcd+2, A
0779 F53B       470       mov bcd+3, A
077B F53C       471       mov bcd+4, A
077D C3         472       clr C                        ; no digit to insert
077E 22         473       ret
077F            474   
077F            475   KF_Digit:
077F            476       ; Not A/B/C/D/*/# -> treat as numeric digit key
077F            477       ; R7 holds the digit, Carry = 1 -> main loop will append it
077F 22         478       ret
0780            479   
0780            480   
0780            481   END
