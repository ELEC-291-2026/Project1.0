06FD            408   
06FD            409   ;--------------------------------------------------
06FD            410   ; Key_Found:
06FD            411   ;   R7 = key code (0-F), C = 1 when we get here.
06FD            412   ;   A/B/C/D (0Ah-0Dh) -> mode select
06FD            413   ;   * (0Eh)           -> delete / backspace one digit
06FD            414   ;   # (0Fh)           -> clear all digits
06FD            415   ;   others (0-9, maybe E/F) -> digit
06FD            416   ;--------------------------------------------------
06FD            417   
06FD            418   Key_Found:
06FD EF         419       mov A, R7
06FE            420   
06FE            421       ; --- Mode A (soak temperature) ---
06FE B40A0B     422       cjne A, #0Ah, KF_CheckB
0701 1204B3     423       lcall Save_Current_BCD_Into_Param
0704 755800     424       mov   active_param, #0       ; A: soak_temp
0707 1204DA     425       lcall Load_Param_Into_BCD
070A C3         426       clr C                        ; do not treat as digit
070B 22         427       ret
070C            428   
070C            429   KF_CheckB:
070C            430       ; --- Mode B (soak time) ---
070C B40B0B     431       cjne A, #0Bh, KF_CheckC
070F 1204B3     432       lcall Save_Current_BCD_Into_Param
0712 755801     433       mov   active_param, #1       ; B: soak_time
0715 1204DA     434       lcall Load_Param_Into_BCD
0718 C3         435       clr C
0719 22         436       ret
071A            437   
071A            438   KF_CheckC:
071A            439       ; --- Mode C (reflow temperature) ---
071A B40C0B     440       cjne A, #0Ch, KF_CheckD
071D 1204B3     441       lcall Save_Current_BCD_Into_Param
0720 755802     442       mov   active_param, #2       ; C: reflow_temp
0723 1204DA     443       lcall Load_Param_Into_BCD
0726 C3         444       clr C
0727 22         445       ret
0728            446   
0728            447   KF_CheckD:
0728            448       ; --- Mode D (reflow time) ---
0728 B40D0B     449       cjne A, #0Dh, KF_CheckStar
072B 1204B3     450       lcall Save_Current_BCD_Into_Param
072E 755803     451       mov   active_param, #3       ; D: reflow_time
0731 1204DA     452       lcall Load_Param_Into_BCD
0734 C3         453       clr C
0735 22         454       ret
0736            455   
0736            456   KF_CheckStar:
0736            457       ; --- '*' key (code 0Eh) -> delete / backspace ---
0736 B40E05     458       cjne A, #0Eh, KF_CheckHash
0739            459       ; Backspace = shift digits right by 1 digit
0739 120487     460       lcall Shift_Digits_Right
073C C3         461       clr C                        ; no new digit for main loop
073D 22         462       ret
073E            463   
073E            464   KF_CheckHash:
073E            465       ; --- '#' key (code 0Fh) -> clear ---
073E B40F0D     466       cjne A, #0Fh, KF_Digit
0741            467       ; Clear all BCD digits for current parameter
0741 E4         468       clr A
0742 F538       469       mov bcd+0, A
0744 F539       470       mov bcd+1, A
0746 F53A       471       mov bcd+2, A
0748 F53B       472       mov bcd+3, A
074A F53C       473       mov bcd+4, A
074C C3         474       clr C                        ; no digit to insert
074D 22         475       ret
074E            476   
074E            477   KF_Digit:
074E            478       ; Not A/B/C/D/*/# -> treat as numeric digit key
