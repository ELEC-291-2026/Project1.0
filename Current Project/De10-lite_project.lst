07C8 C4         202            swap a
07C9 540F       203            anl a, #0FH
07CB 93         204            movc a, @a+dptr
07CC F592       205            mov HEX1, a
07CE            206            
07CE E8         207            mov a, R0
07CF 540F       208            anl a, #0FH
07D1 93         209            movc a, @a+dptr
07D2 F591       210            mov HEX0, a
07D4            211            
07D4 22         212            ret
