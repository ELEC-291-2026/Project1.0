0046             44   tempCold:        ds 4
004A             45   tempFinal:  ds 4
004E             46   timeOn:     ds 2
0050             47   ;Variables from keypad
0050             48   soak_temp:      ds 2      ; mode A 150 +-20
0052             49   soak_time:      ds 2      ; mode B 60-120
0054             50   reflow_temp:    ds 2      ; mode C 230 < 240
0056             51   reflow_time:    ds 2      ; mode D  30 < 45
0058             52   active_param:   ds 1
0059             53   
