07F7            247   
07F7            248   ; The 8-bit hex number passed in the accumulator is converted to
07F7            249   ; BCD and stored in [R1, R0]
07F7            250   Hex_to_bcd_8bit:
07F7 75F064     251            mov b, #100
07FA 84         252            div ab
07FB F9         253            mov R1, a   ; After dividing, a has the 100s
07FC E5F0       254            mov a, b    ; Remainder is in register b
07FE 75F00A     255            mov b, #10
0801 84         256            div ab ; The tens are stored in a, the units are stored in b 
0802 C4         257            swap a
0803 54F0       258            anl a, #0xf0
0805 45F0       259            orl a, b
0807 F8         260            mov R0, a
0808 22         261            ret
