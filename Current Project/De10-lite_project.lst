07F7            240   ;-------MACROS--------------------;
07F7            241   ;Example macro to help with process %0,1,etc represents the input number, this is all pass by reference(i.e it can actually affect the variable)
07F7            242   
                243   ADD_16 MAC
                244       ADD A, %0     ; Add low byte
                245       MOV R2, A       ; Store result back in low var
                246       MOV A, R1       ; Move existing high byte to A
                247       ADDC A, %1     ; Add high byte with carry
                248       MOV R1, A       ; Store back in R1
                249   ENDMAC
07F7            250   
                251   Load_X_Var16 MAC
                252   mov x+0, %0+0
                253   mov x+1, %0+1
                254   mov x+2, #0
                255   mov x+3, #0
                256   ENDMAC
07F7            257   
                258   Load_Y_Var16 MAC
                259   mov y+0, %0+0
                260   mov y+1, %0+1
                261   mov y+2, #0
                262   mov y+3, #0
                263   ENDMAC
07F7            264   
                265   Load_X_Var8 MAC
                266       
                267   mov x+0, %0+0
                268   mov x+1, #0
                269   mov x+2, #0
                270   mov x+3, #0
                271   ENDMAC
07F7            272   
                273   Load_Y_Var8 MAC
                274       
                275   mov y+0, %0+0
                276   mov y+1, #0
                277   mov y+2, #0
                278   mov y+3, #0
                279   ENDMAC
07F7            280   
                281   tempConv_cold MAC
                282   	; Load 32-bit 'x' with 12-bit adc result
                283   	mov x+3, #0
                284   	mov x+2, #0
                285   	mov x+1, ADC_H
                286   	mov x+0, ADC_L
                287   
                288   	Load_y(50300) ; VCC voltage measured
                289   	lcall mul32
                290   	Load_y(4096)
                291   	lcall div32
                292   	Load_y(27300)
                293   	lcall sub32
                294   	Load_y(100)
                295   	lcall mul32
                296   
                297   ENDMAC
07F7            298   
                299   tempConv_hot MAC
                300   	; Load 32-bit 'x' with 12-bit adc result
                301   	mov x+3, #0
                302   	mov x+2, #0
                303   	mov x+1, ADC_H
                304   	mov x+0, ADC_L
                305   
                306   	Load_y(12288)   ; gain constant
                307   	lcall mul32
                308   	
                309   	Load_y(4096)
                310   	lcall div32
                311   
                312   ENDMAC
07F7            313   
                314   powerPercent MAC
                315   	;Convert percentage of time into a time it needs to be on %0 is percentage(i.e 20 is 20%) on, %1 is total time, %2 is the time on
                316   	;load_x(%0)
                317   	mov x+0, %0
                318   	mov x+1, #0
                319   	mov x+2, #0
                320   	mov x+3, #0
                321   	;converts x to a percentage through fractions
                322   	Load_Y_Var16(%1)
                323   	lcall mul32
                324   	
                325   	load_y(100)
                326   	lcall div32
                327   	
                328   	mov %2+0, x+0
                329   	mov %2+1, x+1
                330   ENDMAC
