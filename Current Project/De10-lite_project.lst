0517            266   ;--------------------------------------------------
0517            267   ; Keypad scanning routine
0517            268   ; Output:
0517            269   ;   C = 1 -> numeric key pressed, code in R7 (0-9, maybe E/F)
0517            270   ;   C = 0 -> no digit (no key, mode key, or backspace/clear)
0517            271   ;--------------------------------------------------
0517            272   
0517            273   Keypad:
0517            274   
0517            275       ; KEY1 acts as BACKSPACE / ERASE
0517            276   
0517 20F90E     277       jb  KEY.1, keypad_L0     ; if KEY1=1 (not pressed) -> skip
051A 1204A6     278       lcall Wait25ms
051D 20F908     279       jb  KEY.1, keypad_L0     ; if bounced back high, skip
0520 30F9FD     280       jnb KEY.1, $             ; wait for release (KEY1 low while pressed)
0523 120487     281       lcall Shift_Digits_Right ; delete LSD for active parameter
0526 C3         282       clr C                    ; no digit returned
0527 22         283       ret
0528            284   
0528            285   keypad_L0:
0528            286   
0528            287       ; Drive all rows LOW - check if any column LOW
0528            288   
0528 C292       289       clr ROW1
052A C294       290       clr ROW2
052C C296       291       clr ROW3
052E C2A0       292       clr ROW4
0530            293   
0530 A2A2       294       mov C, COL1
0532 82A4       295       anl C, COL2
0534 82A6       296       anl C, COL3
0536 82B0       297       anl C, COL4
0538 5002       298       jnc Keypad_Debounce      ; if any column low -> possible key
053A C3         299       clr C
053B 22         300       ret
053C            301   
053C            302   Keypad_Debounce:
053C            303       ; Wait and check again to avoid bouncing
053C 1204A6     304       lcall Wait25ms
053F            305   
053F A2A2       306       mov C, COL1
0541 82A4       307       anl C, COL2
0543 82A6       308       anl C, COL3
0545 82B0       309       anl C, COL4
