0809            264   ;-------MACROS--------------------;
0809            265   ;Example macro to help with process %0,1,etc represents the input number, this is all pass by reference(i.e it can actually affect the variable)
0809            266   
                267   ADD_16 MAC
                268       ADD A, %0     ; Add low byte
                269       MOV R2, A       ; Store result back in low var
                270       MOV A, R1       ; Move existing high byte to A
                271       ADDC A, %1     ; Add high byte with carry
                272       MOV R1, A       ; Store back in R1
                273   ENDMAC
0809            274   
                275   Load_X_Var16 MAC
                276   mov x+0, %0+0
                277   mov x+1, %0+1
                278   mov x+2, #0
                279   mov x+3, #0
                280   ENDMAC
0809            281   
                282   Load_Y_Var16 MAC
                283   mov y+0, %0+0
                284   mov y+1, %0+1
                285   mov y+2, #0
                286   mov y+3, #0
                287   ENDMAC
0809            288   
                289   Load_X_Var8 MAC
                290       
                291   mov x+0, %0+0
                292   mov x+1, #0
                293   mov x+2, #0
                294   mov x+3, #0
                295   ENDMAC
0809            296   
                297   Load_Y_Var8 MAC
                298       
                299   mov y+0, %0+0
                300   mov y+1, #0
                301   mov y+2, #0
                302   mov y+3, #0
                303   ENDMAC
0809            304   
0809            305   ;Macro for conversion of LM335
                306   tempConv_cold MAC
                307   	; Load 32-bit 'x' with 12-bit adc result
                308   	mov x+3, #0
                309   	mov x+2, #0
                310   	mov x+1, ADC_H
                311   	mov x+0, ADC_L
                312   
                313   	Load_y(5000)
                314       lcall mul32
                315       Load_y(4096)
                316       lcall div32           ; x = Vlm in mV
                317   
                318       Load_y(10)
                319       lcall div32           ; x = Kelvin
                320       Load_y(273)
                321       lcall sub32           ; x = Celsius
                322       
                323       mov tempCold+0, x+0
                324   	mov tempCold+1, x+1
                325   	mov tempCold+2, x+2
                326   	mov tempCold+3, x+3
                327       
                328       
                329   
                330   ENDMAC
0809            331   
0809            332   ;For the coupling wire
                333   tempConv_hot MAC
                334   	; Load 32-bit 'x' with 12-bit adc result
                335   	mov x+3, #0
                336   	mov x+2, #0
                337   	mov x+1, ADC_H
                338   	mov x+0, ADC_L
                339   
                340   	Load_y(10000)         ; Was 1000, now 10000 to keep one decimal place
                341       lcall mul32
                342       Load_y(12300)
                343       lcall div32           ; x = scaled TC temperature (e.g., 123 for 12.3C)
                344   
                345       ; Save this intermediate result in y to free up x for CJ scaling
                346       mov y+0, x+0
                347       mov y+1, x+1
                348       mov y+2, x+2
                349       mov y+3, x+3
                350   
                351       
                352   
                353   ENDMAC
0809            354   
                355   tempConv_final MAC
                356   	; Load Cold Junction and scale it by 10 to match units
                357       mov x+0, tempCold+0
                358       mov x+1, tempCold+1
                359       mov x+2, tempCold+2
                360       mov x+3, tempCold+3
                361       
                362       push y+0              ; Save our TC result safely
                363       push y+1
                364       push y+2
                365       push y+3
                366       
                367       Load_y(10)
                368       lcall mul32           ; x = CJ * 10
                369       
                370       pop y+3               ; Restore TC result into y
                371       pop y+2
                372       pop y+1
                373       pop y+0
                374       
                375       lcall add32           ; Final result: (TC_temp*10) + (CJ_temp*10)
                376       
                377       mov tempFinal+0, x+0
                378   	mov tempFinal+1, x+1
                379   	mov tempFinal+2, x+2
                380   	mov tempFinal+3, x+3
                381       
                382   
                383   
                384   
                385   ENDMAC
0809            386   
                387   powerPercent MAC
                388   	;Convert percentage of time into a time it needs to be on %0 is percentage(i.e 20 is 20%) on, %1 is total time, %2 is the time on
                389   	;load_x(%0)
                390   	mov x+0, %0
                391   	mov x+1, #0
                392   	mov x+2, #0
                393   	mov x+3, #0
                394   	;converts x to a percentage through fractions
                395   	Load_Y_Var16(%1)
                396   	lcall mul32
                397   	
                398   	load_y(100)
                399   	lcall div32
                400   	
                401   	mov %2+0, x+0
                402   	mov %2+1, x+1
                403   ENDMAC
