07E5            224   ; The 8-bit hex number passed in the accumulator is converted to
07E5            225   ; BCD and stored in [R1, R0]
07E5            226   Hex_to_bcd_8bit:
07E5 75F064     227            mov b, #100
07E8 84         228            div ab
07E9 F9         229            mov R1, a   ; After dividing, a has the 100s
07EA E5F0       230            mov a, b    ; Remainder is in register b
07EC 75F00A     231            mov b, #10
07EF 84         232            div ab ; The tens are stored in a, the units are stored in b 
07F0 C4         233            swap a
07F1 54F0       234            anl a, #0xf0
07F3 45F0       235            orl a, b
07F5 F8         236            mov R0, a
07F6 22         237            ret
