0000              1   ; main project file
                  3   $LIST
0000              5   
0000              6   
0000              7   CLK              EQU 33333333 ; Microcontroller system crystal frequency in Hz
0000              8   TIMER2_RATE      EQU 1000     ; 1000Hz, for a timer tick of 1ms
0000              9   TIMER2_RELOAD    EQU ((65536-(CLK/(12*TIMER2_RATE))))
0000             10   TIMER0_RATE     EQU 1024    ; 2048Hz squarewave (peak amplitude of CEM-1203 speaker)
0000             11   TIMER0_RELOAD   EQU ((65536-(CLK/TIMER0_RATE)))
0000             12   FREQ                     EQU 33333333
0000             13   BAUD                     EQU 115200
0000             14   T2LOAD                   EQU 65536-(FREQ/(32*BAUD))
0000             15   
0000             16   ;PIN Assignemet
0000             17   ;Need to figure out wich ADC pins the LM335 and OP07 are on 
0000             18   LM335_ADC equ 0
0000             19   OP07_ADC equ 1
0000             20   
0000             21   
0000             22   ; Reset vector
0000             23   org 0x0000
0000 020875      24       ljmp main
0003             25       
0003             26   ; Timer/Counter 0 overflow interrupt vector
000B             27   org 0x000B
000B 020762      28            ljmp Timer0_ISR
000E             29   
000E             30   ; Timer/Counter 2 overflow interrupt vector
002B             31   org 0x002B
002B 020783      32            ljmp Timer2_ISR
002E             33   
002E             34   
0030             35   dseg at 0x30
0030             36   ; For math 
0030             37   x:                       ds 4
0034             38   y:                       ds 4
0038             39   bcd:             ds 5
003D             40   
003D             41   math_space: ds 5
0042             42   
0042             43   tempHot:         ds 4
0046             44   tempCold:        ds 4
004A             45   tempFinal:  ds 4
004E             46   timeOn:     ds 2
0050             47   ;Variables from keypad
0050             48   soak_temp:      ds 2      ; mode A 150 +-20
0052             49   soak_time:      ds 2      ; mode B 60-120
0054             50   reflow_temp:    ds 2      ; mode C 230 < 240
0056             51   reflow_time:    ds 2      ; mode D  30 < 45
0058             52   active_param:   ds 1
0059             53   
0059             54   Timer0Reload:   ds 2
005B             55   
005B             56   ; Each FSM has its own timer
005B             57   FSM_timer:  ds 1
005C             58   QuarterSecondsCounter: ds 1
005D             59   SecondsCounter: ds 1
005E             60   SecondsCounterTotal: ds 1
005F             61   MinutesCounterTotal: ds 1
