0761            118   Timer0_Init:
0761 E589       119            mov a, TMOD
0763 54F0       120            anl a, #0xf0 ; 11110000 Clear the bits for timer 0
0765 4401       121            orl a, #0x01 ; 00000001 Configure timer 0 as 16-timer
0767 F589       122            mov TMOD, a
0769            123            
0769 855A8C     124            mov TH0, Timer0Reload+1
076C 85598A     125            mov TL0, Timer0Reload+0
076F            126            
076F            127            ; Enable the timer and interrupts
076F D2A9       128       setb ET0  ; Enable timer 0 interrupt
0771 D28C       129       setb TR0  ; Start timer 0
0773 22         130            ret
0774            131   
0774            132   ;---------------------------------;
0774            133   ; ISR for timer 0.  Set to execute;
0774            134   ; every 1/4096Hz to generate a    ;
0774            135   ; 2048 Hz wave at pin SOUND_OUT   ;
0774            136   ;---------------------------------;
0774            137   
0774            138   Timer0_ISR:
0774 C28C       139            clr TR0
0776 855A8C     140            mov TH0, Timer0Reload+1
0779 85598A     141            mov TL0, Timer0Reload+0
077C D28C       142            setb TR0
077E B284       143            cpl SOUND_OUT ; Connect speaker the pin assigned to 'SOUND_OUT'!
0780 32         144            reti
