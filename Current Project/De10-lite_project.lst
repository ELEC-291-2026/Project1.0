                 -1   $include(keypad_lib_2.asm)
03EA              1   ;--------------------------------------------------
03EA              2   ; Code Segment
03EA              3   ;--------------------------------------------------
03EA              4   CSEG
03EA              5   
03EA              6   ;--------------------------------------------------
03EA              7   ; Lookup table for 7-segment display patterns (common anode)
03EA              8   ; Index 0-F = segment pattern
03EA              9   ;--------------------------------------------------
03EA             10   
03EA             11   myLUT:
03EA C0F9A4B0    12       DB 0C0h, 0F9h, 0A4h, 0B0h, 099h        ; digits 0-4
     99
03EF 9282F880    13       DB 092h, 082h, 0F8h, 080h, 090h        ; digits 5-9
     90
03F4 8883C6A1    14       DB 088h, 083h, 0C6h, 0A1h, 086h, 08Eh  ; A-F
     868E
03FA             15   
03FA             16   ;--------------------------------------------------
03FA             17   ; Macro: showBCD
03FA             18   ; Input : one byte containing two BCD digits
03FA             19   ; Output: two 7-seg displays
03FA             20   ;   %0 = bcd byte
03FA             21   ;   %1 = HEX low
03FA             22   ;   %2 = HEX high
03FA             23   ;--------------------------------------------------
03FA             24   
                 25   showBCD MAC
                 26       ; ---- Display lower nibble (LSD) ----
                 27       mov  A, %0           ; Load BCD byte
                 28       anl  A, #0Fh         ; Keep lower 4 bits
                 29       movc A, @A+dptr      ; Convert using LUT
                 30       mov  %1, A           ; Output to first HEX display
                 31   
                 32       ; ---- Display upper nibble (MSD) ----
                 33       mov  A, %0
                 34       swap A               ; Swap nibbles
                 35       anl  A, #0Fh
                 36       movc A, @A+dptr
                 37       mov  %2, A           ; Output to second HEX display
                 38   ENDMAC
03FA             39   
03FA             40   
03FA             41   ;--------------------------------------------------
03FA             42   ; Display routine - show BCD number on HEX displays
03FA             43   ; KEY3: 0 = show high digits, 1 = show low digits
03FA             44   ; LEDRA.7: overflow indicator if bcd+3 or bcd+4 != 0
03FA             45   ;--------------------------------------------------
03FA             46   
03FA             47   Display:
03FA 9003EA      48       mov dptr, #myLUT     ; Point to lookup table
03FD             49   
03FD             50       ; If digits 10-7 (bcd+3 and bcd+4) are NOT zero
03FD             51       ; turn ON LEDRA.7 as overflow indicator
03FD             52   
03FD E53B        53       mov A, bcd+3
03FF 453C        54       orl A, bcd+4
0401 6004        55       jz  Display_L1
0403 D2EF        56       setb LEDRA.7         ; Alert LED on
0405 8002        57       sjmp Display_L2
0407             58   Display_L1:
0407 C2EF        59       clr LEDRA.7          ; Alert LED off
0409             60   Display_L2:
0409             61   
0409             62       ; If KEY3 pressed (assuming active low) show HIGH digits
0409             63       ; Otherwise show LOW digits
0409             64   
0409 30FB2F      65       jnb KEY.3, Display_high_digits
040C             66   
040C             67       ; Show lower 6 digits
040C             68       ; ---- Display lower nibble (LSD) ----
040C E538        68       mov  A, bcd+0           ; Load BCD byte
040E 540F        68       anl  A, #0Fh         ; Keep lower 4 bits
0410 93          68       movc A, @A+dptr      ; Convert using LUT
0411 F591        68       mov  HEX0, A           ; Output to first HEX display
0413             68   
0413             68       ; ---- Display upper nibble (MSD) ----
0413 E538        68       mov  A, bcd+0
0415 C4          68       swap A               ; Swap nibbles
0416 540F        68       anl  A, #0Fh
0418 93          68       movc A, @A+dptr
0419 F592        68       mov  HEX1, A           ; Output to second HEX display
041B             69       ; ---- Display lower nibble (LSD) ----
041B E539        69       mov  A, bcd+1           ; Load BCD byte
041D 540F        69       anl  A, #0Fh         ; Keep lower 4 bits
041F 93          69       movc A, @A+dptr      ; Convert using LUT
0420 F593        69       mov  HEX2, A           ; Output to first HEX display
0422             69   
0422             69       ; ---- Display upper nibble (MSD) ----
0422 E539        69       mov  A, bcd+1
0424 C4          69       swap A               ; Swap nibbles
0425 540F        69       anl  A, #0Fh
0427 93          69       movc A, @A+dptr
0428 F594        69       mov  HEX3, A           ; Output to second HEX display
042A             70       ; ---- Display lower nibble (LSD) ----
042A E53A        70       mov  A, bcd+2           ; Load BCD byte
042C 540F        70       anl  A, #0Fh         ; Keep lower 4 bits
042E 93          70       movc A, @A+dptr      ; Convert using LUT
042F F58E        70       mov  HEX4, A           ; Output to first HEX display
0431             70   
0431             70       ; ---- Display upper nibble (MSD) ----
0431 E53A        70       mov  A, bcd+2
0433 C4          70       swap A               ; Swap nibbles
0434 540F        70       anl  A, #0Fh
0436 93          70       movc A, @A+dptr
0437 F58F        70       mov  HEX5, A           ; Output to second HEX display
0439 8024        71       sjmp Display_end
043B             72   
043B             73   Display_high_digits:
043B             74       ; Show upper 4 digits
043B             75       ; ---- Display lower nibble (LSD) ----
043B E53B        75       mov  A, bcd+3           ; Load BCD byte
043D 540F        75       anl  A, #0Fh         ; Keep lower 4 bits
043F 93          75       movc A, @A+dptr      ; Convert using LUT
0440 F591        75       mov  HEX0, A           ; Output to first HEX display
0442             75   
0442             75       ; ---- Display upper nibble (MSD) ----
0442 E53B        75       mov  A, bcd+3
0444 C4          75       swap A               ; Swap nibbles
0445 540F        75       anl  A, #0Fh
0447 93          75       movc A, @A+dptr
0448 F592        75       mov  HEX1, A           ; Output to second HEX display
044A             76       ; ---- Display lower nibble (LSD) ----
044A E53C        76       mov  A, bcd+4           ; Load BCD byte
044C 540F        76       anl  A, #0Fh         ; Keep lower 4 bits
044E 93          76       movc A, @A+dptr      ; Convert using LUT
044F F593        76       mov  HEX2, A           ; Output to first HEX display
0451             76   
0451             76       ; ---- Display upper nibble (MSD) ----
0451 E53C        76       mov  A, bcd+4
0453 C4          76       swap A               ; Swap nibbles
0454 540F        76       anl  A, #0Fh
0456 93          76       movc A, @A+dptr
0457 F594        76       mov  HEX3, A           ; Output to second HEX display
0459             77   
0459             78       ; Blank remaining displays
0459 758EFF      79       mov HEX4, #0FFh
045C 758FFF      80       mov HEX5, #0FFh
045F             81   
045F             82   Display_end:
045F 22          83       ret
0460             84   
0460             85   ;--------------------------------------------------
0460             86   ; Macro: Rotate Left through Carry
0460             87   ;--------------------------------------------------
0460             88   
                 89   MYRLC MAC
                 90       mov A, %0
                 91       rlc A
                 92       mov %0, A
                 93   ENDMAC
0460             94   
0460             95   ;--------------------------------------------------
0460             96   ; Shift all BCD digits LEFT by 4 bits
0460             97   ; Makes room for new digit in LSD (R7)
0460             98   ;--------------------------------------------------
0460             99   
0460            100   Shift_Digits_Left:
0460 7804       101       mov R0, #4           ; 4 bit shifts (one nibble)
0462            102   
0462            103   Shift_Digits_Left_L0:
0462 C3         104       clr C                ; Clear carry before shift
0463 E538       105       mov A, bcd+0
0465 33         105       rlc A
0466 F538       105       mov bcd+0, A
0468 E539       106       mov A, bcd+1
046A 33         106       rlc A
046B F539       106       mov bcd+1, A
046D E53A       107       mov A, bcd+2
046F 33         107       rlc A
0470 F53A       107       mov bcd+2, A
0472 E53B       108       mov A, bcd+3
0474 33         108       rlc A
0475 F53B       108       mov bcd+3, A
0477 E53C       109       mov A, bcd+4
0479 33         109       rlc A
047A F53C       109       mov bcd+4, A
047C D8E4       110       djnz R0, Shift_Digits_Left_L0
047E            111   
047E            112       ; Insert new digit from R7 into lowest nibble safely
047E            113       ; Keep upper nibble of bcd+0 unchanged
047E 5338F0     114       anl  bcd+0, #0F0h    ; clear lower nibble
0481 EF         115       mov  A, R7
0482 540F       116       anl  A, #0Fh         ; ensure only 0-F
0484 4238       117       orl  bcd+0, A
0486 22         118       ret
0487            119   
0487            120   ;--------------------------------------------------
0487            121   ; Macro: Rotate Right through Carry
0487            122   ;--------------------------------------------------
0487            123   
                124   MYRRC MAC
                125       mov A, %0
                126       rrc A
                127       mov %0, A
                128   ENDMAC
0487            129   
0487            130   ;--------------------------------------------------
0487            131   ; Shift digits RIGHT by 4 bits
0487            132   ; Used for BACKSPACE (delete last digit)
0487            133   ;--------------------------------------------------
0487            134   
0487            135   Shift_Digits_Right:
0487 7804       136       mov R0, #4
0489            137   
0489            138   Shift_Digits_Right_L0:
0489 C3         139       clr C
048A E53C       140       mov A, bcd+4
048C 13         140       rrc A
048D F53C       140       mov bcd+4, A
048F E53B       141       mov A, bcd+3
0491 13         141       rrc A
0492 F53B       141       mov bcd+3, A
0494 E53A       142       mov A, bcd+2
0496 13         142       rrc A
0497 F53A       142       mov bcd+2, A
0499 E539       143       mov A, bcd+1
049B 13         143       rrc A
049C F539       143       mov bcd+1, A
049E E538       144       mov A, bcd+0
04A0 13         144       rrc A
04A1 F538       144       mov bcd+0, A
04A3 D8E4       145       djnz R0, Shift_Digits_Right_L0
04A5 22         146       ret
04A6            147   
04A6            148   
04A6            149   ;--------------------------------------------------
04A6            150   ; 25 ms delay (software debounce)
04A6            151   ;--------------------------------------------------
04A6            152   
04A6            153   Wait25ms:
04A6 780F       154       mov R0, #15
04A8 794A       155   L6: mov R1, #74
04AA 7AFA       156   L5: mov R2, #250
04AC DAFE       157   L4: djnz R2, L4
04AE D9FA       158       djnz R1, L5
04B0 D8F6       159       djnz R0, L6
04B2 22         160       ret
04B3            161   
04B3            162   
04B3            163   ;--------------------------------------------------
04B3            164   ; Helper routines for parameter storage
04B3            165   ; Each parameter value lives in bcd+0..bcd+1
04B3            166   ; active_param: 0=A, 1=B, 2=C, 3=D
04B3            167   ;--------------------------------------------------
04B3            168   
04B3            169   ; Save current BCD (bcd+0..bcd+1) into active parameter
04B3            170   Save_Current_BCD_Into_Param:
04B3 E558       171       mov A, active_param
04B5 B40007     172       cjne A, #0, Save_NotA
04B8            173       ; A: soak_temp
04B8 853850     174       mov soak_temp,   bcd+0
04BB 853951     175       mov soak_temp+1, bcd+1
04BE 22         176       ret
04BF            177   Save_NotA:
04BF B40107     178       cjne A, #1, Save_NotB
04C2            179       ; B: soak_time
04C2 853852     180       mov soak_time,   bcd+0
04C5 853953     181       mov soak_time+1, bcd+1
04C8 22         182       ret
04C9            183   Save_NotB:
04C9 B40207     184       cjne A, #2, Save_NotC
04CC            185       ; C: reflow_temp
04CC 853854     186       mov reflow_temp,   bcd+0
04CF 853955     187       mov reflow_temp+1, bcd+1
04D2 22         188       ret
04D3            189   Save_NotC:
04D3            190       ; D: reflow_time (default case)
04D3 853856     191       mov reflow_time,   bcd+0
04D6 853957     192       mov reflow_time+1, bcd+1
04D9 22         193       ret
