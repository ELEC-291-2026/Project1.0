050A            227   
050A            228   ;--------------------------------------------------
050A            229   ; Macro: Check one keypad column
050A            230   ; If pressed -> R7 = key value, C=1, jump to Key_Found
050A            231   ; %0 = column bit, %1 = key code (immediate)
050A            232   ;--------------------------------------------------
050A            233   
                234   CHECK_COLUMN MAC
                235       jb  %0, CHECK_COL_%M     ; if column=1 -> no key here -> skip
                236       mov R7, %1               ; store key code
                237       jnb %0, $                ; wait until key is released
                238       setb C                   ; mark "key found"
                239       ljmp Key_Found           ; use long jump instead of short
                240   CHECK_COL_%M:
                241   ENDMAC
050A            242   
050A            243   
