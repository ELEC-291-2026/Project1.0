0781            147   ; Routine to initialize the ISR   ;
0781            148   ; for timer 2                     ;
0781            149   ;---------------------------------;
0781            150   Timer2_Init:
0781 75C800     151            mov T2CON, #0 ; Stop timer/counter.  Autoreload mode.
0784 75CDF5     152            mov TH2, #high(TIMER2_RELOAD)
0787 75CC27     153            mov TL2, #low(TIMER2_RELOAD)
078A            154            ; Set the reload value
078A 75CBF5     155            mov RCAP2H, #high(TIMER2_RELOAD)
078D 75CA27     156            mov RCAP2L, #low(TIMER2_RELOAD)
0790            157            ; Enable the timer and interrupts
0790 D2AD       158       setb ET2  ; Enable timer 2 interrupt
0792 D2CA       159       setb TR2  ; Enable timer 2
0794 22         160            ret
0795            161   
0795            162   ;---------------------------------;
0795            163   ; ISR for timer 2.  Runs every ms ;
0795            164   ;---------------------------------;
0795            165   
0795            166   Timer2_ISR:
0795            167   
0795 C2CF       168            clr TF2  ; Timer 2 doesn't clear TF2 automatically. Do it in ISR
0797            169            ; Increment the timers for each FSM. That is all we do here!
0797 055B       170            inc FSM_timer 
0799            171            
0799 E55B       172            mov a, FSM_timer
