0123            257   ; -------------------------------------------------
0123            258   ; Macro: Check one keypad column
0123            259   ; If pressed ? R7 = key value, C=1, jump to Key_Found
0123            260   ; %0 = column bit, %1 = key code (immediate)
0123            261   ; -------------------------------------------------
0123            262   
                263   CHECK_COLUMN MAC
                264       jb %0, CHECK_COL_%M      ; if column=1 ? no key here ? skip
                265       mov R7, %1               ; store key code
                266       jnb %0, $                ; wait until key is released
                267       setb c                   ; mark "key found"
                268       ljmp Key_Found           ; use long jump instead of short
                269   CHECK_COL_%M:
                270   ENDMAC
