0013             47   ;--------------------------------------------------
0013             48   ; Macro: showBCD
0013             49   ; Input : one byte containing two BCD digits
0013             50   ; Output: two 7-seg displays
0013             51   ;   %0 = bcd byte
0013             52   ;   %1 = HEX low
0013             53   ;   %2 = HEX high
0013             54   ;--------------------------------------------------
0013             55   
                 56   showBCD MAC
                 57       ; ---- Display lower nibble (LSD) ----
                 58       mov  A, %0           ; Load BCD byte
                 59       anl  A, #0Fh         ; Keep lower 4 bits
                 60       movc A, @A+dptr      ; Convert using LUT
                 61       mov  %1, A           ; Output to first HEX display
                 62   
                 63       ; ---- Display upper nibble (MSD) ----
                 64       mov  A, %0
                 65       swap A               ; Swap nibbles
                 66       anl  A, #0Fh
                 67       movc A, @A+dptr
                 68       mov  %2, A           ; Output to second HEX display
                 69   ENDMAC
0013             70   
0013             71   
0013             72   ;--------------------------------------------------
0013             73   ; Display routine - show BCD number on HEX displays
0013             74   ; KEY3: 0 = show high digits, 1 = show low digits
0013             75   ; LEDRA.7: overflow indicator if bcd+3 or bcd+4 != 0
0013             76   ;--------------------------------------------------
0013             77   
0013             78   Display:
0013 900003      79       mov dptr, #myLUT     ; Point to lookup table
0016             80   
0016             81       ; If digits 10-7 (bcd+3 and bcd+4) are NOT zero
0016             82       ; turn ON LEDRA.7 as overflow indicator
0016             83   
0016 E533        84       mov A, bcd+3
0018 4534        85       orl A, bcd+4
001A 6004        86       jz  Display_L1
001C D2EF        87       setb LEDRA.7         ; Alert LED on
001E 8002        88       sjmp Display_L2
0020             89   Display_L1:
0020 C2EF        90       clr LEDRA.7          ; Alert LED off
0022             91   Display_L2:
0022             92   
0022             93       ; If KEY3 pressed (assuming active low) show HIGH digits
0022             94       ; Otherwise show LOW digits
0022             95   
0022 30FB2F      96       jnb KEY.3, Display_high_digits
