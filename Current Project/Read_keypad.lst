0123 439B54     279       orl P1MOD, #0b_01010100  ; Rows as output
0126 439C01     280       orl P2MOD, #0b_00000001
0129 539CAB     281       anl P2MOD, #0b_10101011  ; Columns as input
012C 539DFE     282       anl P3MOD, #0b_11111110
012F 22         283       ret
