                155       rrc a
                156       mov %0, a
                157   ENDMAC
00A0            158   
00A0            159   ; -------------------------------------------------
00A0            160   ; Shift digits RIGHT by 4 bits
00A0            161   ; ? used for BACKSPACE (delete last digit)
00A0            162   ; -------------------------------------------------
00A0            163   
00A0            164   Shift_Digits_Right:
00A0 7804       165       mov R0, #4
00A2            166   
00A2            167   Shift_Digits_Right_L0:
00A2 C3         168       clr c
00A3 E534       169       mov a, bcd+4
00A5 13         169       rrc a
00A6 F534       169       mov bcd+4, a
00A8 E533       170       mov a, bcd+3
00AA 13         170       rrc a
00AB F533       170       mov bcd+3, a
00AD E532       171       mov a, bcd+2
00AF 13         171       rrc a
00B0 F532       171       mov bcd+2, a
00B2 E531       172       mov a, bcd+1
00B4 13         172       rrc a
00B5 F531       172       mov bcd+1, a
00B7 E530       173       mov a, bcd+0
00B9 13         173       rrc a
00BA F530       173       mov bcd+0, a
00BC D8E4       174       djnz R0, Shift_Digits_Right_L0
00BE 22         175       ret
