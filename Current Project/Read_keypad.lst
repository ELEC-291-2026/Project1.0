0130            296   ; -------------------------------------------------
0130            297   ; Keypad scanning routine
0130            298   ; Output:
0130            299   ;   C = 1 ? numeric key pressed, code in R7 (0–9, maybe E/F)
0130            300   ;   C = 0 ? no digit (no key, mode key, or backspace)
0130            301   ; -------------------------------------------------
0130            302   
0130            303   Keypad:
0130            304   
0130            305       ; KEY1 acts as BACKSPACE / ERASE
0130            306       
0130 20F90E     307       jb KEY.1, keypad_L0      ; if KEY1=1 (not pressed) ? skip
0133 1200BF     308       lcall Wait25ms
0136 20F908     309       jb KEY.1, keypad_L0      ; still high? ? bounce, skip
0139 30F9FD     310       jnb KEY.1, $             ; wait for release (KEY1 low while pressed)
013C 1200A0     311       lcall Shift_Digits_Right ; delete LSD for active parameter
013F C3         312       clr c                    ; no digit returned
0140 22         313       ret
0141            314   
0141            315   keypad_L0:
0141            316       
0141            317       ; Drive all rows LOW ? check if any column LOW
0141            318       
0141 C292       319       clr ROW1
0143 C294       320       clr ROW2
0145 C296       321       clr ROW3
0147 C2A0       322       clr ROW4
0149            323   
0149 A2A2       324       mov c, COL1
014B 82A4       325       anl c, COL2
014D 82A6       326       anl c, COL3
014F 82B0       327       anl c, COL4
0151 5002       328       jnc Keypad_Debounce      ; if any column low ? possible key
0153 C3         329       clr c
0154 22         330       ret
0155            331   
0155            332   Keypad_Debounce:
0155            333       ; Wait and check again to avoid bouncing
0155 1200BF     334       lcall Wait25ms
0158            335   
0158 A2A2       336       mov c, COL1
015A 82A4       337       anl c, COL2
015C 82A6       338       anl c, COL3
015E 82B0       339       anl c, COL4
0160 5002       340       jnc Keypad_Key_Code
0162 C3         341       clr c
0163 22         342       ret
0164            343   
0164            344   Keypad_Key_Code:
0164            345       ; Prepare to scan each row individually
0164 D292       346       setb ROW1
0166 D294       347       setb ROW2
0168 D296       348       setb ROW3
016A D2A0       349       setb ROW4
016C            350   
016C            351       ; SW0 selects layout orientation
016C 30E803     352       jnb SWA.0, keypad_default
016F 020244     353       ljmp keypad_90deg
