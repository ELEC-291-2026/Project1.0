0130            297   ;--------------------------------------------------
0130            298   ; Keypad scanning routine
0130            299   ; Output:
0130            300   ;   C = 1 -> numeric key pressed, code in R7 (0-9, maybe E/F)
0130            301   ;   C = 0 -> no digit (no key, mode key, or backspace)
0130            302   ;--------------------------------------------------
0130            303   
0130            304   Keypad:
0130            305   
0130            306       ; KEY1 acts as BACKSPACE / ERASE
0130            307   
0130 20F90E     308       jb  KEY.1, keypad_L0     ; if KEY1=1 (not pressed) -> skip
0133 1200BF     309       lcall Wait25ms
0136 20F908     310       jb  KEY.1, keypad_L0     ; if bounced back high, skip
0139 30F9FD     311       jnb KEY.1, $             ; wait for release (KEY1 low while pressed)
013C 1200A0     312       lcall Shift_Digits_Right ; delete LSD for active parameter
013F C3         313       clr C                    ; no digit returned
0140 22         314       ret
0141            315   
0141            316   keypad_L0:
0141            317   
0141            318       ; Drive all rows LOW - check if any column LOW
0141            319   
0141 C292       320       clr ROW1
0143 C294       321       clr ROW2
0145 C296       322       clr ROW3
0147 C2A0       323       clr ROW4
0149            324   
0149 A2A2       325       mov C, COL1
014B 82A4       326       anl C, COL2
014D 82A6       327       anl C, COL3
014F 82B0       328       anl C, COL4
0151 5002       329       jnc Keypad_Debounce      ; if any column low -> possible key
0153 C3         330       clr C
0154 22         331       ret
0155            332   
0155            333   Keypad_Debounce:
0155            334       ; Wait and check again to avoid bouncing
0155 1200BF     335       lcall Wait25ms
0158            336   
0158 A2A2       337       mov C, COL1
015A 82A4       338       anl C, COL2
015C 82A6       339       anl C, COL3
015E 82B0       340       anl C, COL4
0160 5002       341       jnc Keypad_Key_Code
0162 C3         342       clr C
0163 22         343       ret
0164            344   
0164            345   Keypad_Key_Code:
0164            346       ; Prepare to scan each row individually
0164 D292       347       setb ROW1
0166 D294       348       setb ROW2
0168 D296       349       setb ROW3
016A D2A0       350       setb ROW4
016C            351   
016C            352       ; SW0 selects layout orientation
016C 30E803     353       jnb SWA.0, keypad_default
016F 020244     354       ljmp keypad_90deg
0172            355   
