0013             45   ;---------------------------------------------------------
0013             46   ; Macro: showBCD
0013             47   ; Input : one byte containing two BCD digits
0013             48   ; Output: two 7-seg displays
0013             49   ;   %0 = bcd byte
0013             50   ;   %1 = HEX low
0013             51   ;   %2 = HEX high
0013             52   ;---------------------------------------------------------
0013             53   
                 54   showBCD MAC
                 55       ; ---- Display lower nibble (LSD) ----
                 56       mov A, %0          ; Load BCD byte
                 57       anl a, #0fh        ; Keep lower 4 bits
                 58       movc A, @A+dptr    ; Convert using LUT
                 59       mov %1, A          ; Output to first HEX display
                 60   
                 61       ; ---- Display upper nibble (MSD) ----
                 62       mov A, %0
                 63       swap a             ; Swap nibbles
                 64       anl a, #0fh
                 65       movc A, @A+dptr
                 66       mov %2, A          ; Output to second HEX display
                 67   ENDMAC
0013             68   
0013             69   
0013             70   ; -------------------------------------------------
0013             71   ; Display routine – show BCD number on HEX displays
0013             72   ; KEY3: 0 ? show high digits, 1 ? show low digits
0013             73   ; LEDRA.7: overflow indicator if bcd+3 or bcd+4 != 0
0013             74   ; -------------------------------------------------
0013             75   
0013             76   Display:
0013 900003      77       mov dptr, #myLUT   ; Point to lookup table
0016             78   
0016             79       ; If digits 10–7 (bcd+3 and bcd+4) are NOT zero
0016             80       ; ? turn ON LEDR7 as overflow indicator
0016             81   
0016 E533        82       mov a, bcd+3
0018 4534        83       orl a, bcd+4
001A 6004        84       jz Display_L1
001C D2EF        85       setb LEDRA.7       ; Alert LED on
001E 8002        86       sjmp Display_L2
0020             87   Display_L1:
0020 C2EF        88       clr LEDRA.7        ; Alert LED off
0022             89   Display_L2:
0022             90   
0022             91       ; If KEY3 pressed (assuming active low) ? show HIGH digits
