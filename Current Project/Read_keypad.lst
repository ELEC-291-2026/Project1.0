00BF            180   ;--------------------------------------------------
00BF            181   ; 25 ms delay (software debounce)
00BF            182   ;--------------------------------------------------
00BF            183   
00BF            184   Wait25ms:
00BF 780F       185       mov R0, #15
00C1 794A       186   L3: mov R1, #74
00C3 7AFA       187   L2: mov R2, #250
00C5 DAFE       188   L1: djnz R2, L1
00C7 D9FA       189       djnz R1, L2
00C9 D8F6       190       djnz R0, L3
00CB 22         191       ret
