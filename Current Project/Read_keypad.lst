0123            258   
0123            259   ;--------------------------------------------------
0123            260   ; Macro: Check one keypad column
0123            261   ; If pressed -> R7 = key value, C=1, jump to Key_Found
0123            262   ; %0 = column bit, %1 = key code (immediate)
0123            263   ;--------------------------------------------------
0123            264   
                265   CHECK_COLUMN MAC
                266       jb  %0, CHECK_COL_%M     ; if column=1 -> no key here -> skip
                267       mov R7, %1               ; store key code
                268       jnb %0, $                ; wait until key is released
                269       setb C                   ; mark "key found"
                270       ljmp Key_Found           ; use long jump instead of short
                271   CHECK_COL_%M:
                272   ENDMAC
0123            273   
0123            274   
