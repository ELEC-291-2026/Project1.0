0029 93          99       movc A, @A+dptr      ; Convert using LUT
002A F591        99       mov  HEX0, A           ; Output to first HEX display
002C             99   
002C             99       ; ---- Display upper nibble (MSD) ----
002C E530        99       mov  A, bcd+0
002E C4          99       swap A               ; Swap nibbles
002F 540F        99       anl  A, #0Fh
0031 93          99       movc A, @A+dptr
0032 F592        99       mov  HEX1, A           ; Output to second HEX display
