0316            439   ; -------------------------------------------------
0316            440   ; Key_Found:
0316            441   ;   R7 = key code (0–F), C = 1 when we get here.
0316            442   ;   A/B/C/D (0Ah–0Dh) ? mode select, no digit
0316            443   ;   Others ? numeric digit, C stays 1
0316            444   ; -------------------------------------------------
0316            445   
0316            446   Key_Found:
0316 EF         447       mov a, R7
0317            448   
