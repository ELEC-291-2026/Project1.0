0316            440   ;--------------------------------------------------
0316            441   ; Key_Found:
0316            442   ;   R7 = key code (0-F), C = 1 when we get here.
0316            443   ;   A/B/C/D (0Ah-0Dh) -> mode select
0316            444   ;   * (0Eh)           -> delete / backspace one digit
0316            445   ;   # (0Fh)           -> clear all digits
0316            446   ;   others (0-9, maybe E/F) -> digit
0316            447   ;--------------------------------------------------
0316            448   
0316            449   Key_Found:
0316 EF         450       mov A, R7
0317            451   
0317            452       ; --- Mode A (soak temperature) ---
0317 B40A0B     453       cjne A, #0Ah, KF_CheckB
031A 1200CC     454       lcall Save_Current_BCD_Into_Param
031D 753D00     455       mov   active_param, #0       ; A: soak_temp
0320 1200F3     456       lcall Load_Param_Into_BCD
0323 C3         457       clr C                        ; do not treat as digit
0324 22         458       ret
0325            459   
0325            460   KF_CheckB:
0325            461       ; --- Mode B (soak time) ---
0325 B40B0B     462       cjne A, #0Bh, KF_CheckC
0328 1200CC     463       lcall Save_Current_BCD_Into_Param
032B 753D01     464       mov   active_param, #1       ; B: soak_time
032E 1200F3     465       lcall Load_Param_Into_BCD
0331 C3         466       clr C
0332 22         467       ret
0333            468   
0333            469   KF_CheckC:
0333            470       ; --- Mode C (reflow temperature) ---
0333 B40C0B     471       cjne A, #0Ch, KF_CheckD
0336 1200CC     472       lcall Save_Current_BCD_Into_Param
0339 753D02     473       mov   active_param, #2       ; C: reflow_temp
033C 1200F3     474       lcall Load_Param_Into_BCD
033F C3         475       clr C
0340 22         476       ret
0341            477   
0341            478   KF_CheckD:
0341            479       ; --- Mode D (reflow time) ---
0341 B40D0B     480       cjne A, #0Dh, KF_CheckStar
0344 1200CC     481       lcall Save_Current_BCD_Into_Param
0347 753D03     482       mov   active_param, #3       ; D: reflow_time
034A 1200F3     483       lcall Load_Param_Into_BCD
034D C3         484       clr C
034E 22         485       ret
034F            486   
034F            487   KF_CheckStar:
034F            488       ; --- '*' key (code 0Eh) -> delete / backspace ---
034F B40E05     489       cjne A, #0Eh, KF_CheckHash
0352            490       ; Backspace = shift digits right by 1 digit
0352 1200A0     491       lcall Shift_Digits_Right
0355 C3         492       clr C                        ; no new digit for main loop
0356 22         493       ret
0357            494   
0357            495   KF_CheckHash:
0357            496       ; --- '#' key (code 0Fh) -> clear ---
0357 B40F0D     497       cjne A, #0Fh, KF_Digit
035A            498       ; Clear all BCD digits for current parameter
035A E4         499       clr A
035B F530       500       mov bcd+0, A
035D F531       501       mov bcd+1, A
035F F532       502       mov bcd+2, A
0361 F533       503       mov bcd+3, A
0363 F534       504       mov bcd+4, A
0365 C3         505       clr C                        ; no digit to insert
0366 22         506       ret
0367            507   
0367            508   KF_Digit:
0367            509       ; Not A/B/C/D/*/# -> treat as numeric digit key
0367            510       ; R7 holds the digit, Carry = 1 -> main loop will append it
0367 22         511       ret
0368            512   
0368            513   
0368            514   ;--------------------------------------------------
0368            515   ; MAIN PROGRAM
0368            516   ;--------------------------------------------------
0368            517   
0368            518   main_code:
0368 75817F     519       mov SP, #7Fh        ; Initialize stack pointer
036B            520   
036B E4         521       clr A
036C F5E8       522       mov LEDRA, A        ; Clear LEDs
036E F595       523       mov LEDRB, A
0370            524   
0370            525       ; Clear all BCD digits
0370 F530       526       mov bcd+0, A
0372 F531       527       mov bcd+1, A
0374 F532       528       mov bcd+2, A
0376 F533       529       mov bcd+3, A
0378 F534       530       mov bcd+4, A
037A            531   
037A            532       ; Clear parameter storage
037A F535       533       mov soak_temp,   A
037C F536       534       mov soak_temp+1, A
037E F537       535       mov soak_time,   A
0380 F538       536       mov soak_time+1, A
0382 F539       537       mov reflow_temp,   A
0384 F53A       538       mov reflow_temp+1, A
0386 F53B       539       mov reflow_time,   A
0388 F53C       540       mov reflow_time+1, A
038A            541   
038A            542       ; Start in mode A: soak temperature
038A 753D00     543       mov active_param, #0
038D 1200F3     544       lcall Load_Param_Into_BCD
0390            545   
0390 120123     546       lcall Configure_Keypad_Pins
0393            547   
0393            548   
0393            549   ;--------------------------------------------------
0393            550   ; Main loop
0393            551   ;--------------------------------------------------
0393            552   
0393            553   forever:
0393 120130     554       lcall Keypad        ; Scan keypad
0396 120013     555       lcall Display       ; Update HEX displays (or later, LCD)
0399 50F8       556       jnc  forever        ; If C=0 -> no digit to insert (mode/backspace/clear/none)
039B            557   
039B 120079     558       lcall Shift_Digits_Left  ; If C=1 -> numeric key; insert new digit from R7
039E 020393     559       ljmp forever
03A1            560   
03A1            561   end
