0003             40   myLUT:
0003 C0F9A4B0    41       DB 0xC0, 0xF9, 0xA4, 0xB0, 0x99        ; digits 0–4
     99
0008 9282F880    42       DB 0x92, 0x82, 0xF8, 0x80, 0x90        ; digits 5–9
     90
000D 8883C6A1    43       DB 0x88, 0x83, 0xC6, 0xA1, 0x86, 0x8E  ; A–F
     868E
