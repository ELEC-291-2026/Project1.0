00BF            178   ; -------------------------------------------------
00BF            179   ; 25 ms delay (software debounce)
00BF            180   ; -------------------------------------------------
00BF            181   
00BF            182   Wait25ms:
00BF 780F       183       mov R0, #15
00C1 794A       184   L3: mov R1, #74
00C3 7AFA       185   L2: mov R2, #250
00C5 DAFE       186   L1: djnz R2, L1
00C7 D9FA       187       djnz R1, L2
00C9 D8F6       188       djnz R0, L3
00CB 22         189       ret
