00CC            194   ;--------------------------------------------------
00CC            195   ; Helper routines for parameter storage
00CC            196   ; Each parameter value lives in bcd+0..bcd+1
00CC            197   ; active_param: 0=A, 1=B, 2=C, 3=D
00CC            198   ;--------------------------------------------------
00CC            199   
00CC            200   ; Save current BCD (bcd+0..bcd+1) into active parameter
00CC            201   Save_Current_BCD_Into_Param:
00CC E53D       202       mov A, active_param
00CE B40007     203       cjne A, #0, Save_NotA
00D1            204       ; A: soak_temp
00D1 853035     205       mov soak_temp,   bcd+0
00D4 853136     206       mov soak_temp+1, bcd+1
00D7 22         207       ret
00D8            208   Save_NotA:
00D8 B40107     209       cjne A, #1, Save_NotB
00DB            210       ; B: soak_time
00DB 853037     211       mov soak_time,   bcd+0
00DE 853138     212       mov soak_time+1, bcd+1
00E1 22         213       ret
00E2            214   Save_NotB:
00E2 B40207     215       cjne A, #2, Save_NotC
00E5            216       ; C: reflow_temp
00E5 853039     217       mov reflow_temp,   bcd+0
00E8 85313A     218       mov reflow_temp+1, bcd+1
00EB 22         219       ret
00EC            220   Save_NotC:
00EC            221       ; D: reflow_time (default case)
00EC 85303B     222       mov reflow_time,   bcd+0
00EF 85313C     223       mov reflow_time+1, bcd+1
00F2 22         224       ret
00F3            225   
00F3            226   
00F3            227   ; Load active parameter into BCD (bcd+0..bcd+1)
00F3            228   ; Clear the higher digits.
00F3            229   Load_Param_Into_BCD:
00F3 753200     230       mov bcd+2, #00h
00F6 753300     231       mov bcd+3, #00h
00F9 753400     232       mov bcd+4, #00h
00FC            233   
00FC E53D       234       mov A, active_param
00FE B40007     235       cjne A, #0, Load_NotA
0101            236       ; A: soak_temp
0101 853530     237       mov bcd+0, soak_temp
0104 853631     238       mov bcd+1, soak_temp+1
0107 22         239       ret
0108            240   Load_NotA:
0108 B40107     241       cjne A, #1, Load_NotB
010B            242       ; B: soak_time
010B 853730     243       mov bcd+0, soak_time
010E 853831     244       mov bcd+1, soak_time+1
0111 22         245       ret
0112            246   Load_NotB:
0112 B40207     247       cjne A, #2, Load_NotC
0115            248       ; C: reflow_temp
