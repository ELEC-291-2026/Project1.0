0013             48   ; Display routine – show BCD number on HEX displays
0013             49   
0013             50   Display:
0013 900003      51       mov dptr, #myLUT   ; Point to lookup table
0016             52   
0016             53       ; If digits 10–7 (bcd+3 and bcd+4) are NOT zero
