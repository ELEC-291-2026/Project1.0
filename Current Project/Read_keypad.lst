0079            117   ; Macro: Rotate Left through Carry
0079            118   ;--------------------------------------------------
0079            119   
                120   MYRLC MAC
                121       mov A, %0
                122       rlc A
                123       mov %0, A
                124   ENDMAC
0079            125   
0079            126   ;--------------------------------------------------
0079            127   ; Shift all BCD digits LEFT by 4 bits
0079            128   ; Makes room for new digit in LSD (R7)
0079            129   ;--------------------------------------------------
0079            130   
0079            131   Shift_Digits_Left:
0079 7804       132       mov R0, #4           ; 4 bit shifts (one nibble)
007B            133   
007B            134   Shift_Digits_Left_L0:
007B C3         135       clr C                ; Clear carry before shift
007C E530       136       mov A, bcd+0
007E 33         136       rlc A
007F F530       136       mov bcd+0, A
0081 E531       137       mov A, bcd+1
0083 33         137       rlc A
0084 F531       137       mov bcd+1, A
0086 E532       138       mov A, bcd+2
0088 33         138       rlc A
0089 F532       138       mov bcd+2, A
008B E533       139       mov A, bcd+3
008D 33         139       rlc A
008E F533       139       mov bcd+3, A
0090 E534       140       mov A, bcd+4
0092 33         140       rlc A
0093 F534       140       mov bcd+4, A
0095 D8E4       141       djnz R0, Shift_Digits_Left_L0
0097            142   
0097            143       ; Insert new digit from R7 into lowest nibble safely
0097            144       ; Keep upper nibble of bcd+0 unchanged
0097 5330F0     145       anl  bcd+0, #0F0h    ; clear lower nibble
009A EF         146       mov  A, R7
009B 540F       147       anl  A, #0Fh         ; ensure only 0-F
009D 4230       148       orl  bcd+0, A
009F 22         149       ret
00A0            150   
