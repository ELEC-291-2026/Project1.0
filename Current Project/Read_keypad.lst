0079            115   ; Macro: Rotate Left through Carry
0079            116   ; -------------------------------------------------
0079            117   
                118   MYRLC MAC
                119       mov a, %0
                120       rlc a
                121       mov %0, a
                122   ENDMAC
0079            123   
0079            124   ; -------------------------------------------------
0079            125   ; Shift all BCD digits LEFT by 4 bits
0079            126   ; ? makes room for new digit in LSD (R7)
0079            127   ; -------------------------------------------------
0079            128   
0079            129   Shift_Digits_Left:
0079 7804       130       mov R0, #4         ; Need 4 bit shifts (one nibble)
007B            131   
007B            132   Shift_Digits_Left_L0:
007B C3         133       clr c              ; Clear carry before shift
007C E530       134       mov a, bcd+0
007E 33         134       rlc a
007F F530       134       mov bcd+0, a
0081 E531       135       mov a, bcd+1
0083 33         135       rlc a
0084 F531       135       mov bcd+1, a
0086 E532       136       mov a, bcd+2
0088 33         136       rlc a
0089 F532       136       mov bcd+2, a
008B E533       137       mov a, bcd+3
008D 33         137       rlc a
008E F533       137       mov bcd+3, a
0090 E534       138       mov a, bcd+4
0092 33         138       rlc a
0093 F534       138       mov bcd+4, a
0095 D8E4       139       djnz R0, Shift_Digits_Left_L0
0097            140   
0097            141       ; Insert new digit from R7 into lowest nibble safely
0097            142       ; Keep upper nibble of bcd+0 unchanged
0097 5330F0     143       anl bcd+0, #0F0h   ; clear lower nibble
009A EF         144       mov a, R7
009B 540F       145       anl a, #0Fh        ; ensure only 0–F
009D 4230       146       orl bcd+0, a
009F 22         147       ret
