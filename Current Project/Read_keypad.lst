0003             37   ;--------------------------------------------------
0003             38   ; Lookup table for 7-segment display patterns (common anode)
0003             39   ; Index 0-F = segment pattern
0003             40   ;--------------------------------------------------
0003             41   
0003             42   myLUT:
0003 C0F9A4B0    43       DB 0C0h, 0F9h, 0A4h, 0B0h, 099h        ; digits 0-4
     99
0008 9282F880    44       DB 092h, 082h, 0F8h, 080h, 090h        ; digits 5-9
     90
000D 8883C6A1    45       DB 088h, 083h, 0C6h, 0A1h, 086h, 08Eh  ; A-F
     868E
