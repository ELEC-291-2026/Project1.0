031D 753D00     452       mov active_param, #0       ; A: soak_temp
0320 1200F3     453       lcall Load_Param_Into_BCD
0323            454       ; Optional: indicate mode with LEDs (e.g., LEDRB = active_param)
0323            455       ; mov a, active_param
0323            456       ; mov LEDRB, a
0323 C3         457       clr c                      ; not a digit
0324 22         458       ret
