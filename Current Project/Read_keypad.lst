00CC            192   ; -------------------------------------------------
00CC            193   ; Helper routines for parameter storage
00CC            194   ; Each parameter value lives in bcd+0..bcd+1
00CC            195   ; active_param: 0=A, 1=B, 2=C, 3=D
00CC            196   ; -------------------------------------------------
00CC            197   
00CC            198   ; Save current BCD (bcd+0..bcd+1) into active parameter
00CC            199   Save_Current_BCD_Into_Param:
00CC E53D       200       mov a, active_param
00CE B40007     201       cjne a, #0, Save_NotA
00D1            202       ; A: soak_temp
00D1 853035     203       mov soak_temp,   bcd+0
00D4 853136     204       mov soak_temp+1, bcd+1
00D7 22         205       ret
00D8            206   Save_NotA:
00D8 B40107     207       cjne a, #1, Save_NotB
00DB            208       ; B: soak_time
00DB 853037     209       mov soak_time,   bcd+0
00DE 853138     210       mov soak_time+1, bcd+1
00E1 22         211       ret
00E2            212   Save_NotB:
00E2 B40207     213       cjne a, #2, Save_NotC
00E5            214       ; C: reflow_temp
00E5 853039     215       mov reflow_temp,   bcd+0
00E8 85313A     216       mov reflow_temp+1, bcd+1
00EB 22         217       ret
00EC            218   Save_NotC:
00EC            219       ; D: reflow_time (default case)
00EC 85303B     220       mov reflow_time,   bcd+0
00EF 85313C     221       mov reflow_time+1, bcd+1
00F2 22         222       ret
00F3            223   
00F3            224   
00F3            225   ; Load active parameter into BCD (bcd+0..bcd+1)
