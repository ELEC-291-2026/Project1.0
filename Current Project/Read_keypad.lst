                155   MYRRC MAC
                156       mov A, %0
                157       rrc A
                158       mov %0, A
                159   ENDMAC
00A0            160   
00A0            161   ;--------------------------------------------------
00A0            162   ; Shift digits RIGHT by 4 bits
00A0            163   ; Used for BACKSPACE (delete last digit)
00A0            164   ;--------------------------------------------------
00A0            165   
00A0            166   Shift_Digits_Right:
00A0 7804       167       mov R0, #4
00A2            168   
00A2            169   Shift_Digits_Right_L0:
00A2 C3         170       clr C
00A3 E534       171       mov A, bcd+4
00A5 13         171       rrc A
00A6 F534       171       mov bcd+4, A
00A8 E533       172       mov A, bcd+3
00AA 13         172       rrc A
00AB F533       172       mov bcd+3, A
00AD E532       173       mov A, bcd+2
00AF 13         173       rrc A
00B0 F532       173       mov bcd+2, A
00B2 E531       174       mov A, bcd+1
00B4 13         174       rrc A
00B5 F531       174       mov bcd+1, A
00B7 E530       175       mov A, bcd+0
00B9 13         175       rrc A
00BA F530       175       mov bcd+0, A
00BC D8E4       176       djnz R0, Shift_Digits_Right_L0
00BE 22         177       ret
