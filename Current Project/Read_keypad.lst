0013             26   ;---------------------------------------------------------
0013             27   ; Macro: showBCD
0013             28   ; Input : one byte containing two BCD digits
0013             29   ; Output: two 7-seg displays
0013             30   ;---------------------------------------------------------
0013             31   
                 32   showBCD MAC
                 33       ; ---- Display lower nibble (LSD) ----
                 34       mov A, %0          ; Load BCD byte
                 35       anl a, #0fh        ; Keep lower 4 bits
                 36       movc A, @A+dptr    ; Convert using LUT
                 37       mov %1, A          ; Output to first HEX display
                 38   
                 39       ; ---- Display upper nibble (MSD) ----
                 40       mov A, %0
                 41       swap a             ; Swap nibbles
                 42       anl a, #0fh
                 43       movc A, @A+dptr
                 44       mov %2, A          ; Output to second HEX display
                 45   ENDMAC
0013             46   
