0123            276   ; Configure GPIO directions for keypad
0123            277   ;--------------------------------------------------
0123            278   
0123            279   Configure_Keypad_Pins:
0123 439B54     280       orl P1MOD, #01010100b    ; Rows as output on P1
0126 439C01     281       orl P2MOD, #00000001b
0129 539CAB     282       anl P2MOD, #10101011b    ; Columns as input on P2
012C 539DFE     283       anl P3MOD, #11111110b    ; Column on P3.0 input
012F 22         284       ret
