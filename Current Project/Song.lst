0000              1   ; ISR_example_DE10Lite.asm:
0000              2   ; a) Increments/decrements a BCD variable every half second using
0000              3   ;    an ISR for timer 2.  Uses SW0 to decide.  Also 'blinks' LEDR0 every
0000              4   ;    half a second.
0000              5   ; b) Generates a 2kHz square wave at pin P1.5 using an ISR for timer 0.
0000              6   ; c) In the 'main' loop it displays the variable incremented/decremented
0000              7   ;    using the ISR for timer 2 on the LCD and the 7-segment displays.
0000              8   ;    Also resets it to zero if the KEY1 pushbutton  is pressed.
0000              9   ; d) Controls the LCD using general purpose pins P2.3, P2.5, P2.7, P3.1, P3.3, P3.5, P3.7
0000             10   ;
                 12   $LIST
0000             14   
0000             15   CLK           EQU 33333333 ; Microcontroller system crystal frequency in Hz
0000             16   TIMER0_RATE   EQU 4096     ; 2048Hz squarewave (peak amplitude of CEM-1203 speaker)
0000             17   TIMER0_RELOAD EQU ((65536-(CLK/(12*TIMER0_RATE)))) ; The prescaler in the CV-8052 is always 12 unlike the N76E003 where is selectable.
0000             18   TIMER2_RATE   EQU 1000     ; 1000Hz, for a timer tick of 1ms
0000             19   TIMER2_RELOAD EQU ((65536-(CLK/(12*TIMER2_RATE))))
0000             20   
0000             21   SOUND_OUT     equ P0.4
0000             22   UPDOWN        equ SWA.0
0000             23   
0000             24   ; Reset vector
0000             25   org 0x0000
0000 020188      26       ljmp main
0003             27   
0003             28   ; External interrupt 0 vector (not used in this code)
0003             29   org 0x0003
0003 32          30            reti
0004             31   
0004             32   ; Timer/Counter 0 overflow interrupt vector
000B             33   org 0x000B
000B 02010B      34            ljmp Timer0_ISR
000E             35   
000E             36   ; External interrupt 1 vector (not used in this code)
0013             37   org 0x0013
0013 32          38            reti
0014             39   
0014             40   ; Timer/Counter 1 overflow interrupt vector (not used in this code)
001B             41   org 0x001B
001B 32          42            reti
001C             43   
001C             44   ; Serial port receive/transmit interrupt vector (not used in this code)
0023             45   org 0x0023 
0023 32          46            reti
0024             47            
0024             48   ; Timer/Counter 2 overflow interrupt vector
002B             49   org 0x002B
002B 02012D      50            ljmp Timer2_ISR
002E             51   
002E             52   ; In the 8051 we can define direct access variables starting at location 0x30 up to location 0x7F
0030             53   dseg at 0x30
0030             54   Count1ms:     ds 2 ; Used to determine when half second has passed
0032             55   BCD_counter:  ds 1 ; The BCD counter incrememted in the ISR and displayed in the main loop
0033             56   
0033             57   ; In the 8051 we have variables that are 1-bit in size.  We can use the setb, clr, jb, and jnb
0033             58   ; instructions with these variables.  This is how you define a 1-bit variable:
0000             59   bseg
0000             60   half_seconds_flag: dbit 1 ; Set to one in the ISR every time 500 ms had passed
0001             61   
002E             62   cseg
002E             63   ; These 'equ' must match the wiring between the DE10Lite board and the LCD!
002E             64   ; P0 is in connector JPIO.  Check "CV-8052 Soft Processor in the DE10Lite Board: Getting
002E             65   ; Started Guide" for the details.
002E             66   ELCD_RS equ P3.7
002E             67   ELCD_RW equ P3.5
002E             68   ELCD_E  equ P3.3
002E             69   ELCD_D4 equ P3.1
002E             70   ELCD_D5 equ P2.7
002E             71   ELCD_D6 equ P2.5
002E             72   ELCD_D7 equ P2.3
                 74   	$LIST
00E7             76   
00E7             77   ;                     1234567890123456    <- This helps determine the location of the counter
00E7 4243445F    78   Initial_Message:  db 'BCD_counter: xx ', 0
     636F756E
     7465723A
     20787820
     00
00F8             79   
00F8             80   ;---------------------------------;
00F8             81   ; Routine to initialize the ISR   ;
00F8             82   ; for timer 0                     ;
00F8             83   ;---------------------------------;
00F8             84   Timer0_Init:
00F8 E589        85            mov a, TMOD
00FA 54F0        86            anl a, #0xf0 ; Clear the bits for timer 0
00FC 4401        87            orl a, #0x01 ; Configure timer 0 as 16-timer
00FE F589        88            mov TMOD, a
0100 758CFD      89            mov TH0, #high(TIMER0_RELOAD)
0103 758A5A      90            mov TL0, #low(TIMER0_RELOAD)
0106             91            ; Enable the timer and interrupts
0106 D2A9        92       setb ET0  ; Enable timer 0 interrupt
0108 D28C        93       setb TR0  ; Start timer 0
010A 22          94            ret
010B             95   
010B             96   ;---------------------------------;
010B             97   ; ISR for timer 0.  Set to execute;
010B             98   ; every 1/4096Hz to generate a    ;
010B             99   ; 2048 Hz square wave at pin P3.7 ;
010B            100   ;---------------------------------;
010B            101   Timer0_ISR:
010B            102            ;clr TF0  ; According to the data sheet this is done for us already.
010B 758CFD     103            mov TH0, #high(TIMER0_RELOAD) ; Timer 0 doesn't have autoreload in the CV-8052
010E 758A5A     104            mov TL0, #low(TIMER0_RELOAD)
0111 B284       105            cpl SOUND_OUT ; Connect speaker to P3.7!
0113 32         106            reti
0114            107   
0114            108   ;---------------------------------;
0114            109   ; Routine to initialize the ISR   ;
0114            110   ; for timer 2                     ;
0114            111   ;---------------------------------;
0114            112   Timer2_Init:
0114 75C800     113            mov T2CON, #0 ; Stop timer/counter.  Autoreload mode.
0117 75CDF5     114            mov TH2, #high(TIMER2_RELOAD)
011A 75CC27     115            mov TL2, #low(TIMER2_RELOAD)
011D            116            ; Set the reload value
011D 75CBF5     117            mov RCAP2H, #high(TIMER2_RELOAD)
0120 75CA27     118            mov RCAP2L, #low(TIMER2_RELOAD)
0123            119            ; Init One millisecond interrupt counter.  It is a 16-bit variable made with two 8-bit parts
0123 E4         120            clr a
0124 F530       121            mov Count1ms+0, a
0126 F531       122            mov Count1ms+1, a
0128            123            ; Enable the timer and interrupts
0128 D2AD       124       setb ET2  ; Enable timer 2 interrupt
012A D2CA       125       setb TR2  ; Enable timer 2
012C 22         126            ret
012D            127   
012D            128   ;---------------------------------;
012D            129   ; ISR for timer 2                 ;
012D            130   ;---------------------------------;
012D            131   Timer2_ISR:
012D C2CF       132            clr TF2  ; Timer 2 doesn't clear TF2 automatically. Do it in ISR
012F B291       133            cpl P1.1 ; To check the interrupt rate with oscilloscope. It must be precisely a 1 ms pulse.
0131            134            
0131            135            ; The two registers used in the ISR must be saved in the stack
0131 C0E0       136            push acc
0133 C0D0       137            push psw
0135            138            
0135            139            ; Increment the 16-bit one mili second counter
0135 0530       140            inc Count1ms+0    ; Increment the low 8-bits first
0137 E530       141            mov a, Count1ms+0 ; If the low 8-bits overflow, then increment high 8-bits
0139 7002       142            jnz Inc_Done
013B 0531       143            inc Count1ms+1
013D            144   
013D            145   Inc_Done:
013D            146            ; Check if half second has passed
013D E530       147            mov a, Count1ms+0
013F B4F41E     148            cjne a, #low(500), Timer2_ISR_done ; Warning: this instruction changes the carry flag!
0142 E531       149            mov a, Count1ms+1
0144 B40119     150            cjne a, #high(500), Timer2_ISR_done
0147            151            
0147            152            ; 500 milliseconds have passed.  Set a flag so the main program knows
0147 D200       153            setb half_seconds_flag ; Let the main program know half second had passed
0149            154            ; Toggle LEDR0 so it blinks
0149 B2E8       155            cpl LEDRA.0
014B B28C       156            cpl TR0 ; Enable/disable timer/counter 0. This line creates a beep-silence-beep-silence sound.
014D            157            ; Reset to zero the milli-seconds counter, it is a 16-bit variable
014D E4         158            clr a
014E F530       159            mov Count1ms+0, a
0150 F531       160            mov Count1ms+1, a
0152            161            ; Increment the BCD counter
0152 E532       162            mov a, BCD_counter
0154 20E804     163            jb UPDOWN, Timer2_ISR_decrement
0157 2401       164            add a, #0x01
0159 8002       165            sjmp Timer2_ISR_da
015B            166   Timer2_ISR_decrement:
015B 2499       167            add a, #0x99 ; Adding the 10-complement of -1 is like subtracting 1.
015D            168   Timer2_ISR_da:
015D D4         169            da a ; Decimal adjust instruction.  Check datasheet for more details!
015E F532       170            mov BCD_counter, a
0160            171            
0160            172   Timer2_ISR_done:
0160 D0D0       173            pop psw
0162 D0E0       174            pop acc
0164 32         175            reti
0165            176   
0165            177   ; Look-up table for the 7-seg displays. (Segments are turn on with zero) 
0165            178   T_7seg:
0165 C0F9A4B0   179       DB 0xC0, 0xF9, 0xA4, 0xB0, 0x99        ; 0 TO 4
     99
016A 9282F880   180       DB 0x92, 0x82, 0xF8, 0x80, 0x90        ; 4 TO 9
     90
016F 8883C6A1   181       DB 0x88, 0x83, 0xC6, 0xA1, 0x86, 0x8E  ; A to F
     868E
0175            182   
0175            183   ; Displays a BCD number in HEX1-HEX0
0175            184   Display_BCD_7_Seg:
0175            185            
0175 900165     186            mov dptr, #T_7seg
0178            187   
0178 E532       188            mov a, BCD_counter
017A C4         189            swap a
017B 540F       190            anl a, #0FH
017D 93         191            movc a, @a+dptr
017E F592       192            mov HEX1, a
0180            193            
0180 E532       194            mov a, BCD_counter
0182 540F       195            anl a, #0FH
0184 93         196            movc a, @a+dptr
0185 F591       197            mov HEX0, a
0187            198            
0187 22         199            ret
0188            200   
0188            201   ;---------------------------------;
0188            202   ; Main program. Includes hardware ;
0188            203   ; initialization and 'forever'    ;
0188            204   ; loop.                           ;
0188            205   ;---------------------------------;
0188            206   main:
0188            207            ; Initialization
0188 75817F     208       mov SP, #0x7F
018B 1200F8     209       lcall Timer0_Init
018E 120114     210       lcall Timer2_Init
0191            211       ; We use the pins of P0 to control the LCD.  Configure as outputs.
0191 759A7F     212       mov P0MOD, #01111111b ; P0.0 to P0.6 are outputs.  ('1' makes the pin output)
0194            213       ; We use pins P1.5 and P1.1 as outputs also.  Configure accordingly.
0194 759B22     214       mov P1MOD, #00100010b ; P1.5 and P1.1 are outputs
0197 759CFF     215       mov P2MOD, #0xff
019A 759DFF     216       mov P3MOD, #0xff
019D            217       ; Turn off all the LEDs
019D 75E800     218       mov LEDRA, #0 ; LEDRA is bit addressable
01A0 759500     219       mov LEDRB, #0 ; LEDRB is NOT bit addresable
01A3 D2AF       220       setb EA   ; Enable Global interrupts
01A5 12008A     221       lcall ELCD_4BIT ; Configure LCD in four bit mode
01A8            222       ; For convenience a few handy macros are included in 'LCD_4bit_DE1Lite.inc':
01A8 C0E0       223            push acc
01AA 7401       223            mov a, #1
01AC 14         223            dec a
01AD 1200CC     223            lcall ?Set_Cursor_1 ; Select column and row
01B0 D0E0       223            pop acc
01B2 C083       224            push dph
01B4 C082       224            push dpl
01B6 C0E0       224            push acc
01B8 9000E7     224            mov dptr, #Initial_Message
01BB 1200BF     224            lcall ?Send_Constant_String
01BE D0E0       224            pop acc
01C0 D082       224            pop dpl
01C2 D083       224            pop dph
01C4 D200       225       setb half_seconds_flag
01C6 753200     226            mov BCD_counter, #0x00 ; Initialize counter to zero
01C9            227            
01C9            228            ; After initialization the program stays in this 'forever' loop
01C9            229   loop:
01C9 20F91C     230            jb KEY.1, loop_a  ; if the KEY1 button is not pressed skip
01CC C002       231            push AR2
01CE 7A32       231            mov R2, #50
01D0 12003B     231            lcall ?Wait_Milli_Seconds
01D3 D002       231            pop AR2         ; Debounce delay.  This macro is also in 'LCD_4bit_DE1Lite.inc'
01D5 20F910     232            jb KEY.1, loop_a  ; if the KEY1 button is not pressed skip
01D8 30F9FD     233            jnb KEY.1, $            ; Wait for button release.  The '$' means: jump to same instruction.
01DB            234            ; A valid press of the 'BOOT' button has been detected, reset the BCD counter.
01DB            235            ; But first stop timer 2 and reset the milli-seconds counter, to resync everything.
01DB C2CA       236            clr TR2 ; Stop timer 2
01DD E4         237            clr a
01DE F530       238            mov Count1ms+0, a
01E0 F531       239            mov Count1ms+1, a
01E2            240            ; Now clear the BCD counter
01E2 F532       241            mov BCD_counter, a
01E4 D2CA       242            setb TR2    ; Start timer 2
01E6 8003       243            sjmp loop_b ; Display the new value
01E8            244   loop_a:
01E8 3000DE     245            jnb half_seconds_flag, loop
01EB            246   loop_b:
01EB C200       247       clr half_seconds_flag ; We clear this flag in the main loop, but it is set in the ISR for timer 2
01ED C0E0       248            push acc
01EF 740E       248            mov a, #14
01F1 14         248            dec a
01F2 1200CC     248            lcall ?Set_Cursor_1 ; Select column and row
01F5 D0E0       248            pop acc     ; the place in the LCD where we want the BCD counter value
01F7 C000       249            push ar0
01F9 A832       249            mov r0, BCD_counter
01FB 1200D1     249            lcall ?Display_BCD
01FE D000       249            pop ar0 ; This macro is also in 'LCD_4bit_DE1Lite.inc'
0200 120175     250            lcall Display_BCD_7_Seg ; Also display the counter using the 7-segment displays.
0203 0201C9     251       ljmp loop
0206            252   END
