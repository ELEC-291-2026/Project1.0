                  2   $LIST
0000              4   
0000              5   CLK            EQU 33333333
0000              6   TIMER2_RATE    EQU 1000
0000              7   TIMER2_RELOAD  EQU (65536-(CLK/(12*TIMER2_RATE))) ; 1ms tick
0000              8   
0000              9   ; 2 kHz tone
0000             10   TONE_RATE      EQU 4000
0000             11   TIMER0_RELOAD  EQU (65536-(CLK/(12*TONE_RATE)))
0000             12   
0000             13   SPEAKER        BIT P1.0
0000             14   
0000             15   ; --------------------------
0000             16   ; VECTORS
0000             17   ; --------------------------
0000             18   CSEG at 0x0000
0000 02007F      19       ljmp main
0003             20   
000B             21   CSEG at 0x000B
000B 02003D      22       ljmp Timer0_ISR
000E             23   
002B             24   CSEG at 0x002B
002B 020060      25       ljmp Timer2_ISR
002E             26   
002E             27   ; --------------------------
002E             28   ; RAM
002E             29   ; --------------------------
0040             30   DSEG at 0x40
0040             31   ms_lo: ds 1
0041             32   ms_hi: ds 1
0042             33   
002E             34   CSEG
002E             35   
002E             36   ; --------------------------
002E             37   ; Timer0: tone
002E             38   ; --------------------------
002E             39   Timer0_Init:
002E 5389F0      40       anl TMOD, #0F0h
0031 438901      41       orl TMOD, #01h
0034 758CFD      42       mov TH0, #HIGH(TIMER0_RELOAD)
0037 758A4A      43       mov TL0, #LOW(TIMER0_RELOAD)
003A D2A9        44       setb ET0
003C 22          45       ret
003D             46   
003D             47   Timer0_ISR:
003D 758CFD      48       mov TH0, #HIGH(TIMER0_RELOAD)
0040 758A4A      49       mov TL0, #LOW(TIMER0_RELOAD)
0043 B290        50       cpl SPEAKER
0045 32          51       reti
0046             52   
0046             53   ; --------------------------
0046             54   ; Timer2: 1 ms counter
0046             55   ; --------------------------
0046             56   Timer2_Init:
0046 75C800      57       mov T2CON, #00h
0049 75CBF5      58       mov RCAP2H,#HIGH(TIMER2_RELOAD)
004C 75CA27      59       mov RCAP2L,#LOW(TIMER2_RELOAD)
004F 75CDF5      60       mov TH2,#HIGH(TIMER2_RELOAD)
0052 75CC27      61       mov TL2,#LOW(TIMER2_RELOAD)
0055             62   
0055 754000      63       mov ms_lo,#0
0058 754100      64       mov ms_hi,#0
005B             65   
005B D2AD        66       setb IE.5        ; ET2
005D D2CA        67       setb TR2
005F 22          68       ret
0060             69   
0060             70   Timer2_ISR:
0060 0540        71       inc ms_lo
0062 E540        72       mov a, ms_lo
0064 7002        73       jnz t2_done
0066 0541        74       inc ms_hi
0068             75   t2_done:
0068 32          76       reti
0069             77   
0069             78   ; --------------------------
0069             79   ; Wait R7 ms
0069             80   ; --------------------------
0069             81   WaitMs:
0069 AE40        82       mov r6, ms_lo
006B AD41        83       mov r5, ms_hi
006D             84   
006D             85   wait_loop:
006D E540        86       mov a, ms_lo
006F C3          87       clr c
0070 9E          88       subb a, r6
0071 F5F0        89       mov b, a
0073             90   
0073 E541        91       mov a, ms_hi
0075 9D          92       subb a, r5
0076 7006        93       jnz done
0078             94   
0078 E5F0        95       mov a, b
007A C3          96       clr c
007B 9F          97       subb a, r7
007C 40EF        98       jc wait_loop
007E             99   done:
007E 22         100       ret
007F            101   
007F            102   ; --------------------------
007F            103   ; MAIN
007F            104   ; --------------------------
007F            105   main:
007F 75817F     106       mov SP,#7Fh
0082            107   
0082 12002E     108       lcall Timer0_Init
0085 120046     109       lcall Timer2_Init
0088 D2AF       110       setb EA
008A            111   
008A            112   forever:
008A D28C       113       setb TR0        ; sound ON
008C 7FFA       114       mov r7,#250
008E 120069     115       lcall WaitMs
0091 7FFA       116       mov r7,#250
0093 120069     117       lcall WaitMs
0096            118   
0096 C28C       119       clr TR0         ; sound OFF
0098 C290       120       clr SPEAKER
009A 7FFA       121       mov r7,#250
009C 120069     122       lcall WaitMs
009F 7FFA       123       mov r7,#250
00A1 120069     124       lcall WaitMs
00A4            125   
00A4 80E4       126       sjmp forever
00A6            127   
00A6            128   END
